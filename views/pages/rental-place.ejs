<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 pt-32">
    <!-- Header/Breadcrumbs -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm font-medium text-apple-text-gray">
                    <li><a href="/home" class="hover:text-apple-dark transition-colors">Home</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li class="text-apple-dark">Rentalplace</li>

                </ol>
            </nav>
            <h1 class="text-4xl font-bold text-apple-dark tracking-tight font-serif">Rentalplace</h1>

            <p class="mt-2 text-apple-text-gray"><%= total %> books available for rent</p>
        </div>

        <!-- Actions: Search & Mobile Filters -->
        <div class="flex flex-row items-center gap-2 w-full md:w-1/2 md:ml-auto justify-end">
            <!-- Search Bar -->
            <div class="relative flex-grow">
                <form action="/rental-place" method="GET" class="relative group">
                    <% if (query.category) { %>
                        <% if (Array.isArray(query.category)) { %>
                            <% query.category.forEach(cat => { %>
                                <input type="hidden" name="category" value="<%= cat %>">
                            <% }) %>
                        <% } else { %>
                            <input type="hidden" name="category" value="<%= query.category %>">
                        <% } %>
                    <% } %>
                    <% if (query.sort) { %>
                        <input type="hidden" name="sort" value="<%= query.sort %>">
                    <% } %>
                    <input type="text" name="search" value="<%= query.search || '' %>"
                        placeholder="Search rental books..."
                        class="w-full pl-12 pr-10 py-2.5 bg-white/5 backdrop-blur-md border border-white/10 rounded-xl focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue transition-all shadow-xl group-hover:shadow-2xl text-sm text-apple-dark">
                    <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray"></i>
                    <% if (query.search) { %>
                        <button type="button" onclick="window.location.href='/rental-place?<%= new URLSearchParams({...query, search: ''}).toString() %>'"
                            class="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:bg-white/10 rounded-full transition-colors">
                            <i data-lucide="x" class="w-4 h-4 text-apple-text-gray"></i>
                        </button>
                    <% } %>
                </form>
            </div>

            <!-- Mobile Filter Toggle -->
            <button onclick="toggleMobileFilters()" 
                class="md:hidden flex items-center justify-center w-10 h-10 bg-apple-blue text-white rounded-xl shadow-md transition-transform active:scale-95 shrink-0">
                <i data-lucide="sliders-horizontal" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <!-- Sidebar filters -->
        <aside class="hidden lg:block lg:col-span-1">
            <div class="sticky top-32 space-y-8">
                <%- include('../partials/rental-filter-panel') %>

                <div class="bg-apple-blue/5 rounded-3xl p-6 border border-apple-blue/10">
                    <h4 class="font-bold text-apple-dark mb-2 tracking-tight">Have books to share?</h4>
                    <p class="text-xs text-apple-text-gray mb-4 leading-relaxed">Join our community of book lovers and start earning from your collection.</p>
                    <a href="/list-rental-book" class="inline-flex items-center gap-2 px-4 py-2 bg-apple-blue text-white rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-apple-blue/90 transition-all shadow-lg shadow-apple-blue/10">
                        <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                        Start Listing
                    </a>
                </div>
            </div>
        </aside>


        <main class="lg:col-span-3">
            <% if (rentals.length > 0) { %>
                <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
                    <% rentals.forEach(rental => { %>
                        <div class="bg-apple-card border border-white/10 rounded-2xl sm:rounded-3xl overflow-hidden group hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
                            <div class="relative aspect-[3/4] overflow-hidden">
                                <img src="<%= rental.coverImage || rental.images[0] %>" alt="<%= rental.bookTitle %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                                <div class="absolute top-2 right-2 sm:top-4 sm:right-4 bg-apple-blue/90 backdrop-blur-md px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg sm:rounded-xl text-[10px] sm:text-sm font-bold text-white shadow-lg">
                                    ₹<%= rental.dailyRate %>/d
                                </div>
                                <div class="absolute bottom-2 left-2 sm:bottom-4 sm:left-4 bg-black/60 backdrop-blur-md px-2 py-1 rounded-lg text-[8px] sm:text-[10px] font-bold text-white uppercase tracking-widest">
                                    <%= rental.bookCondition %>
                                </div>
                            </div>
                            <div class="p-3 sm:p-6">
                                <div class="mb-3 sm:mb-4">
                                    <span class="inline-block px-2 py-0.5 bg-apple-blue/10 text-apple-blue rounded text-[8px] sm:text-[10px] font-bold uppercase tracking-wider mb-1 sm:mb-2">
                                        <%= rental.category ? rental.category.name : 'Uncategorized' %>
                                    </span>
                                    <h3 class="text-sm sm:text-lg font-bold text-apple-dark leading-tight group-hover:text-apple-blue transition-colors truncate">
                                        <a href="/rental/<%= rental._id %>"><%= rental.bookTitle %></a>
                                    </h3>
                                    <p class="text-[10px] sm:text-sm text-apple-text-gray mt-0.5 sm:mt-1 truncate">by <%= rental.author %></p>
                                </div>
                                
                                <div class="hidden sm:flex items-center justify-between pt-4 border-t border-white/5">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-apple-blue/20 flex items-center justify-center">
                                            <i data-lucide="user" class="w-3 h-3 text-apple-blue"></i>
                                        </div>
                                        <span class="text-xs text-apple-text-gray font-medium truncate max-w-[80px]"><%= rental.owner.firstName %></span>
                                    </div>
                                    <div class="text-[10px] font-bold text-apple-text-gray/50 uppercase tracking-widest">
                                        Min <%= rental.minRentalDays %> Days
                                    </div>
                                </div>
                                
                                <a href="/rental/<%= rental._id %>" class="mt-2 sm:mt-4 w-full py-2 sm:py-3 bg-white/5 border border-white/10 rounded-lg sm:rounded-xl text-[10px] sm:text-xs font-bold text-apple-dark hover:bg-apple-blue hover:text-white hover:border-apple-blue transition-all flex items-center justify-center gap-2 uppercase tracking-widest">
                                    View Details
                                </a>
                            </div>
                        </div>
                    <% }) %>
                </div>


                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                    <div class="mt-16 flex items-center justify-center gap-2">
                        <% if (currentPage > 1) { %>
                            <a href="/rental-place?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>"
                                class="p-2 rounded-xl border border-white/10 hover:bg-white/5 transition-all text-apple-dark">
                                <i data-lucide="chevron-left" class="w-5 h-5"></i>
                            </a>
                        <% } %>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <a href="/rental-place?<%= new URLSearchParams({...query, page: i}).toString() %>"
                                class="w-10 h-10 flex items-center justify-center rounded-xl font-medium transition-all
                                <%= currentPage === i ? 'bg-apple-blue text-white shadow-lg' : 'text-apple-text-gray hover:bg-white/5 border border-transparent' %>">
                                <%= i %>
                            </a>
                        <% } %>

                        <% if (currentPage < totalPages) { %>
                            <a href="/rental-place?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>"
                                class="p-2 rounded-xl border border-white/10 hover:bg-white/5 transition-all text-apple-dark">
                                <i data-lucide="chevron-right" class="w-5 h-5"></i>
                            </a>
                        <% } %>
                    </div>
                <% } %>
            <% } else { %>
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center py-24 bg-white/5 rounded-[40px] border border-dashed border-white/10">
                    <div class="w-20 h-20 bg-apple-blue/10 rounded-3xl flex items-center justify-center mb-6">
                        <i data-lucide="search-x" class="w-10 h-10 text-apple-blue"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-apple-dark mb-2 font-serif">No rental books found</h2>
                    <p class="text-apple-text-gray mb-8">Be the first one to list a book in this category!</p>
                    <a href="/list-rental-book" class="px-8 py-3 bg-apple-blue text-white rounded-2xl font-bold shadow-xl shadow-apple-blue/20 transition-transform active:scale-95">List a Book Now</a>
                </div>
            <% } %>
        </main>
    </div>
</div>

<!-- Mobile Filter Drawer -->
<div id="mobileFilterDrawer" class="lg:hidden fixed inset-0 z-[100001] pointer-events-none invisible">

    <div id="mobileFilterBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300" onclick="toggleMobileFilters()"></div>
    <div id="mobileFilterContent" class="absolute bottom-0 left-0 right-0 bg-apple-card/95 backdrop-blur-3xl border-t border-white/20 rounded-t-[40px] p-8 pb-12 translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] pointer-events-auto max-h-[92vh] overflow-y-auto shadow-[0_-20px_50px_rgba(0,0,0,0.3)]">
        <!-- Drawer Handle -->
        <div class="w-12 h-1.5 bg-gray-300/50 rounded-full mx-auto mb-8"></div>
        
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-apple-dark font-serif">Filters & Sort</h2>
            <button onclick="toggleMobileFilters()" class="p-2 bg-white/5 rounded-full">
                <i data-lucide="x" class="w-5 h-5 text-apple-text-gray"></i>
            </button>
        </div>
        <%- include('../partials/rental-filter-panel') %>
    </div>
</div>

<script>

    function toggleMobileFilters() {
        const drawer = document.getElementById('mobileFilterDrawer');
        const backdrop = document.getElementById('mobileFilterBackdrop');
        const content = document.getElementById('mobileFilterContent');
        const isHidden = drawer.classList.contains('invisible');

        if (isHidden) {
            drawer.classList.remove('invisible', 'pointer-events-none');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                backdrop.classList.add('opacity-100');
                content.classList.remove('translate-y-full');
            }, 10);
        } else {
            backdrop.classList.remove('opacity-100');
            content.classList.add('translate-y-full');
            document.body.style.overflow = '';
            setTimeout(() => {
                drawer.classList.add('invisible', 'pointer-events-none');
            }, 300);
        }
    }

</script>

    </div>
</div>
