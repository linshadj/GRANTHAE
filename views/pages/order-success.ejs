<div class="min-h-[70vh] flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8">
    <div class="glass-card max-w-2xl w-full p-10 sm:p-16 rounded-[2.5rem] text-center shadow-2xl border border-white/40">
        
        <!-- Animated Illustration -->
        <div class="relative w-40 h-40 mx-auto mb-8">
            <div class="absolute inset-0 bg-green-100 rounded-full animate-pulse blur-xl opacity-50"></div>
            <div class="relative bg-gradient-to-tr from-green-400 to-green-300 w-full h-full rounded-full flex items-center justify-center shadow-lg shadow-green-500/30">
                <i data-lucide="check" class="w-20 h-20 text-white"></i>
            </div>
            <!-- Decorative particles -->
            <div class="absolute top-0 right-0 w-4 h-4 bg-yellow-400 rounded-full animate-bounce" style="animation-delay: 100ms;"></div>
            <div class="absolute bottom-4 left-0 w-3 h-3 bg-blue-400 rounded-full animate-bounce" style="animation-delay: 300ms;"></div>
            <div class="absolute top-1/2 -right-6 w-5 h-5 bg-purple-400 rounded-full animate-bounce" style="animation-delay: 500ms;"></div>
        </div>

        <h1 class="text-4xl sm:text-5xl font-bold text-apple-dark font-luxury mb-4">Thank You!</h1>
        <p class="text-xl text-apple-text-gray mb-10">
            Your order has been placed successfully.<br>
            <span class="text-sm">We'll send you a confirmation email shortly.</span>
        </p>

        <div class="bg-gray-50 rounded-2xl p-6 mb-10 inline-block text-left w-full sm:w-auto border border-gray-100">
            <p class="text-sm text-gray-500 uppercase tracking-widest mb-1 font-semibold">Order Reference ID</p>
            <p class="text-lg font-mono font-bold text-apple-dark"><%= orderId %></p>
        </div>

        <!-- Call to Actions -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-4">
            <a href="/profile/orders/<%= orderId %>" class="btn-primary w-full sm:w-auto px-8 py-3.5">
                View Order Details
            </a>
            <a href="/marketplace" class="btn-secondary w-full sm:w-auto px-8 py-3.5">
                Continue Shopping
            </a>
        </div>
    </div>
</div>
