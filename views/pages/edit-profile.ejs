    async function confirmDeleteAddress() {
        if (!selectedAddressId) return;

        try {
            const res = await fetch("/profile/delete-address", {
                method: "DELETE",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({
                    addressId: selectedAddressId,
                }),
            });

            const data = await res.json();

            if (data.success) {
                window.location.reload(); // simple & safe
            } else {
                alert(data.message || "Failed to delete address.");
            }

        } catch (err) {
            console.error("Delete error:", err);
            alert("Something went wrong.");
        }

        closeDeleteModal();
    }


    function openAddressModal(mode = "add", data = null, id = null) {

        addressMode = mode;
        editingAddressId = id;

        const addressItems = document.querySelectorAll("#address-list .group.relative.z-20");

        if (mode === "add" && addressItems.length >= 5) {
            openLimitModal();   
            return;
        }

        if (!modal) return;

        const title = document.getElementById("modal-title");
        const btn = document.getElementById("save-address-btn");

        // Reset fields
        document.getElementById("address-label").value = "";
        document.getElementById("address-streetAddress").value = "";
        document.getElementById("address-city").value = "";
        document.getElementById("address-state").value = "";
        document.getElementById("address-pin").value = "";
        document.getElementById("address-phone").value = "";
        document.getElementById("address-country").value = "";

        if (mode === "edit" && data) {
            title.textContent = "Edit Address";
            btn.textContent = "Update Address";
            document.getElementById("address-label").value = data.label || "";
            document.getElementById("address-streetAddress").value = data.streetAddress || "";
            document.getElementById("address-city").value = data.city || "";
            document.getElementById("address-state").value = data.state || "";
            document.getElementById("address-pin").value = data.pin || "";
            document.getElementById("address-phone").value = data.phoneNumber || "";
            document.getElementById("address-country").value = data.country || "";
        } else {
            addressMode = "add";
            editingAddressId = null;
            title.textContent = "Add New Address";
            btn.textContent = "Save Address";
        }

        // Move to body to escape blur and stacking context
        document.body.appendChild(modal);
        toggleModalState(true);
        modal.classList.remove("hidden");
        setTimeout(() => {
            backdrop.classList.remove("opacity-0");
            panel.classList.remove("opacity-0", "translate-y-4", "sm:scale-95");
            panel.classList.add("opacity-100", "translate-y-0", "sm:scale-100");
        }, 10);
    }

    function closeAddressModal() {
        resetErrorFields()
        if (!modal) return;
        backdrop.classList.add("opacity-0");
        panel.classList.remove("opacity-100", "translate-y-0", "sm:scale-100");
        panel.classList.add("opacity-0", "translate-y-4", "sm:scale-95");
        setTimeout(() => {
            modal.classList.add("hidden");
            toggleModalState(false);
        }, 200);
    }


    // ADD NEW ADDRESS

    const addNewAddressform = document.getElementById("add-new-address-form");

    addNewAddressform.addEventListener("submit", async (e) => {
        e.preventDefault();
        const addressLabel = document.getElementById("address-label");
        const addressStreetAddress = document.getElementById("address-streetAddress");
        const addressCity = document.getElementById("address-city");
        const addressState = document.getElementById("address-state");
        const addressPin = document.getElementById("address-pin");
        const addressPhone = document.getElementById("address-phone");
        const addressCountry = document.getElementById("address-country");
        const submitButton = document.getElementById("save-address-btn");

        const labelError = document.getElementById("labelError");
        const streetAddressError = document.getElementById("streetAddressError");
        const cityError = document.getElementById("cityError");
        const stateError = document.getElementById("stateError");
        const pinCodeError = document.getElementById("pinCodeError");
        const phoneNumberError = document.getElementById("phoneNumberError");
        const countryError = document.getElementById("countryError");
        const addressFormError = document.getElementById("addressFormError");

        submitButton.disabled = true;
        submitButton.classList.add("opacity-50", "cursor-not-allowed");
        submitButton.textContent = "Saving...";

        let isValid = true; 

        if (addressLabel.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            labelError.classList.remove("hidden");
            labelError.textContent = "Address label is required.";
        } else {
            labelError.classList.add("hidden");
        }

        if (addressStreetAddress.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            streetAddressError.classList.remove("hidden");
            streetAddressError.textContent = "Street address is required.";
        } else {
            streetAddressError.classList.add("hidden");
        }

        if (addressCity.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            cityError.classList.remove("hidden");
            cityError.textContent = "City is required.";
        } else {
            cityError.classList.add("hidden");
        }

        if (addressState.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            stateError.classList.remove("hidden");
            stateError.textContent = "State is required.";
        } else {
            stateError.classList.add("hidden");
        }

        if (addressPin.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            pinCodeError.classList.remove("hidden");
            pinCodeError.textContent = "PIN is required.";
        } else if (!validatePin(addressPin.value.trim())) {
            resetSubmitButton(submitButton);
            isValid = false;
            pinCodeError.classList.remove("hidden");
            pinCodeError.textContent = "PIN must be 6 digits.";
        } else {
            pinCodeError.classList.add("hidden");
        }

        if (addressPhone.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            phoneNumberError.classList.remove("hidden");
            phoneNumberError.textContent = "Phone number is required.";
        } else if (!validatePhone(addressPhone.value.trim())) {
            resetSubmitButton(submitButton);
            isValid = false;
            phoneNumberError.classList.remove("hidden");
            phoneNumberError.textContent = "Phone number must be 10 digits.";
        } else {
            phoneNumberError.classList.add("hidden");
        }

        if (addressCountry.value.trim() === "") {
            resetSubmitButton(submitButton);
            isValid = false;
            countryError.classList.remove("hidden");
            countryError.textContent = "Country is required.";
        } else {
            countryError.classList.add("hidden");
        }


        if (isValid) {

            let url = "";
            let method = "";

            if (addressMode === "add") {
                url = "/profile/edit/add-new-address";
                method = "POST";
            } else if (addressMode === "edit") {
                url = `/profile/edit/address/${editingAddressId}`;
                method = "PATCH";
            }

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({
                        label: addressLabel.value.trim().toUpperCase(),
                        streetAddress: addressStreetAddress.value.trim(),
                        city: addressCity.value.trim(),
                        state: addressState.value.trim(),
                        pinCode: addressPin.value.trim(),
                        phoneNumber: addressPhone.value.trim(),
                        country: addressCountry.value.trim(),
                    }),
                });

                const data = await res.json();

                if (data.success) {
                    window.location.reload();
                } else {
                    resetSubmitButton(submitButton);
                    addressFormError.classList.remove("hidden");
                    addressFormError.textContent = data.message;
                }

            } catch (error) {
                resetSubmitButton(submitButton);
                addressFormError.classList.remove("hidden");
                addressFormError.textContent = "Something went wrong.";
            }
        }

    });

    // Validate phoneNUmber
    function validatePhone(phone) {
        const phoneRegex = /^\d{10}$/;
        return phoneRegex.test(phone);
    }

    //  Validate Pin
    function validatePin(pin) {
        const pinRegex = /^\d{6}$/;
        return pinRegex.test(pin);
    }

    if (defaultBackdrop) defaultBackdrop.addEventListener("click", closeDefaultModal);
    if (deleteBackdrop) deleteBackdrop.addEventListener("click", closeDeleteModal);
    if (backdrop) backdrop.addEventListener("click", closeAddressModal);

    function updateEmptyState() {
        const list = document.getElementById("address-list");
        const emptyMsg = document.getElementById("no-addresses-message");
        if (list && emptyMsg) {
            // Count items that are not the empty message
            const items = list.querySelectorAll(".group.relative.z-20");
            const hasAddresses = items.length > 0;
            emptyMsg.classList.toggle("hidden", hasAddresses);
        }
    }
    document.addEventListener("DOMContentLoaded", updateEmptyState);
</script>