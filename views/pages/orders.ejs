<%
    const formatDate = (date) => new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 });
    const getDisplayStatus = (order) => order.orderStatus === 'Cancelled' ? 'Cancelled' : order.paymentStatus === 'Failed' ? 'Failed' : order.orderStatus;
    const getStatusClass = (status) => {
        if (status === 'Delivered') return 'bg-green-500/10 text-green-400 border-green-500/20';
        if (status === 'Shipped') return 'bg-blue-500/10 text-blue-400 border-blue-500/20';
        if (status === 'Out for delivery') return 'bg-purple-500/10 text-purple-400 border-purple-500/20';
        if (status === 'Cancelled' || status === 'Failed') return 'bg-red-500/10 text-red-400 border-red-500/20';
        return 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20';
    };
    const getActionLabel = (order, displayStatus) => {
        if (displayStatus === 'Failed' && order.paymentMethod === 'Razorpay') return 'Retry Payment';
        if (displayStatus === 'Delivered') return 'View Details';
        if (displayStatus === 'Shipped' || displayStatus === 'Out for delivery') return 'Track Order';
        return 'View Details';
    };
    const getActionHref = (order, displayStatus) => {
        if (displayStatus === 'Failed' && order.paymentMethod === 'Razorpay') return `/payment-failure/${order._id}`;
        return `/profile/orders/${order._id}`;
    };
%>

<div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 id="page-title" class="text-2xl font-bold text-apple-dark">Order History</h1>
            <p class="text-apple-text-gray/80 text-sm">Track purchased books, payments, and returns.</p>
        </div>

        <div class="bg-white/5 p-1 rounded-xl border border-white/10 flex items-center w-max">
            <a href="/profile/orders"
                class="px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 bg-apple-card shadow-sm text-apple-dark">
                My Orders
            </a>
            <a href="/profile/my-listings"
                class="px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 text-apple-text-gray hover:text-apple-dark">
                My Listings
            </a>
            <a href="/profile/my-listings/rental-requests"
                class="px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 text-apple-text-gray hover:text-apple-dark">
                Rentals
            </a>
        </div>

        <a href="/marketplace" class="btn-secondary hidden md:flex items-center gap-2 text-xs">
            <i data-lucide="shopping-bag" class="w-4 h-4"></i>
            Browse More
        </a>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="px-6 py-4 border-b border-white/5 flex flex-col lg:flex-row justify-between lg:items-center gap-4 bg-green-50/5">
            <h3 class="font-semibold text-apple-dark flex items-center gap-2">
                <i data-lucide="shopping-bag" class="w-4 h-4 text-green-600"></i>
                Purchased Books
            </h3>

            <form action="/profile/orders" method="GET" class="relative w-full lg:w-80 group">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray/50 group-focus-within:text-apple-blue transition-colors"></i>
                <input type="text" name="search" value="<%= searchQuery || '' %>" placeholder="Search order ID..."
                    class="w-full h-10 pl-10 pr-10 rounded-xl bg-white/5 border border-white/10 text-sm text-apple-dark placeholder:text-apple-text-gray/50 focus:outline-none focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue/50 transition-all">
                <% if (searchQuery) { %>
                    <a href="/profile/orders" class="absolute right-3 top-1/2 -translate-y-1/2 text-apple-text-gray/50 hover:text-red-500 transition-colors">
                        <i data-lucide="x" class="w-4 h-4"></i>
                    </a>
                <% } %>
            </form>
        </div>

        <% if (orders && orders.length > 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-apple-text-gray uppercase bg-white/5">
                        <tr>
                            <th class="px-6 py-3 font-medium min-w-[260px]">Book Info</th>
                            <th class="px-6 py-3 font-medium whitespace-nowrap">Date</th>
                            <th class="px-6 py-3 font-medium whitespace-nowrap">Status</th>
                            <th class="px-6 py-3 font-medium whitespace-nowrap">Payment</th>
                            <th class="px-6 py-3 font-medium whitespace-nowrap">Total</th>
                            <th class="px-6 py-3 font-medium text-right whitespace-nowrap">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% orders.forEach(order => { %>
                            <%
                                const displayStatus = getDisplayStatus(order);
                                const firstItem = order.items && order.items.length > 0 ? order.items[0] : null;
                                const product = firstItem ? firstItem.product : null;
                                const coverImage = product && (product.coverImage || (product.images && product.images[0])) ? (product.coverImage || product.images[0]) : '/images/default-book.jpg';
                                const itemCount = order.items ? order.items.reduce((total, item) => total + Number(item.quantity || 0), 0) : 0;
                            %>
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <img src="<%= coverImage %>" class="w-10 h-14 object-cover rounded shadow-sm border border-white/10" alt="<%= product ? product.name : 'Book' %>">
                                        <div class="min-w-0">
                                            <div class="font-medium text-apple-dark line-clamp-1">
                                                <%= product ? product.name : 'Unknown Product' %>
                                            </div>
                                            <div class="text-xs text-apple-text-gray mt-0.5">
                                                <%= product && product.author ? product.author : `Order #${order.orderID}` %>
                                            </div>
                                            <div class="text-[10px] text-apple-text-gray/60 mt-1 uppercase tracking-wider">
                                                <%= itemCount %> item<%= itemCount === 1 ? '' : 's' %>
                                                <% if (order.items && order.items.length > 1) { %>
                                                    &middot; <%= order.items.length - 1 %> more title<%= order.items.length - 1 === 1 ? '' : 's' %>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-apple-text-gray whitespace-nowrap">
                                    <%= formatDate(order.createdAt) %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= getStatusClass(displayStatus) %>">
                                        <%= displayStatus %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-apple-dark font-medium">
                                        <%= order.paymentMethod === 'COD' ? 'Cash on Delivery' : order.paymentMethod %>
                                    </div>
                                    <div class="text-[10px] uppercase tracking-wider <%= order.paymentStatus === 'Success' ? 'text-green-500' : order.paymentStatus === 'Failed' ? 'text-red-500' : 'text-yellow-500' %>">
                                        <%= order.paymentStatus %>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-medium text-apple-dark whitespace-nowrap">
                                    ₹<%= formatAmount(order.totalAmount) %>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                    <a href="<%= getActionHref(order, displayStatus) %>" class="text-sm text-apple-blue hover:underline">
                                        <%= getActionLabel(order, displayStatus) %>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-10 sm:p-14 text-center text-apple-text-gray text-sm">
                <div class="w-16 h-16 bg-white/5 text-apple-text-gray/30 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-white/10">
                    <i data-lucide="package" class="w-8 h-8"></i>
                </div>
                <% if (searchQuery) { %>
                    <h2 class="text-xl font-bold text-apple-dark mb-2">No matching orders</h2>
                    <p class="mb-6">No orders matched "<%= searchQuery %>".</p>
                    <a href="/profile/orders" class="btn-secondary inline-flex items-center gap-2 px-6 py-3">
                        <i data-lucide="x" class="w-4 h-4"></i>
                        Clear Search
                    </a>
                <% } else { %>
                    <h2 class="text-xl font-bold text-apple-dark mb-2">No orders yet</h2>
                    <p class="mb-6">Your purchased books will appear here.</p>
                    <a href="/marketplace" class="btn-primary inline-flex items-center gap-2 px-6 py-3">
                        <i data-lucide="shopping-bag" class="w-4 h-4"></i>
                        Explore Marketplace
                    </a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>
