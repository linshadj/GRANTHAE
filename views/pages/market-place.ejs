<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 pt-32">
    <!-- Header/Breadcrumbs -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm font-medium text-apple-text-gray">
                    <li><a href="/home" class="hover:text-apple-dark transition-colors">Home</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li class="text-apple-dark">Marketplace</li>
                </ol>
            </nav>
            <h1 class="text-4xl font-bold text-apple-dark tracking-tight">Marketplace</h1>
            <p class="mt-2 text-apple-text-gray"><%= totalProducts %> matches found</p>
        </div>

        <!-- Actions: Search & Mobile Filters -->
        <div class="flex flex-row items-center gap-2 w-full md:w-1/2 md:ml-auto justify-end">
            <!-- Search Bar -->
            <div class="relative flex-grow">
                <form action="/marketplace" method="GET" class="relative group">
                    <% if (query.category) { %>
                        <% if (Array.isArray(query.category)) { %>
                            <% query.category.forEach(cat => { %>
                                <input type="hidden" name="category" value="<%= cat %>">
                            <% }) %>
                        <% } else { %>
                            <input type="hidden" name="category" value="<%= query.category %>">
                        <% } %>
                    <% } %>
                    <% if (query.sort) { %>
                        <input type="hidden" name="sort" value="<%= query.sort %>">
                    <% } %>
                    <input type="text" name="search" value="<%= query.search || '' %>"
                        placeholder="Search books..."
                        class="w-full pl-12 pr-10 py-2.5 bg-white/5 backdrop-blur-md border border-white/10 rounded-xl focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue transition-all shadow-xl group-hover:shadow-2xl text-sm text-apple-dark">
                    <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray"></i>
                    <% if (query.search) { %>
                        <button type="button" onclick="window.location.href='/marketplace?<%= new URLSearchParams({...query, search: ''}).toString() %>'"
                            class="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:bg-white/10 rounded-full transition-colors">
                            <i data-lucide="x" class="w-4 h-4 text-apple-text-gray"></i>
                        </button>
                    <% } %>

                </form>
            </div>

            <!-- Mobile Filter Toggle (Matching Search Height) -->
            <button onclick="toggleMobileFilters()" 
                class="md:hidden flex items-center justify-center w-10 h-10 bg-apple-dark text-white rounded-xl shadow-md transition-transform active:scale-95 shrink-0">
                <i data-lucide="sliders-horizontal" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <!-- Sidebar filters -->
        <aside class="hidden lg:block lg:col-span-1">
            <div class="sticky top-32">
                <%- include('../partials/filter-panel') %>
            </div>
        </aside>


        <!-- Product Grid -->
        <main class="lg:col-span-3">
            <% if (products.length > 0) { %>
                <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
                    <% products.forEach(book => { %>
                        <%- include('../partials/book-card', { book, 
                             book: {
                                 ...book,
                                 title: book.name,
                                 image: book.coverImage || '/images/default-book.jpg',
                                 rating: book.avgRating || '4.5'
                             }
                        }) %>
                    <% }) %>
                </div>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                    <div class="mt-16 flex items-center justify-center gap-2">
                        <% if (currentPage > 1) { %>
                            <a href="/marketplace?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>"
                                class="p-2 rounded-xl border border-gray-200 hover:bg-white hover:shadow-md transition-all text-apple-dark">
                                <i data-lucide="chevron-left" class="w-5 h-5"></i>
                            </a>
                        <% } %>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <a href="/marketplace?<%= new URLSearchParams({...query, page: i}).toString() %>"
                                class="w-10 h-10 flex items-center justify-center rounded-xl font-medium transition-all
                                <%= currentPage === i ? 'bg-apple-dark text-white shadow-lg' : 'text-apple-text-gray hover:bg-white hover:shadow-md border border-transparent hover:border-gray-100' %>">
                                <%= i %>
                            </a>
                        <% } %>

                        <% if (currentPage < totalPages) { %>
                            <a href="/marketplace?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>"
                                class="p-2 rounded-xl border border-gray-200 hover:bg-white hover:shadow-md transition-all text-apple-dark">
                                <i data-lucide="chevron-right" class="w-5 h-5"></i>
                            </a>
                        <% } %>
                    </div>
                <% } %>
            <% } else { %>
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center py-20 bg-apple-teal/10 rounded-3xl border border-dashed border-apple-teal/30">
                    <div class="w-20 h-20 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-6">
                        <i data-lucide="search-x" class="w-10 h-10 text-apple-text-gray"></i>
                    </div>
                    <h2 class="text-xl font-bold text-apple-dark mb-2">No books found</h2>
                    <p class="text-apple-text-gray mb-8">Try adjusting your filters or search terms.</p>
                    <a href="/marketplace" class="btn-primary">Clear all filters</a>
                </div>
            <% } %>
        </main>
    </div>
</div>

<!-- Mobile Filter Drawer -->
<div id="mobileFilterDrawer" class="lg:hidden fixed inset-0 z-[100001] pointer-events-none invisible">

    <div id="mobileFilterBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300" onclick="toggleMobileFilters()"></div>
    <div id="mobileFilterContent" class="absolute bottom-0 left-0 right-0 bg-apple-card/95 backdrop-blur-3xl border-t border-white/20 rounded-t-[40px] p-8 pb-12 translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] pointer-events-auto max-h-[92vh] overflow-y-auto shadow-[0_-20px_50px_rgba(0,0,0,0.3)]">
        <!-- Drawer Handle -->
        <div class="w-12 h-1.5 bg-gray-300/50 rounded-full mx-auto mb-8"></div>
        
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-apple-dark">Filters & Sort</h2>
            <button onclick="toggleMobileFilters()" class="p-2 bg-gray-100 rounded-full">
                <i data-lucide="x" class="w-5 h-5 text-apple-text-gray"></i>
            </button>
        </div>
        <%- include('../partials/filter-panel') %>
    </div>
</div>


<script>
    function toggleMobileFilters() {
        const drawer = document.getElementById('mobileFilterDrawer');
        const backdrop = document.getElementById('mobileFilterBackdrop');
        const content = document.getElementById('mobileFilterContent');
        const isHidden = drawer.classList.contains('invisible');

        if (isHidden) {
            drawer.classList.remove('invisible', 'pointer-events-none');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                backdrop.classList.add('opacity-100');
                content.classList.remove('translate-y-full');
            }, 10);
        } else {
            backdrop.classList.remove('opacity-100');
            content.classList.add('translate-y-full');
            document.body.style.overflow = '';
            setTimeout(() => {
                drawer.classList.add('invisible', 'pointer-events-none');
            }, 300);
        }
    }

</script>
