<div class="text-center mb-8">
    <h1 class="text-3xl font-bold font-serif text-apple-dark mb-2">Reset Password</h1>
    <p class="text-apple-text-gray">Enter your email and we'll send you instructions.</p>
</div>

<form class="space-y-5" action="/otp" method="GET">
    <div>
        <label class="block text-sm font-medium text-apple-text-gray mb-1.5">Email Address</label>
        <div class="relative">
            <i data-lucide="mail"
                class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-apple-dark transition-colors"></i>
            <input type="email"
                class="w-full pl-12 pr-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-apple-gold/20 focus:border-apple-gold outline-none transition-all placeholder-gray-300 text-apple-dark"
                placeholder="you@example.com">
        </div>
    </div>

    <button type="submit" class="w-full btn-primary py-3.5 shadow-lg shadow-apple-gold/20">
        Send Instructions
    </button>
</form>

<p class="mt-8 text-center text-sm text-apple-text-gray">
    Remember your password?
    <a href="/sign-in" class="relative z-20 text-apple-dark hover:underline decoration-apple-gold/50">Login here</a>
</p>