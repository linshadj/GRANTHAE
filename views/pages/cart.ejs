<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-24 min-h-[70vh]">
    <div class="mb-10 text-center md:text-left">
        <h1 class="text-4xl font-bold text-apple-dark font-luxury">Your Cart</h1>
        <p class="text-apple-text-gray mt-2 text-lg">Review your items before checkout.</p>
    </div>

    <% if (cartItems.length === 0) { %>
        <div class="glass-card py-32 px-8 text-center rounded-3xl w-full border border-white/10 shadow-xl">
            <div class="w-24 h-24 bg-apple-blue/10 text-apple-blue rounded-full flex items-center justify-center mx-auto mb-6">
                <i data-lucide="shopping-bag" class="w-10 h-10"></i>
            </div>
            <h2 class="text-2xl font-bold text-apple-dark mb-4 font-luxury">Your cart is empty</h2>
            <p class="text-apple-text-gray mb-8 max-w-md mx-auto">Looks like you haven't added anything to your cart yet. Discover items in the marketplace.</p>
            <a href="/marketplace" class="btn-primary inline-flex">Explore Marketplace</a>
        </div>
    <% } else { %>
        <div class="flex flex-col lg:flex-row gap-10 lg:gap-12 items-start">
            <!-- Cart Items -->
            <div class="w-full lg:w-[65%] space-y-6">
                <% cartItems.forEach((item, index) => { %>
                    <div class="glass-card p-5 sm:p-6 rounded-3xl flex flex-col sm:flex-row gap-6 relative transition-all duration-500 hover:shadow-premium-hover <%= item.isBlocked || item.isDeleted || item.stock < 1 ? 'opacity-60' : '' %>" id="cart-item-container-<%= item.productId %>-<%= item.variant || 'default' %>">
                        <div class="flex flex-col sm:flex-row gap-6 w-full">
                            <!-- Image -->
                            <div class="w-20 h-28 shrink-0 bg-white/5 rounded-xl overflow-hidden relative border border-white/10 flex items-center justify-center p-2">
                                <img src="<%= item.coverImage || '/images/default-book.jpg' %>" alt="<%= item.productName %>" class="max-w-full max-h-full object-contain drop-shadow-md">
                                <% if (item.isBlocked || item.isDeleted) { %>
                                    <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px] flex items-center justify-center p-4">
                                        <span class="bg-red-500/90 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest shadow-lg text-center">Unavailable</span>
                                    </div>
                                <% } else if (item.stock < 1) { %>
                                    <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px] flex items-center justify-center p-4">
                                        <span class="bg-gray-700/90 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest shadow-lg text-center">Out of Stock</span>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Details -->
                            <div class="flex-grow flex flex-col justify-between py-2">
                                <div>
                                    <div class="flex justify-between items-start mb-1.5 pr-10">
                                        <a href="/product/<%= item.productId %>" class="text-2xl font-bold text-apple-dark hover:text-apple-blue transition-colors line-clamp-2 font-luxury leading-tight">
                                            <%= item.productName %>
                                        </a>
                                    </div>
                                    
                                    <p class="text-apple-text-gray text-sm mb-4 flex items-center flex-wrap gap-2">
                                        <span><%= item.author || 'Author Unknown' %></span>
                                        <% if (item.brand) { %>
                                            <span class="text-gray-300">|</span>
                                            <span class="text-xs uppercase tracking-wider text-apple-text-gray/70 font-medium"><%= item.brand %></span>
                                        <% } %>
                                    </p>

                                    <div class="flex flex-wrap items-center gap-2">
                                        <span class="text-sm text-apple-text-gray/80 font-medium tracking-wide">
                                            Unit Price: <span class="font-bold text-apple-dark">₹<%= item.price %></span>
                                        </span>
                                        <% if (item.variant) { %>
                                            <span class="text-gray-300">|</span>
                                            <span class="inline-flex items-center text-xs font-bold text-apple-blue uppercase tracking-widest">
                                                <i data-lucide="tag" class="w-3 h-3 mr-1"></i> <%= item.variant %>
                                            </span>
                                        <% } %>
                                    </div>
                                </div>

                                <div class="flex flex-wrap items-center justify-between gap-6 mt-6 relative z-10">
                                    <div class="flex items-center gap-4 bg-black/20 border border-white/10 rounded-full p-1.5 shadow-inner relative z-20">
                                        <button class="relative z-30 w-8 h-8 flex items-center justify-center rounded-full bg-apple-card text-apple-dark hover:bg-apple-blue/20 hover:text-apple-blue transition-all duration-300 shadow-sm qty-btn <%= (item.isBlocked || item.isDeleted) ? 'opacity-50 cursor-not-allowed' : '' %>" 
                                                onclick="updateCartQty('<%= item.productId %>', '<%= item.variant || '' %>', 'decrement')" 
                                                <%= item.isBlocked || item.isDeleted ? 'disabled' : '' %>
                                                aria-label="Decrease quantity">
                                            <i data-lucide="minus" class="w-4 h-4"></i>
                                        </button>
                                        <span class="w-8 text-center font-bold text-apple-dark text-base qty-display" id="qty-<%= item.productId %>-<%= item.variant || 'default' %>"><%= item.quantity %></span>
                                        <button class="relative z-30 w-8 h-8 flex items-center justify-center rounded-full bg-apple-card text-apple-dark hover:bg-apple-blue/20 hover:text-apple-blue transition-all duration-300 shadow-sm qty-btn <%= (item.isBlocked || item.isDeleted || item.quantity >= 10 || item.quantity >= item.stock) ? 'opacity-50 cursor-not-allowed' : '' %>" 
                                                onclick="updateCartQty('<%= item.productId %>', '<%= item.variant || '' %>', 'increment')" 
                                                <%= (item.isBlocked || item.isDeleted || item.quantity >= 10 || item.quantity >= item.stock) ? 'disabled' : '' %>
                                                aria-label="Increase quantity"
                                                id="inc-btn-<%= item.productId %>-<%= item.variant || 'default' %>">
                                            <i data-lucide="plus" class="w-4 h-4"></i>
                                        </button>
                                    </div>
                                    <div class="text-right flex flex-col items-end">
                                        <p class="text-[10px] uppercase tracking-widest text-apple-text-gray/60 mb-0.5">Subtotal</p>
                                        <p class="text-2xl font-bold text-apple-dark">₹<span class="item-total" id="total-<%= item.productId %>-<%= item.variant || 'default' %>"><%= item.itemTotal %></span></p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Remove Button -->
                        <button class="absolute top-6 right-6 p-2.5 text-apple-text-gray/40 hover:text-red-400 hover:bg-red-400/10 rounded-full transition-all duration-300" 
                                title="Remove Item" 
                                onclick="removeCartItem('<%= item.productId %>', '<%= item.variant || '' %>')">
                            <i data-lucide="trash-2" class="w-5 h-5"></i>
                        </button>
                    </div>
                <% }) %>
            </div>

            <!-- Summary -->
            <div class="w-full lg:w-[35%] h-full">
                <div class="glass-card p-6 rounded-3xl sticky top-20 border border-white/10 shadow-2xl overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-apple-blue/5 rounded-full blur-3xl -mr-16 -mt-16"></div>
                    
                    <h3 class="text-xl font-bold text-apple-dark mb-5 font-luxury relative">Order Summary</h3>
                    
                    <div class="space-y-5 mb-8 relative">
                        <div class="flex justify-between items-center text-apple-text-gray">
                            <span class="text-sm">Price Details (<span id="cart-item-count"><%= cartItems.length %></span> items)</span>
                            <span class="font-semibold text-apple-dark">₹<span id="cart-subtotal"><%= cartTotal %></span></span>
                        </div>
                        <div class="flex justify-between items-center text-apple-text-gray">
                            <span class="text-sm">Shipping Fee</span>
                            <span class="font-semibold text-green-500 uppercase text-xs tracking-wider">Free Delivery</span>
                        </div>
                        <div class="h-px bg-white/5 my-4"></div>
                        <div class="flex justify-between items-end">
                            <div>
                                <p class="text-sm text-apple-text-gray/60 uppercase tracking-widest mb-1">Total Amount</p>
                                <p class="text-3xl font-bold text-apple-blue leading-none">₹<span id="cart-grand-total"><%= cartTotal %></span></p>
                            </div>
                        </div>
                    </div>

                    <% 
                        const hasUnavailableItems = cartItems.some(i => i.isBlocked || i.isDeleted || i.stock < 1);
                    %>

                    <div id="unavailable-warning" class="<%= hasUnavailableItems ? '' : 'hidden' %> mb-6 p-4 rounded-2xl bg-orange-500/10 border border-orange-500/20 text-orange-200 text-xs flex gap-3 animate-fade-in">
                        <i data-lucide="alert-triangle" class="w-5 h-5 shrink-0 text-orange-400"></i>
                        <p class="leading-relaxed">Please remove unavailable or out-of-stock items to proceed with your order.</p>
                    </div>

                    <a href="/checkout" id="checkout-btn" class="btn-primary w-full flex justify-center items-center gap-3 py-4 text-lg font-bold group <%= hasUnavailableItems ? 'opacity-50 pointer-events-none' : '' %>" <%= hasUnavailableItems ? 'disabled' : '' %>>
                        Secure Checkout 
                        <i data-lucide="arrow-right" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"></i>
                    </a>
                    
                    <div class="mt-6 flex items-center justify-center gap-4 text-[10px] text-apple-text-gray/40 uppercase tracking-widest font-medium">
                        <span class="flex items-center gap-1.5"><i data-lucide="shield-check" class="w-3.5 h-3.5"></i> Secure</span>
                        <span class="w-1 h-1 bg-white/10 rounded-full"></span>
                        <span class="flex items-center gap-1.5"><i data-lucide="truck" class="w-3.5 h-3.5"></i> Fast Shipping</span>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>

<script>
    async function updateCartQty(productId, variant, action) {
        const variantKey = variant || 'default';
        const qtyDisplay = document.getElementById(`qty-${productId}-${variantKey}`);
        const itemTotalDisplay = document.getElementById(`total-${productId}-${variantKey}`);
        const cartSubtotal = document.getElementById('cart-subtotal');
        const cartGrandTotal = document.getElementById('cart-grand-total');
        const incBtn = document.getElementById(`inc-btn-${productId}-${variantKey}`);
        
        // Disable buttons during request to prevent spam
        const buttons = document.querySelectorAll(`#cart-item-container-${productId}-${variantKey} .qty-btn`);
        buttons.forEach(btn => btn.disabled = true);

        try {
            Swal.fire({
                toast: true,
                position: 'top-end',
                title: 'Updating cart...',
                showConfirmButton: false,
                background: '#2c3b32',
                color: '#e6cfa7',
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            const res = await fetch('/cart/update', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, variant, action })
            });
            const data = await res.json();
            
            if (data.success) {
                Swal.close();
                // Smoothly update the UI
                qtyDisplay.innerText = data.quantity;
                itemTotalDisplay.innerText = data.itemTotal;
                cartSubtotal.innerText = data.cartTotal;
                cartGrandTotal.innerText = data.cartTotal;
                
                // Update button states
                if (data.quantity >= 10) {
                    incBtn.disabled = true;
                    incBtn.classList.add('opacity-50', 'cursor-not-allowed');
                } else {
                    incBtn.disabled = false;
                    incBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
                
                // Fade effect on update
                qtyDisplay.classList.add('animate-pulse');
                setTimeout(() => qtyDisplay.classList.remove('animate-pulse'), 500);

            } else {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'error',
                    title: data.message,
                    showConfirmButton: false,
                    timer: 3000,
                    background: '#2c3b32',
                    color: '#e6cfa7'
                });
            }
        } catch (err) {
            console.error(err);
        } finally {
            // Re-enable buttons, respecting overall disabling conditions
            buttons.forEach(btn => btn.disabled = false);
            // Re-check inc button specific disabled state
            if (parseInt(qtyDisplay.innerText) >= 10) {
                incBtn.disabled = true;
            }
        }
    }

    async function removeCartItem(productId, variant) {
        Swal.fire({
            title: 'Remove from cart?',
            text: "Are you sure you want to remove this item from your cart?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e6cfa7',
            cancelButtonColor: '#ff4b4b',
            confirmButtonText: '<span style="color: #3a4b41">Yes, remove it</span>',
            cancelButtonText: 'Keep it',
            background: '#2c3b32',
            color: '#e6cfa7',
            backdrop: 'rgba(0,0,0,0.6)',
            customClass: {
                popup: 'rounded-3xl border border-white/10 shadow-2xl font-luxury',
                confirmButton: 'rounded-full px-6 py-2 fw-bold',
                cancelButton: 'rounded-full px-6 py-2'
            }
        }).then(async (result) => {
            if (result.isConfirmed) {
                try {
                    Swal.fire({
                        title: 'Removing...',
                        allowOutsideClick: false,
                        background: '#2c3b32',
                        color: '#e6cfa7',
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    const res = await fetch('/cart/remove', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId, variant })
                    });
                    const data = await res.json();
                    if (data.success) {
                        // Success toast and then reload to show empty state if needed
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: 'Removed from cart',
                            showConfirmButton: false,
                            timer: 1500,
                            background: '#2c3b32',
                            color: '#e6cfa7'
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                           icon: 'error',
                           title: 'Error',
                           text: data.message,
                           background: '#2c3b32',
                           color: '#e6cfa7'
                        });
                    }
                } catch (err) {
                    console.error(err);
                }
            }
        });
    }
</script>
