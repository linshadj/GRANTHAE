<div class="space-y-24 pb-24">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 animate-fade-in-up">
                <span class="block text-apple-dark">Buy books.</span>
                <span class="block text-transparent bg-clip-text bg-gradient-to-r from-apple-blue to-purple-600">Build your
                    collection.</span>
            </h1>
            <p class="mt-4 text-xl text-apple-text-gray max-w-2xl mx-auto animate-fade-in-up"
                style="animation-delay: 0.1s;">
                The premium marketplace for book lovers. Buy the latest bestsellers or monetize your personal
                collection today.
            </p>
            <div class="mt-10 flex justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.2s;">
                <a href="/marketplace" class="btn-primary flex items-center gap-2">
                    Browse Marketplace <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </a>
                <a href="/list-rental-book" class="btn-secondary">List Your Book</a>
            </div>

    </section>

    <!-- Fixed Home Page Doodles -->
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none opacity-20">
        <!-- Big Wave (Top Right) -->
        <svg class="parallax-layer absolute top-[5%] right-[2%] w-[450px] h-[450px] text-apple-blue" data-speed="0.02"
            viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M40 60 Q 60 40, 80 60 T 120 60 T 160 60" />
            <path d="M40 80 Q 60 60, 80 80 T 120 80 T 160 80" />
            <path d="M40 100 Q 60 80, 80 100 T 120 100 T 160 100" />
            <path d="M40 120 Q 60 100, 80 120 T 120 120 T 160 120" />
            <!-- Open Book -->
            <path
                d="M40 150 Q 70 160, 100 150 Q 130 160, 160 150 V 170 Q 130 180, 100 170 Q 70 180, 40 170 Z M 100 150 V 170" />
        </svg>

        <!-- Big Geometric (Bottom Left) -->
        <svg class="parallax-layer absolute bottom-[15%] left-[0%] w-[350px] h-[350px] text-apple-gold opacity-30"
            data-speed="0.03" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
        </svg>
    </div>

    <!-- Featured Books -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-12">
            <h2 class="text-3xl font-bold text-apple-dark">Trending Now</h2>
            <a href="/marketplace" class="text-apple-blue hover:underline flex items-center gap-1 text-sm font-medium">View all
                <i data-lucide="chevron-right" class="w-4 h-4"></i></a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-8">
            <% if (typeof trendingProducts !== 'undefined' && trendingProducts && trendingProducts.length > 0) { %>
                <% trendingProducts.forEach(product => { %>
                    <%- include('../partials/book-card', { book: { 
                        _id: product._id,
                        title: product.name, 
                        author: product.author,
                        price: product.price, 
                        image: product.coverImage || (product.images.length > 0 ? product.images[0] : ''), 
                        genre: product.category ? product.category.name : 'Uncategorized', 
                        rating: 4.5,
                        totalStock: product.totalStock
                    } }) %>

                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center">
                    <p class="text-apple-text-gray">No trending books available at the moment.</p>
                </div>
            <% } %>
        </div>
    </section>

    <!-- How it Works (Value Prop) -->
    <section class="bg-apple-teal py-24 border-y border-gray-100/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl font-bold text-black mb-4">How it works</h2>
                <p class="text-black">Buy a book in seconds, or turn your shelf into a business.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
                <div
                    class="group p-6 rounded-2xl transition-all duration-300 border border-transparent hover:bg-apple-card/10 hover:backdrop-blur-md hover:border-white/20 hover:shadow-xl">
                    <div
                        class="w-16 h-16 bg-blue-50 text-apple-blue rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
                        <i data-lucide="search" class="w-8 h-8"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-3 text-black">1. Find a Book</h3>
                    <p class="text-black text-sm leading-relaxed">Search our community library for the titles
                        you
                        love. Filter by location, genre, or price.</p>
                </div>

                <div
                    class="group p-6 rounded-2xl transition-all duration-300 border border-transparent hover:bg-apple-card/10 hover:backdrop-blur-md hover:border-white/20 hover:shadow-xl">
                    <div
                        class="w-16 h-16 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
                        <i data-lucide="shopping-cart" class="w-8 h-8"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-3 text-black">2. Buy Instantly</h3>
                    <p class="text-black text-sm leading-relaxed">Secure checkout and fast delivery. Own your
                        favorite titles permanently with just a few clicks.</p>
                </div>

                <div
                    class="group p-6 rounded-2xl transition-all duration-300 border border-transparent hover:bg-apple-card/10 hover:backdrop-blur-md hover:border-white/20 hover:shadow-xl">
                    <div
                        class="w-16 h-16 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
                        <i data-lucide="library" class="w-8 h-8"></i>
                    </div>
                    <h3 class="text-xl font-semibold mb-3 text-black">3. Join our Community</h3>
                    <p class="text-black text-sm leading-relaxed">Connect with other readers, share
                        reviews, and
                        grow your collection with GRANTHAE.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Share Bookshelf CTA -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <div class="relative bg-apple-card rounded-3xl overflow-hidden p-8 md:p-16 text-center md:text-left">
            <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-3xl md:text-4xl font-bold text-apple-blue mb-6">Rent your books</h2>
                    <p class="text-lg text-apple-text-gray mb-8 leading-relaxed">
                        Earn passive income by renting out books from your personal library. Join the sharing economy on GRANTHAE.
                    </p>
                    <a href="/list-rental-book" class="btn-primary inline-flex items-center gap-2">
                        Start Listing
                        <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>

                </div>
                <div class="hidden md:flex justify-center">
                    <div class="relative">
                        <div class="absolute inset-0 bg-apple-blue/20 blur-3xl rounded-full"></div>
                        <i data-lucide="library" class="w-40 h-40 text-apple-blue relative z-10 opacity-80"></i>
                    </div>
                </div>
            </div>
            <!-- Decorative -->
            <div
                class="absolute top-0 right-0 w-64 h-64 bg-apple-blue/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2">
            </div>
        </div>
    </section>

    <!-- Genre Categories -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-apple-dark mb-12">Browse by Genre</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
            <% if (typeof activeCategories !== 'undefined' && activeCategories && activeCategories.length > 0) { %>
                <% activeCategories.forEach(function(category) { %>
                    <a href="/marketplace?category=<%= category._id %>"
                        class="relative flex items-center justify-center h-32 rounded-xl overflow-hidden shadow-sm hover:shadow-premium-hover transition-all duration-300 group">
                        
                        <img src="<%= category.coverImage || 'https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=400' %>" alt="<%= category.name %>"
                            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">

                        <div
                            class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300">
                        </div>

                        <span
                            class="relative z-10 font-bold text-white tracking-wide group-hover:scale-105 transition-transform text-center px-4">
                            <%= category.name %>
                        </span>
                    </a>
                <% }); %>
            <% } else { %>
                <div class="col-span-full py-10 text-center">
                    <p class="text-apple-text-gray">No categories available.</p>
                </div>
            <% } %>
        </div>
    </section>
</div>