<form action="/otp" method="GET" class="space-y-6" novalidate>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label for="firstName" class="block text-sm font-medium text-apple-dark">First Name</label>
      <div class="mt-1 relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i data-lucide="user" class="h-5 w-5 text-gray-400"></i>
        </div>
        <input
          type="text"
          name="firstName"
          id="firstName"
          class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg text-apple-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-apple-blue/50 focus:border-apple-blue transition-shadow sm:text-sm"
          placeholder="John"
        />
      </div>
      <p id="firstNameError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
    </div>
    <div>
      <label for="lastName" class="block text-sm font-medium text-apple-dark">Last Name</label>
      <div class="mt-1 relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i data-lucide="user" class="h-5 w-5 text-gray-400"></i>
        </div>
        <input
          type="text"
          name="lastName"
          id="lastName"
          class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg text-apple-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-apple-blue/50 focus:border-apple-blue transition-shadow sm:text-sm"
          placeholder="Doe"
        />
      </div>
      <p id="lastNameError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
    </div>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-apple-dark">Email address</label>
    <div class="mt-1 relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <i data-lucide="mail" class="h-5 w-5 text-gray-400"></i>
      </div>
      <input
        type="email"
        name="email"
        id="email"
        class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg text-apple-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-apple-blue/50 focus:border-apple-blue transition-shadow sm:text-sm"
        placeholder="you@example.com"
      />
    </div>
    <p id="emailError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
  </div>

  <div>
    <label for="password" class="block text-sm font-medium text-apple-dark">Password</label>
    <div class="mt-1 relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <i data-lucide="lock" class="h-5 w-5 text-gray-400"></i>
      </div>
      <input
        type="password"
        name="password"
        id="password"
        class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg text-apple-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-apple-blue/50 focus:border-apple-blue transition-shadow sm:text-sm"
        placeholder="••••••••"
      />
    </div>
    <p id="passwordError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
  </div>

  <div>
    <label for="confirm-password" class="block text-sm font-medium text-apple-dark"
      >Confirm Password</label
    >
    <div class="mt-1 relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <i data-lucide="lock" class="h-5 w-5 text-gray-400"></i>
      </div>
      <input
        type="password"
        name="confirm-password"
        id="confirm-password"
        class="block w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg text-apple-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-apple-blue/50 focus:border-apple-blue transition-shadow sm:text-sm"
        placeholder="••••••••"
      />
    </div>
    <p id="confirmPasswordError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
  </div>

  <p id="backendError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>

  <button
    type="submit"
    class="w-full btn-primary flex justify-center py-3 shadow-lg shadow-apple-blue/20"
  >
    Create Account
  </button>

  <div class="my-6 flex items-center justify-center gap-4">
    <div class="h-px bg-gray-300 flex-1"></div>
    <span class="text-xs text-apple-text-gray uppercase tracking-widest">Or continue with</span>
    <div class="h-px bg-gray-300 flex-1"></div>
  </div>

  <a
    href="/auth/google"
    class="relative z-20 w-full flex items-center justify-center gap-3 py-3 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors duration-200 group"
  >
    <svg
      class="h-5 w-5 group-hover:scale-110 transition-transform duration-200"
      viewBox="0 0 24 24"
    >
      <path
        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
        fill="#4285F4"
      />
      <path
        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
        fill="#34A853"
      />
      <path
        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.84z"
        fill="#FBBC05"
      />
      <path
        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
        fill="#EA4335"
      />
    </svg>
    <span class="font-medium text-gray-700">Sign up with Google</span>
  </a>

  <div class="relative z-20 text-xs text-apple-text-gray text-center mt-4">
    By signing up, you agree to our <a href="#" class="underline">Terms</a> and
    <a href="#" class="underline">Privacy Policy</a>.
  </div>

  <p class="relative z-20 mt-6 text-center text-sm text-apple-text-gray">
    Already have an account?
    <a href="/sign-in" class="font-medium text-apple-blue hover:text-apple-dark">Log in</a>
  </p>
</form>
<script>
  const firstName = document.getElementById("firstName");
  const lastName = document.getElementById("lastName");
  const email = document.getElementById("email");
  const password = document.getElementById("password");
  const confirmPassword = document.getElementById("confirm-password");
  const form = document.querySelector("form");

  const firstNameError = document.getElementById("firstNameError");
  const lastNameError = document.getElementById("lastNameError");
  const emailError = document.getElementById("emailError");
  const passwordError = document.getElementById("passwordError");
  const confirmPasswordError = document.getElementById("confirmPasswordError");

  const backendError = document.getElementById("backendError");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Disable button
    const submitButton = form.querySelector('button[type="submit"]');
    submitButton.disabled = true;
    submitButton.classList.add("opacity-50", "cursor-not-allowed");
    submitButton.textContent = "Submitting...";

    let isValid = true;

    // First Name Validation
    if (firstName.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      firstNameError.classList.remove("hidden");
      firstNameError.textContent = "First name is required.";
    } else if (!validateName(firstName.value.trim())) {
      resetSubmitButton();
      isValid = false;
      firstNameError.classList.remove("hidden");
      firstNameError.textContent = "First name should contain only letters.";
    } else {
      firstNameError.classList.add("hidden");
    }

    // Last Name Validation
    if (lastName.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      lastNameError.classList.remove("hidden");
      lastNameError.textContent = "Last name is required.";
    } else if (!validateName(lastName.value.trim())) {
      resetSubmitButton();
      isValid = false;
      lastNameError.classList.remove("hidden");
      lastNameError.textContent = "Last name should contain only letters.";
    } else {
      lastNameError.classList.add("hidden");
    }

    // Email Validation
    if (email.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      emailError.classList.remove("hidden");
      emailError.textContent = "Email is required.";
    } else if (!validateEmail(email.value.trim())) {
      resetSubmitButton();
      isValid = false;
      emailError.classList.remove("hidden");
      emailError.textContent = "Please enter a valid email address.";
    } else {
      emailError.classList.add("hidden");
    }

    // Password Validation
    if (password.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      passwordError.classList.remove("hidden");
      passwordError.textContent = "Password is required.";
    } else if (!validatePassword(password.value.trim())) {
      resetSubmitButton();
      isValid = false;
      passwordError.classList.remove("hidden");
      passwordError.textContent =
        "Password must be at least 8 characters long and include uppercase, lowercase, number, and special character.";
    } else {
      passwordError.classList.add("hidden");
    }

    // Confirm Password Validation
    if (confirmPassword.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      confirmPasswordError.classList.remove("hidden");
      confirmPasswordError.textContent = "Please confirm your password.";
    } else if (password.value.trim() !== confirmPassword.value.trim()) {
      resetSubmitButton();
      isValid = false;
      confirmPasswordError.classList.remove("hidden");
      confirmPasswordError.textContent = "Passwords do not match.";
    } else {
      confirmPasswordError.classList.add("hidden");
    }

    if (isValid) {
      try {
        const res = await fetch("/sign-up", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            firstName: firstName.value.trim(),
            lastName: lastName.value.trim(),
            email: email.value.trim(),
            password: password.value.trim(),
          }),
        });
        const data = await res.json();
        if (data.success) {
          window.location.href = data.redirectUrl;
        } else {
          resetSubmitButton();
          backendError.classList.remove("hidden");
          backendError.textContent = data.message;
        }
      } catch (error) {
        console.log("Error in signup fetch:", error);
        resetSubmitButton();
        backendError.classList.remove("hidden");
        backendError.textContent = error;
      }
    }
  });

  function validateName(name) {
    const nameRegex = /^[a-zA-Z]+$/;
    return nameRegex.test(name);
  }

  function validateEmail(email) {
    const emailRegex = /^[^/\s@]+@[^/\s@]+\.[^/\s@]+$/;
    return emailRegex.test(email);
  }

  function validatePassword(password) {
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;
    return passwordRegex.test(password);
  }

  // enable button function
  function resetSubmitButton() {
    const submitButton = form.querySelector('button[type="submit"]');
    submitButton.disabled = false;
    submitButton.classList.remove("opacity-50", "cursor-not-allowed");
    submitButton.textContent = "Create Account";
  }
</script>
