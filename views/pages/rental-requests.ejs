<%
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', {
        maximumFractionDigits: 2
    });

    const requestCounts = incomingRequests.reduce((acc, request) => {
        acc.total += 1;
        acc[request.status] = (acc[request.status] || 0) + 1;
        return acc;
    }, { total: 0 });

    const pendingRequests = requestCounts.Requested || 0;
    const activeRequests = requestCounts.Active || 0;
    const returnRequests = requestCounts["Return Requested"] || 0;
    const requestStatusClass = (status) => {
        if (status === "Requested") return "bg-yellow-500/10 text-yellow-500 border-yellow-500/20";
        if (status === "Active") return "bg-green-500/10 text-green-500 border-green-500/20";
        if (status === "Returned") return "bg-apple-blue/10 text-apple-blue border-apple-blue/20";
        if (status === "Return Requested") return "bg-orange-500/10 text-orange-500 border-orange-500/20";
        return "bg-red-500/10 text-red-500 border-red-500/20";
    };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 space-y-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm font-medium text-apple-text-gray">
                    <li><a href="/home" class="hover:text-apple-dark transition-colors">Home</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li><a href="/profile" class="hover:text-apple-dark transition-colors">Profile</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li><a href="/profile/my-listings" class="hover:text-apple-dark transition-colors">My Listings</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li class="text-apple-dark">Incoming Requests</li>
                </ol>
            </nav>
            <h1 class="text-4xl font-bold text-apple-dark tracking-tight font-serif">Incoming Requests</h1>
            <p class="mt-2 text-apple-text-gray">Review rental interest for the books you have listed.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 lg:justify-end">
            <a href="/profile/my-listings"
                class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-2xl bg-white/5 border border-white/10 text-apple-dark hover:bg-white/10 transition-all font-bold text-sm">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Back to Listings
            </a>
            <a href="/list-rental-book"
                class="btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 font-bold shadow-xl shadow-apple-gold/20">
                <i data-lucide="plus" class="w-5 h-5"></i>
                Add New Listing
            </a>
        </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Requests</p>
            <p class="text-3xl font-bold text-apple-dark mt-2"><%= requestCounts.total %></p>
        </div>
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Pending Approval</p>
            <p class="text-3xl font-bold text-yellow-500 mt-2"><%= pendingRequests %></p>
        </div>
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Active</p>
            <p class="text-3xl font-bold text-green-500 mt-2"><%= activeRequests %></p>
        </div>
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Live Books</p>
            <p class="text-3xl font-bold text-apple-dark mt-2"><%= availableListings.length %></p>
        </div>
    </div>


    <% if (incomingRequests.length > 0) { %>
        <div class="bg-apple-card border border-white/10 rounded-3xl overflow-hidden shadow-lg">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white/5 text-apple-text-gray text-xs uppercase tracking-widest">
                            <th class="px-6 py-4 font-bold">Book</th>
                            <th class="px-6 py-4 font-bold">Renter</th>
                            <th class="px-6 py-4 font-bold">Rental Window</th>
                            <th class="px-6 py-4 font-bold">Amount</th>
                            <th class="px-6 py-4 font-bold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% incomingRequests.forEach(request => { %>
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4">
                                    <p class="font-bold text-apple-dark"><%= request.rental?.bookTitle || 'Rental Book' %></p>
                                    <p class="text-xs text-apple-text-gray"><%= request.rental?.author || '' %></p>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="font-medium text-apple-dark"><%= request.renter ? `${request.renter.firstName || ''} ${request.renter.lastName || ''}`.trim() : 'Reader' %></p>
                                    <p class="text-xs text-apple-text-gray"><%= request.renter?.email || '' %></p>
                                </td>
                                <td class="px-6 py-4 text-sm text-apple-text-gray">
                                    <%= new Date(request.startDate).toLocaleDateString('en-IN') %> to <%= new Date(request.endDate).toLocaleDateString('en-IN') %>
                                    <% if (request.returnTrackingId) { %>
                                        <p class="text-[10px] uppercase tracking-widest mt-1">Tracking: <%= request.returnTrackingId %></p>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 font-bold text-apple-dark">
                                    &#8377;<%= formatAmount(request.totalAmount || 0) %>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <span class="inline-flex px-3 py-1 rounded-full <%= requestStatusClass(request.status) %> border text-xs font-bold uppercase tracking-wider">
                                            <%= request.status %>
                                        </span>
                                        <% if (request.status === 'Requested') { %>
                                            <button type="button" onclick="confirmRentalRequest('<%= request._id %>')"
                                                class="px-3 py-1.5 rounded-lg bg-green-500/10 text-green-500 border border-green-500/20 text-xs font-bold hover:bg-green-500/15 transition-colors">
                                                Confirm
                                            </button>
                                            <button type="button" onclick="rejectRentalRequest('<%= request._id %>')"
                                                class="px-3 py-1.5 rounded-lg bg-red-500/10 text-red-500 border border-red-500/20 text-xs font-bold hover:bg-red-500/15 transition-colors">
                                                Decline
                                            </button>
                                        <% } else if (request.status === 'Return Requested') { %>
                                            <button type="button" onclick="completeRentalReturn('<%= request._id %>')"
                                                class="px-3 py-1.5 rounded-lg bg-green-500/10 text-green-500 border border-green-500/20 text-xs font-bold hover:bg-green-500/15 transition-colors">
                                                Confirm Return
                                            </button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } else { %>
        <div class="bg-apple-card border border-white/10 rounded-3xl p-10 sm:p-16 text-center shadow-lg">
            <div class="w-20 h-20 bg-apple-blue/10 rounded-3xl flex items-center justify-center mx-auto mb-6">
                <i data-lucide="inbox" class="w-10 h-10 text-apple-blue"></i>
            </div>
            <h3 class="text-2xl font-bold text-apple-dark mb-2 font-serif">No incoming requests yet</h3>
            <p class="text-apple-text-gray mb-8 max-w-md mx-auto">Requests for approved rental listings will appear here.</p>
            <a href="/rental-place" class="btn-primary inline-flex items-center gap-2 px-8 py-3 font-bold">
                <i data-lucide="book-open" class="w-4 h-4"></i>
                View Rentalplace
            </a>
        </div>
    <% } %>

    <% if (availableListings.length > 0) { %>
        <section class="space-y-4">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h2 class="text-xl font-bold text-apple-dark font-serif">Books Ready for Requests</h2>
                    <p class="text-sm text-apple-text-gray">These listings are live in Rentalplace.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% availableListings.forEach(listing => { %>
                    <%
                        const imageSrc = listing.coverImage || (Array.isArray(listing.images) && listing.images[0]) || '';
                    %>
                    <article class="bg-apple-card border border-white/10 rounded-2xl overflow-hidden shadow-sm flex">
                        <div class="w-24 bg-white/5 shrink-0">
                            <% if (imageSrc) { %>
                                <img src="<%= imageSrc %>" alt="<%= listing.bookTitle %>" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center">
                                    <i data-lucide="book-open" class="w-8 h-8 text-apple-text-gray/40"></i>
                                </div>
                            <% } %>
                        </div>
                        <div class="p-4 min-w-0 flex-1">
                            <p class="font-bold text-apple-dark truncate"><%= listing.bookTitle %></p>
                            <p class="text-sm text-apple-text-gray truncate">by <%= listing.author %></p>
                            <div class="flex items-center justify-between gap-3 mt-4">
                                <span class="text-sm font-bold text-apple-dark">&#8377;<%= formatAmount(listing.dailyRate) %>/day</span>
                                <a href="/rental/<%= listing._id %>" class="text-xs font-bold text-apple-blue hover:underline">View</a>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    <% } %>
</div>

<script>
    async function confirmRentalRequest(rentalOrderId) {
        const result = await Swal.fire({
            title: 'Confirm Rental?',
            text: 'This will capture payment from the renter wallet and mark your book as rented.',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Confirm Rental',
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonColor: '#E6CFA7'
        });

        if (!result.isConfirmed) return;

        try {
            const response = await fetch(`/profile/rentals/${rentalOrderId}/confirm`, { method: 'PATCH' });
            const data = await response.json();

            if (data.success) {
                showToast('success', data.message || 'Rental confirmed.');
                setTimeout(() => window.location.reload(), 900);
                return;
            }

            Swal.fire({ icon: 'error', title: 'Failed', text: data.message || 'Could not confirm rental request.' });
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Failed', text: 'Could not confirm rental request.' });
        }
    }

    async function rejectRentalRequest(rentalOrderId) {
        const result = await Swal.fire({
            title: 'Decline Request?',
            input: 'textarea',
            inputPlaceholder: 'Reason for declining...',
            inputAttributes: { maxlength: 300 },
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Decline',
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonColor: '#ef4444'
        });

        if (!result.isConfirmed) return;

        try {
            const response = await fetch(`/profile/rentals/${rentalOrderId}/reject`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: result.value || '' })
            });
            const data = await response.json();

            if (data.success) {
                showToast('success', data.message || 'Rental request declined.');
                setTimeout(() => window.location.reload(), 900);
                return;
            }

            Swal.fire({ icon: 'error', title: 'Failed', text: data.message || 'Could not decline rental request.' });
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Failed', text: 'Could not decline rental request.' });
        }
    }

    async function completeRentalReturn(rentalOrderId) {
        const result = await Swal.fire({
            title: 'Confirm Return?',
            text: 'This will refund the security deposit to the renter wallet and make the book available again.',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Confirm Return',
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonColor: '#E6CFA7'
        });

        if (!result.isConfirmed) return;

        try {
            const response = await fetch(`/profile/rentals/${rentalOrderId}/return/complete`, { method: 'PATCH' });
            const data = await response.json();

            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Return Confirmed',
                    text: data.message,
                    background: '#1e2a22',
                    color: '#E6CFA7',
                    confirmButtonColor: '#E6CFA7'
                }).then(() => window.location.reload());
                return;
            }

            Swal.fire({ icon: 'error', title: 'Failed', text: data.message || 'Could not confirm return.' });
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Failed', text: 'Could not confirm return.' });
        }
    }
</script>
