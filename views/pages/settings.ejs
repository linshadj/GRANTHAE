  <!-- Account Information -->
  <div class="glass-card p-6 space-y-6">
    <h2 class="text-lg font-semibold text-apple-dark border-b border-white/10 pb-2">
      Account Information
    </h2>
    <div class="space-y-4">
      <div class="flex items-center justify-between">
        <div class="flex-1">
          <p class="text-apple-dark font-medium text-sm mb-1">Email Address</p>
          <p class="text-apple-text-gray text-sm"><%= user.email %></p>
        </div>
        <button
          onclick="<%= user.googleId ? 'openCannotChangeEmailModal()' : 'openEmailModal()' %>"
          class="z-20 relative px-4 py-2 bg-white/5 text-apple-dark hover:bg-white/10 rounded-lg text-sm transition-all font-medium border border-white/10"
        >
          Change Email
        </button>
      </div>
    </div>
  </div>

  <!-- Security -->
  <div class="glass-card p-6 space-y-6">
    <h2 class="text-lg font-semibold text-apple-dark border-b border-white/10 pb-2">Security</h2>
    <div class="space-y-4">
