<!-- Password Modal -->
<div id="password-modal" class="fixed inset-0 z-[998] hidden" role="dialog" aria-modal="true">
  <div
    class="fixed inset-0 bg-black/90 backdrop-blur-md transition-opacity opacity-0"
    id="password-backdrop"
  ></div>
  <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4 text-center">
      <div
        class="relative transform overflow-hidden rounded-2xl bg-apple-card text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-md opacity-0 translate-y-4 scale-95 border border-white/10"
        id="password-panel"
      >
        <div class="p-6 border-b border-white/10 flex items-center justify-between bg-white/5">
          <h3 class="text-lg font-bold text-apple-dark font-serif">Change Password</h3>
          <button
            type="button"
            onclick="closePasswordModal()"
            class="text-apple-text-gray hover:text-apple-dark transition-colors"
          >
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        <form id="passwordForm" action="/settings/change-password" method="POST" novalidate>
          <div class="p-8 space-y-4">
            <div class="space-y-2">
              <label class="text-xs font-bold text-apple-text-gray uppercase tracking-wider"
                >Current Password</label
              >
              <input
                id="currentPassword"
                type="password"
                required
                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-apple-dark focus:border-apple-blue outline-none transition-all placeholder:text-apple-text-gray/40"
                placeholder="••••••••"
              />
            </div>
            <p
              id="currentPasswordError"
              class="hidden text-xs mt-1"
              style="color: rgb(225, 0, 0)"
            ></p>
            <div class="space-y-4 pt-2">
              <div class="space-y-2">
                <label class="text-xs font-bold text-apple-text-gray uppercase tracking-wider"
                  >New Password</label
                >
                <input
                  id="newPassword"
                  type="password"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-apple-dark focus:border-apple-blue outline-none transition-all placeholder:text-apple-text-gray/40"
                  placeholder="••••••••"
                />
              </div>
              <p
                id="newPasswordError"
                class="hidden text-xs mt-1"
                style="color: rgb(225, 0, 0)"
              ></p>
              <div class="space-y-2">
                <label class="text-xs font-bold text-apple-text-gray uppercase tracking-wider"
                  >Confirm New Password</label
                >
                <input
                  id="confirmNewPassword"
                  type="password"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-apple-dark focus:border-apple-blue outline-none transition-all placeholder:text-apple-text-gray/40"
                  placeholder="••••••••"
                />
              </div>
              <p
                id="confirmNewPasswordError"
                class="hidden text-xs mt-1"
                style="color: rgb(225, 0, 0)"
              ></p>
              <p
                id="backendPasswordError"
                class="hidden text-xs mt-1"
                style="color: rgb(225, 0, 0)"
              ></p>
            </div>
          </div>
          <div class="p-6 border-t border-white/10 bg-white/5 flex gap-3">
            <button
              type="button"
              onclick="closePasswordModal()"
              class="flex-1 px-4 py-2 bg-white/5 text-apple-dark hover:bg-white/10 rounded-lg text-sm transition-all font-medium border border-white/10"
            >
              Cancel
            </button>
            <button id="passwordSubmit" type="submit" class="flex-1 btn-primary">
              Update Password
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

