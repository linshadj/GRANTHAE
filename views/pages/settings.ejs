<div class="max-w-2xl mx-auto space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">Settings</h1>
            <p class="text-apple-text-gray/80 text-sm">Manage your account preferences and security.</p>
        </div>
    </div>

    <!-- Notifications -->
    <div class="glass-card p-6 space-y-6">
        <h2 class="text-lg font-semibold text-apple-dark border-b border-white/10 pb-2">Notifications</h2>
        <div class="space-y-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-apple-dark font-medium text-sm">Email Notifications</p>
                    <p class="text-apple-text-gray text-xs">Receive emails about your rentals and listings.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" checked class="sr-only peer">
                    <div
                        class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-apple-blue">
                    </div>
                </label>
            </div>
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-apple-dark font-medium text-sm">Marketing</p>
                    <p class="text-apple-text-gray text-xs">Receive updates about new features and promos.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" class="sr-only peer">
                    <div
                        class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-apple-blue">
                    </div>
                </label>
            </div>
        </div>
    </div>

    <!-- Account Information -->
    <div class="glass-card p-6 space-y-6">
        <h2 class="text-lg font-semibold text-apple-dark border-b border-white/10 pb-2">Account Information</h2>
        <div class="space-y-4">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <p class="text-apple-dark font-medium text-sm mb-1">Email Address</p>
                    <p class="text-apple-text-gray text-sm">linshad@example.com</p>
                    <p class="text-apple-text-gray/70 text-xs mt-1 italic">
                        <i data-lucide="shield-check" class="w-3 h-3 inline"></i>
                        OTP verification required to change email
                    </p>
                </div>
                <button
                    class="px-4 py-2 bg-white/5 text-apple-dark hover:bg-white/10 rounded-lg text-sm transition-all font-medium border border-white/10">
                    Change Email
                </button>
            </div>
        </div>
    </div>

    <!-- Security -->
    <div class="glass-card p-6 space-y-6">
        <h2 class="text-lg font-semibold text-apple-dark border-b border-white/10 pb-2">Security</h2>
        <div class="space-y-4">
            <a href="/profile/change-password"
                class="w-full text-left px-4 py-3 rounded-lg bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-between group">
                <span class="text-apple-text-gray group-hover:text-apple-dark transition-colors">Change Password</span>
                <i data-lucide="chevron-right" class="w-4 h-4 text-apple-text-gray"></i>
            </a>
            <button
                class="w-full text-left px-4 py-3 rounded-lg bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-between group">
                <span class="text-apple-text-gray group-hover:text-apple-dark transition-colors">Two-Factor
                    Authentication</span>
                <span class="text-xs text-apple-text-gray bg-white/5 px-2 py-1 rounded">Off</span>
            </button>
        </div>
    </div>

    <!-- Danger Zone -->
    <div class="glass-card p-6 border border-red-500/20">
        <h2 class="text-lg font-semibold text-red-500 border-b border-red-500/20 pb-2 mb-4">Danger Zone</h2>
        <div class="flex items-center justify-between">
            <div>
                <p class="text-apple-dark font-medium text-sm">Delete Account</p>
                <p class="text-apple-text-gray text-xs">Permanently delete your account and all data.</p>
            </div>
            <button
                class="px-4 py-2 bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white rounded-lg text-sm transition-all font-medium border border-red-500/20">
                Delete Account
            </button>
        </div>
    </div>
</div>