<!-- Email Modal -->
<div id="email-modal" class="fixed inset-0 z-[998] hidden" role="dialog" aria-modal="true">
  <div
    class="fixed inset-0 bg-black/90 backdrop-blur-md transition-opacity opacity-0"
    id="email-backdrop"
  ></div>
  <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4 text-center">
      <div
        class="relative transform overflow-hidden rounded-2xl bg-apple-card text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-md opacity-0 translate-y-4 scale-95 border border-white/10"
        id="email-panel"
      >
        <div class="p-6 border-b border-white/10 flex items-center justify-between bg-white/5">
          <h3 id="email-modal-title" class="text-lg font-bold text-apple-dark font-serif">
            Change Email Address
          </h3>
          <button
            type="button"
            onclick="closeEmailModal()"
            class="text-apple-text-gray hover:text-apple-dark transition-colors"
          >
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>

        <!-- Step 1: Input -->
        <form id="emailForm" action="/settings/change-email" method="POST" novalidate>
          <div id="email-step-input">
            <div class="p-8 space-y-4">
              <p class="text-sm text-apple-text-gray">
                Enter your new email address. We'll send a verification code to confirm it's you.
              </p>
              <div class="space-y-2">
                <label class="text-xs font-bold text-apple-text-gray uppercase tracking-wider"
                  >New Email Address</label
                >
                <input
                  id="newEmail"
                  type="email"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-apple-dark focus:border-apple-blue outline-none transition-all placeholder:text-apple-text-gray/40"
                  placeholder="name@example.com"
                />
              </div>
              <p id="emailError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
            </div>
            <div class="p-6 border-t border-white/10 bg-white/5 flex gap-3">
              <button
                type="button"
                onclick="closeEmailModal()"
                class="flex-1 px-4 py-2 bg-white/5 text-apple-dark hover:bg-white/10 rounded-lg text-sm transition-all font-medium border border-white/10"
              >
                Cancel
              </button>
              <button id="emailSubmit" type="submit" class="flex-1 btn-primary">Send Code</button>
            </div>
          </div>
        </form>

        <!-- Step 2: OTP -->
        <div id="email-step-otp" class="hidden">
          <form id="otpForm" action="/verify-email" method="POST">
            <div class="p-8 space-y-6">
              <div class="text-center space-y-2">
                <div
                  class="w-16 h-16 bg-apple-blue/10 rounded-full flex items-center justify-center mx-auto mb-4"
                >
                  <i data-lucide="mail-check" class="w-8 h-8 text-apple-blue"></i>
                </div>
                <p class="text-sm text-apple-text-gray leading-relaxed">
                  We've sent a 6-digit code to <br /><span
                    id="display-new-email"
                    class="font-bold text-apple-dark"
                  ></span>
                </p>
              </div>

              <div class="flex justify-center gap-2 max-w-[300px] mx-auto">
                <input
                  type="tel"
                  maxlength="1"
                  pattern="[0-9]*"
                  inputmode="numeric"
                  autofocus
                  class="otp-input w-10 h-12 text-center text-xl font-bold bg-white/5 border border-white/10 rounded-lg text-apple-dark focus:border-apple-blue outline-none transition-all"
                />
                <input
                  type="tel"
                  maxlength="1"
                  pattern="[0-9]*"
                  inputmode="numeric"
                  class="otp-input w-10 h-12 text-center text-xl font-bold bg-white/5 border border-white/10 rounded-lg text-apple-dark focus:border-apple-blue outline-none transition-all"
                />
                <input
                  type="tel"
                  maxlength="1"
                  pattern="[0-9]*"
                  inputmode="numeric"
                  class="otp-input w-10 h-12 text-center text-xl font-bold bg-white/5 border border-white/10 rounded-lg text-apple-dark focus:border-apple-blue outline-none transition-all"
                />
                <input
                  type="tel"
                  maxlength="1"
                  pattern="[0-9]*"
                  inputmode="numeric"
                  class="otp-input w-10 h-12 text-center text-xl font-bold bg-white/5 border border-white/10 rounded-lg text-apple-dark focus:border-apple-blue outline-none transition-all"
                />
                <input
                  type="tel"
                  maxlength="1"
                  pattern="[0-9]*"
                  inputmode="numeric"
                  class="otp-input w-10 h-12 text-center text-xl font-bold bg-white/5 border border-white/10 rounded-lg text-apple-dark focus:border-apple-blue outline-none transition-all"
                />
                <input
                  type="tel"
                  maxlength="1"
                  pattern="[0-9]*"
                  inputmode="numeric"
                  class="otp-input w-10 h-12 text-center text-xl font-bold bg-white/5 border border-white/10 rounded-lg text-apple-dark focus:border-apple-blue outline-none transition-all"
                />
              </div>
              <p id="otpError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>

              <p class="mt-8 text-center text-sm text-apple-text-gray">
                Didn't receive the code?
                <button
                  type="button"
                  id="resendBtn"
                  class="relative z-20 font-bold text-apple-dark hover:text-apple-gold cursor-pointer hover:underline decoration-apple-gold/10"
                >
                  Resend Code
                </button>
              </p>
            </div>

            <div class="p-6 border-t border-white/10 bg-white/5 flex gap-3">
              <button
                type="button"
                onclick="goToEmailInputStep()"
                class="flex-1 px-4 py-2 bg-white/5 text-apple-dark hover:bg-white/10 rounded-lg text-sm transition-all font-medium border border-white/10"
              >
                Back
              </button>
              <button id="submitOtp" type="submit" class="flex-1 btn-primary">Verify & Save</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const newEmail = document.getElementById("newEmail");
  const emailError = document.getElementById("emailError");
  const emailForm = document.getElementById("emailForm");
  const emailSubmit = document.getElementById("emailSubmit");

  const otpInputs = document.querySelectorAll('input[type="tel"]');
  const otpForm = document.getElementById("otpForm");
  const otpSubmit = document.getElementById("submitOtp");
  const otpError = document.getElementById("otpError");

  const resendBtn = document.getElementById("resendBtn");

  const passwordForm = document.getElementById("passwordForm");
  const passwordSubmit = document.getElementById("passwordSubmit");
  const currentPassword = document.getElementById("currentPassword");
  const newPassword = document.getElementById("newPassword");
  const confirmNewPassword = document.getElementById("confirmNewPassword");
  const currentPasswordError = document.getElementById("currentPasswordError");
  const newPasswordError = document.getElementById("newPasswordError");
  const confirmNewPasswordError = document.getElementById("confirmNewPasswordError");
  const backendPasswordError = document.getElementById("backendPasswordError");

  const emailSubmitText = "Send Code";
  const otpSubmitText = "Verify & Save";
  const passwordSubmitText = "Update Password";

  const cannotChangeEmailModal = document.getElementById("cannot-change-email-modal");
  const cannotChangeEmailBackdrop = document.getElementById("cannot-change-email-modal-backdrop");
  const cannotChangeEmailPanel = document.getElementById("cannot-change-email-modal-panel");

  const cannotChangePasswordModal = document.getElementById("cannot-change-password-modal");
  const cannotChangePasswordBackdrop = document.getElementById("cannot-change-password-modal-backdrop");
  const cannotChangePasswordPanel = document.getElementById("cannot-change-password-modal-panel");


  // OTP Input auto-focus

  let otp = "";

  otpInputs.forEach((input, index) => {
    input.addEventListener("input", (e) => {
      input.value = input.value.replace(/[^0-9]/g, "");
      otp = Array.from(otpInputs, (input) => input.value).join("");
      if (input.value.length === 1 && index < otpInputs.length - 1) {
        otpInputs[index + 1].focus();
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace" && e.target.value.length === 0 && index > 0) {
        otpInputs[index - 1].focus();
      }
    });
  });

  emailForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Disable button
    emailSubmit.disabled = true;
    emailSubmit.classList.add("opacity-50", "cursor-not-allowed");
    emailSubmit.textContent = "Sending...";

    let isValid = true;

    // Email Validation
    if (newEmail.value.trim() === "") {
      resetSubmitButton(emailSubmit, emailSubmitText);
      isValid = false;
      emailError.classList.remove("hidden");
      emailError.textContent = "Email is required.";
    } else if (!validateEmail(newEmail.value.trim())) {
      resetSubmitButton(emailSubmit, emailSubmitText);
      isValid = false;
      emailError.classList.remove("hidden");
      emailError.textContent = "Please enter a valid email address.";
    } else {
      emailError.classList.add("hidden");
    }

    if (isValid) {
      try {
        const res = await fetch("/settings/change-email", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            newEmail: newEmail.value.trim(),
          }),
        });
        const data = await res.json();
        if (data.success) {
          goToOtpStep();
          resetSubmitButton(emailSubmit, emailSubmitText);
        } else {
          resetSubmitButton(emailSubmit, emailSubmitText);
          emailError.classList.remove("hidden");
          emailError.textContent = data.message;
        }
      } catch (error) {
        console.log("Error in changeEmail fetch:", error);
        resetSubmitButton(emailSubmit, emailSubmitText);
        emailError.classList.remove("hidden");
        emailError.textContent = error.message;
      }
    }
  });

  function validateEmail(email) {
    const emailRegex = /^[^/\s@]+@[^/\s@]+\.[^/\s@]+$/;
    return emailRegex.test(email);
  }

  otpForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    console.log(otp);
    // Disable button
    otpSubmit.disabled = true;
    otpSubmit.classList.add("opacity-50", "cursor-not-allowed");
    otpSubmit.textContent = "Verifying...";

    let isValid = true;

    // Email Validation
    if (newEmail.value.trim() === "") {
      resetSubmitButton(otpSubmit, otpSubmitText);
      isValid = false;
      otpError.classList.remove("hidden");
      otpError.textContent = "Email is required.";
    } else if (!validateEmail(newEmail.value.trim())) {
      resetSubmitButton(otpSubmit, otpSubmitText);
      isValid = false;
      otpError.classList.remove("hidden");
      otpError.textContent = "Please enter a valid email address.";
    } else {
      otpError.classList.add("hidden");
    }

    if (isValid) {
      try {
        const res = await fetch("/otp", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            otp: otp,
          }),
        });

        const data = await res.json();
        if (data.success) {
          window.location.href = data.redirectUrl;
        } else {
          resetSubmitButton(otpSubmit, otpSubmitText);
          otpError.classList.remove("hidden");
          otpError.textContent = data.message;
          otpError.style.color = "#f87171";
        }
      } catch (error) {
        console.log(error);
      }
    }
  });

  let countdownInterval = null;
  let countdownTime = 5 * 60; // 5 min

  resendBtn.addEventListener("click", async () => {
    if (resendBtn.disabled) return;

    try {
      const res = await fetch("/resend-otp", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
      });

      const data = await res.json();

      if (data.success) {
        startCountdown(); // restart timer
      } else {
        otpError.classList.remove("hidden");
        otpError.textContent = data.message;
      }
    } catch (err) {
      console.error(err);
    }
  });

  function startCountdown() {
    // Clear existing timer if running
    if (countdownInterval) {
      clearInterval(countdownInterval);
    }

    resendBtn.disabled = true;
    resendBtn.classList.add("opacity-50", "cursor-not-allowed");

    countdownTime = 300;

    countdownInterval = setInterval(() => {
      const minutes = Math.floor(countdownTime / 60);
      const seconds = countdownTime % 60;

      resendBtn.textContent = `Resend in ${minutes}:${seconds < 10 ? "0" : ""}${seconds}`;

      countdownTime--;

      if (countdownTime < 0) {
        clearInterval(countdownInterval);
        resendBtn.disabled = false;
        resendBtn.classList.remove("opacity-50", "cursor-not-allowed");
        resendBtn.textContent = "Resend Code";
      }
    }, 1000);
  }

  // enable button function
  function resetSubmitButton(submitButton, text) {
    submitButton.disabled = false;
    submitButton.classList.remove("opacity-50", "cursor-not-allowed");
    submitButton.textContent = text;
  }

  // Password Modal Logic
  const passwordModal = document.getElementById("password-modal");
  const passwordBackdrop = document.getElementById("password-backdrop");
  const passwordPanel = document.getElementById("password-panel");

  function openPasswordModal() {
    if (!passwordModal) return;
    // Move to body to escape blur and stacking context
    document.body.appendChild(passwordModal);
    toggleModalState(true);
    passwordModal.classList.remove("hidden");
    setTimeout(() => {
      passwordBackdrop.classList.remove("opacity-0");
      passwordPanel.classList.remove("opacity-0", "translate-y-4", "scale-95");
      passwordPanel.classList.add("opacity-100", "translate-y-0", "scale-100");
    }, 10);
  }

  function closePasswordModal() {
    if (!passwordModal) return;
    passwordBackdrop.classList.add("opacity-0");
    passwordPanel.classList.remove("opacity-100", "translate-y-0", "scale-100");
    passwordPanel.classList.add("opacity-0", "translate-y-4", "scale-95");
    setTimeout(() => {
      passwordModal.classList.add("hidden");
      toggleModalState(false);
    }, 200);
  }

  function openCannotChangeEmailModal() {
    if (!cannotChangeEmailModal) return;

    document.body.appendChild(cannotChangeEmailModal);
    toggleModalState(true);

    cannotChangeEmailModal.classList.remove("hidden");

    setTimeout(() => {
      cannotChangeEmailBackdrop.classList.remove("opacity-0");
      cannotChangeEmailPanel.classList.remove("opacity-0", "translate-y-4", "scale-95");
      cannotChangeEmailPanel.classList.add("opacity-100", "translate-y-0", "scale-100");
    }, 10);
  }

  function closeCannotChangeEmailModal() {
    if (!cannotChangeEmailModal) return;

    cannotChangeEmailBackdrop.classList.add("opacity-0");
    cannotChangeEmailPanel.classList.remove("opacity-100", "translate-y-0", "scale-100");
    cannotChangeEmailPanel.classList.add("opacity-0", "translate-y-4", "scale-95");

    setTimeout(() => {
      cannotChangeEmailModal.classList.add("hidden");
      toggleModalState(false);
    }, 200);
  }

  function openCannotChangePasswordModal() {
    if (!cannotChangePasswordModal) return;

    document.body.appendChild(cannotChangePasswordModal);
    toggleModalState(true);

    cannotChangePasswordModal.classList.remove("hidden");

    setTimeout(() => {
      cannotChangePasswordBackdrop.classList.remove("opacity-0");
      cannotChangePasswordPanel.classList.remove("opacity-0", "translate-y-4", "scale-95");
      cannotChangePasswordPanel.classList.add("opacity-100", "translate-y-0", "scale-100");
    }, 10);
  }

  function closeCannotChangePasswordModal() {
    if (!cannotChangePasswordModal) return;

    cannotChangePasswordBackdrop.classList.add("opacity-0");
    cannotChangePasswordPanel.classList.remove("opacity-100", "translate-y-0", "scale-100");
    cannotChangePasswordPanel.classList.add("opacity-0", "translate-y-4", "scale-95");
    setTimeout(() => {
      cannotChangePasswordModal.classList.add("hidden");
      toggleModalState(false);
    }, 200);
  }

  // Email Modal Flow Logic
  const emailModal = document.getElementById("email-modal");
  const emailBackdrop = document.getElementById("email-backdrop");
  const emailPanel = document.getElementById("email-panel");
  const emailStepInput = document.getElementById("email-step-input");
  const emailStepOtp = document.getElementById("email-step-otp");
  const newEmailField = document.getElementById("newEmail");
  const displayNewEmail = document.getElementById("display-new-email");

  function openEmailModal() {
    if (!emailModal) return;
    // Move to body to escape blur and stacking context
    document.body.appendChild(emailModal);
    toggleModalState(true);
    emailModal.classList.remove("hidden");
    setTimeout(() => {
      emailBackdrop.classList.remove("opacity-0");
      emailPanel.classList.remove("opacity-0", "translate-y-4", "scale-95");
      emailPanel.classList.add("opacity-100", "translate-y-0", "scale-100");
    }, 10);
  }

  function closeEmailModal() {
    if (!emailModal) return;
    emailBackdrop.classList.add("opacity-0");
    emailPanel.classList.remove("opacity-100", "translate-y-0", "scale-100");
    emailPanel.classList.add("opacity-0", "translate-y-4", "scale-95");
    setTimeout(() => {
      emailModal.classList.add("hidden");
      toggleModalState(false);
    }, 200);
  }

  function goToOtpStep() {
    if (!newEmailField.value || !newEmailField.checkValidity()) {
      newEmailField.reportValidity();
      return;
    }
    displayNewEmail.textContent = newEmailField.value;
    emailStepInput.classList.add("hidden");
    emailStepOtp.classList.remove("hidden");
  }

  function goToEmailInputStep() {
    emailStepOtp.classList.add("hidden");
    emailStepInput.classList.remove("hidden");
  }

  passwordForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Disable button
    passwordSubmit.disabled = true;
    passwordSubmit.classList.add("opacity-50", "cursor-not-allowed");
    passwordSubmit.textContent = "Updating...";

    let isValid = true;

    if (currentPassword.value.trim() === "") {
      resetSubmitButton(passwordSubmit, passwordSubmitText);
      isValid = false;
      currentPasswordError.classList.remove("hidden");
      currentPasswordError.textContent = "Current password is required.";
    } else {
      currentPasswordError.classList.add("hidden");
    }

    // Password Validation
    if (newPassword.value.trim() === "") {
      resetSubmitButton(passwordSubmit, passwordSubmitText);
      isValid = false;
      newPasswordError.classList.remove("hidden");
      newPasswordError.textContent = "New password is required.";
    } else if (!validatePassword(newPassword.value.trim())) {
      resetSubmitButton(passwordSubmit, passwordSubmitText);
      isValid = false;
      newPasswordError.classList.remove("hidden");
      newPasswordError.textContent =
        "Password must be at least 8 characters long and include uppercase, lowercase, number, and special character.";
    } else {
      newPasswordError.classList.add("hidden");
    }

    // Confirm Password Validation
    if (confirmNewPassword.value.trim() === "") {
      resetSubmitButton(passwordSubmit, passwordSubmitText);
      isValid = false;
      confirmNewPasswordError.classList.remove("hidden");
      confirmNewPasswordError.textContent = "Please confirm your password.";
    } else if (newPassword.value.trim() !== confirmNewPassword.value.trim()) {
      resetSubmitButton(passwordSubmit, passwordSubmitText);
      isValid = false;
      confirmNewPasswordError.classList.remove("hidden");
      confirmNewPasswordError.textContent = "Passwords do not match.";
    } else {
      confirmNewPasswordError.classList.add("hidden");
    }

    if (isValid) {
      try {
        const res = await fetch("/settings/change-password", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            currentPassword: currentPassword.value.trim(),
            newPassword: newPassword.value.trim(),
          }),
        });
        const data = await res.json();
        if (data.success) {
          window.location.href = data.redirectUrl;
        } else {
          resetSubmitButton(passwordSubmit, passwordSubmitText);
          backendPasswordError.classList.remove("hidden");
          backendPasswordError.textContent = data.message;
        }
      } catch (error) {
        console.log("Error in signup fetch:", error);
        resetSubmitButton(passwordSubmit, passwordSubmitText);
        backendPasswordError.classList.remove("hidden");
        backendPasswordError.textContent = error;
      }
    }
  });

  function validatePassword(password) {
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;
    return passwordRegex.test(password);
  }

  if (passwordBackdrop) passwordBackdrop.addEventListener("click", closePasswordModal);
  if (emailBackdrop) emailBackdrop.addEventListener("click", closeEmailModal);
</script>
