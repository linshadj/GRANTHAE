<div class="max-w-xl mx-auto space-y-8">
  <div class="text-center">
    <h1 class="text-2xl font-bold text-apple-dark">Set Not Password</h1>
    <p class="text-apple-text-gray/80 text-sm mt-2">
      Create a strong password to secure your account.
    </p>
  </div>

  <div class="glass-card p-8">
    <form action="/password-changed" method="GET" class="space-y-6">
      <!-- New Password -->
      <div>
        <label class="block text-sm font-medium text-apple-text-gray mb-2">New Password</label>
        <div class="relative">
          <input
            id="password"
            type="password"
            class="w-full px-4 py-3 rounded-xl bg-apple-gray/50 border border-gray-200 focus:ring-2 focus:ring-apple-gold/50 focus:border-apple-gold outline-none transition-all text-apple-dark"
            placeholder="Enter new password"
          />
          <button
            type="button"
            class="eye absolute right-3 top-1/2 -translate-y-1/2 text-apple-text-gray hover:text-apple-dark"
          >
            <i data-lucide="eye" class="w-5 h-5"></i>
          </button>
        </div>
        <p id="passwordError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
      </div>

      <!-- Confirm New Password -->
      <div>
        <label class="block text-sm font-medium text-apple-text-gray mb-2"
          >Confirm New Password</label
        >
        <div class="relative">
          <input
            id="confirmPassword"
            type="password"
            class="w-full px-4 py-3 rounded-xl bg-apple-gray/50 border border-gray-200 focus:ring-2 focus:ring-apple-gold/50 focus:border-apple-gold outline-none transition-all text-apple-dark"
            placeholder="Confirm new password"
          />
          <button
            type="button"
            class="eye absolute right-3 top-1/2 -translate-y-1/2 text-apple-text-gray hover:text-apple-dark"
          >
            <i data-lucide="eye" class="w-5 h-5"></i>
          </button>
        </div>

        <p id="confirmPasswordError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>
      </div>

      <p id="backendError" class="hidden text-xs mt-1" style="color: rgb(225, 0, 0)"></p>

      <button
        id="submitButton"
        type="submit"
        class="w-full btn-primary py-3.5 shadow-lg shadow-apple-gold/20 font-bold tracking-wide"
      >
        Set Password
      </button>
    </form>
  </div>
</div>

<script>
  // Simple script to toggle password visibility
  document.querySelectorAll(".eye").forEach((btn) => {
    btn.addEventListener("click", () => {
      const input = btn.parentElement.querySelector("input");
      const icon = btn.querySelector("i");

      if (input.type === "password") {
        input.type = "text";
        // icon.setAttribute("data-lucide", "eye-off");
      } else {
        input.type = "password";
        // icon.setAttribute("data-lucide", "eye");
      }
      lucide.createIcons();
    });
  });

  const password = document.getElementById("password");
  const confirmPassword = document.getElementById("confirmPassword");

  const form = document.querySelector("form");

  const passwordError = document.getElementById("passwordError");
  const confirmPasswordError = document.getElementById("confirmPasswordError");

  const backendError = document.getElementById("backendError");
  const submitButton = document.getElementById("submitButton");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Disable button
    submitButton.disabled = true;
    submitButton.classList.add("opacity-50", "cursor-not-allowed");
    submitButton.textContent = "Setting password...";

    let isValid = true;

    // Password Validation
    if (password.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      passwordError.classList.remove("hidden");
      passwordError.textContent = "Password is required.";
    } else if (!validatePassword(password.value.trim())) {
      resetSubmitButton();
      isValid = false;
      passwordError.classList.remove("hidden");
      passwordError.textContent =
        "Password must be at least 8 characters long and include uppercase, lowercase, number, and special character.";
    } else {
      passwordError.classList.add("hidden");
    }

    // Confirm Password Validation
    if (confirmPassword.value.trim() === "") {
      resetSubmitButton();
      isValid = false;
      confirmPasswordError.classList.remove("hidden");
      confirmPasswordError.textContent = "Please confirm your password.";
    } else if (password.value.trim() !== confirmPassword.value.trim()) {
      resetSubmitButton();
      isValid = false;
      confirmPasswordError.classList.remove("hidden");
      confirmPasswordError.textContent = "Passwords do not match.";
    } else {
      confirmPasswordError.classList.add("hidden");
    }

    if (isValid) {
      try {
        const res = await fetch("/reset-password", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            newPassword: password.value.trim(),
          }),
        });

        const data = await res.json();
        if (data.success) {
          window.location.href = data.redirectUrl;
        } else {
          resetSubmitButton();
          backendError.classList.remove("hidden");
          backendError.textContent = data.message;
        }
      } catch (error) {
        console.log("Error in setNewPass fetch:", error);
        resetSubmitButton();
        backendError.classList.remove("hidden");
        backendError.textContent = error;
      }
    }
  });

  function validatePassword(password) {
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;
    return passwordRegex.test(password);
  }

  // enable button function
  function resetSubmitButton() {
    const submitButton = form.querySelector('button[type="submit"]');
    submitButton.disabled = false;
    submitButton.classList.remove("opacity-50", "cursor-not-allowed");
    submitButton.textContent = "Set Password";
  }
</script>
