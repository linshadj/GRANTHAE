<div class="min-h-[70vh] flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8">
    <div class="glass-card max-w-2xl w-full p-10 sm:p-16 rounded-[2.5rem] text-center shadow-2xl border border-white/40">
        <div class="relative w-40 h-40 mx-auto mb-8">
            <div class="absolute inset-0 bg-red-500/10 rounded-full animate-pulse blur-xl opacity-70"></div>
            <div class="relative bg-white/10 border border-red-500/25 w-full h-full rounded-full flex items-center justify-center shadow-lg shadow-red-500/20">
                <i data-lucide="x" class="w-20 h-20 text-red-500"></i>
            </div>
            <div class="absolute top-0 right-0 w-4 h-4 bg-yellow-400 rounded-full animate-bounce" style="animation-delay: 100ms;"></div>
            <div class="absolute bottom-4 left-0 w-3 h-3 bg-blue-400 rounded-full animate-bounce" style="animation-delay: 300ms;"></div>
            <div class="absolute top-1/2 -right-6 w-5 h-5 bg-purple-400 rounded-full animate-bounce" style="animation-delay: 500ms;"></div>
        </div>

        <h1 class="text-4xl sm:text-5xl font-bold text-apple-dark font-luxury mb-4">Payment Failed</h1>
        <p class="text-xl text-apple-text-gray mb-10">
            We could not complete your Razorpay payment.<br>
            <span class="text-sm">Your order is saved, and you can retry the payment now.</span>
        </p>

        <div class="bg-gray-50 rounded-2xl p-6 mb-10 text-left w-full border border-gray-100">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <p class="text-sm text-gray-500 uppercase tracking-widest mb-1 font-semibold">Order Reference ID</p>
                    <p class="text-lg font-mono font-bold text-apple-dark"><%= order.orderID %></p>
                </div>
                <div>
                    <p class="text-sm text-gray-500 uppercase tracking-widest mb-1 font-semibold">Payable Amount</p>
                    <p class="text-lg font-mono font-bold text-apple-dark">₹<%= order.totalAmount %></p>
                </div>
            </div>
            <% if (order.paymentFailureReason) { %>
                <div class="mt-5 pt-5 border-t border-gray-200">
                    <p class="text-sm text-gray-500 uppercase tracking-widest mb-1 font-semibold">Failure Reason</p>
                    <p class="text-sm text-red-500 font-medium"><%= order.paymentFailureReason %></p>
                </div>
            <% } %>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-4">
            <% if (razorpayConfigured && order.paymentMethod === 'Razorpay' && order.orderStatus !== 'Cancelled') { %>
                <button id="retry-payment-btn" type="button" class="btn-primary w-full sm:w-auto px-8 py-3.5">
                    Retry Payment
                </button>
            <% } %>
            <a href="/profile/orders/<%= order._id %>" class="btn-secondary w-full sm:w-auto px-8 py-3.5">
                View Order Details
            </a>
            <a href="/marketplace" class="btn-secondary w-full sm:w-auto px-8 py-3.5">
                Continue Shopping
            </a>
        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    const retryPaymentBtn = document.getElementById('retry-payment-btn');
    const failedOrderId = <%- JSON.stringify(order._id.toString()) %>;

    async function recordRazorpayFailure(internalOrderId, reason) {
        try {
            const res = await fetch('/checkout/razorpay/failure', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ internalOrderId, reason })
            });
            const data = await res.json();
            return data.redirectUrl || `/payment-failure/${internalOrderId}`;
        } catch (error) {
            return `/payment-failure/${internalOrderId}`;
        }
    }

    function openRetryCheckout(data) {
        let paymentFinished = false;
        const options = {
            key: data.razorpay.keyId,
            amount: data.razorpay.amount,
            currency: data.razorpay.currency,
            name: data.razorpay.name,
            description: data.razorpay.description,
            order_id: data.razorpay.orderId,
            prefill: data.razorpay.prefill,
            theme: { color: '#2c3b32' },
            handler: async function(response) {
                paymentFinished = true;
                try {
                    const verifyRes = await fetch('/checkout/razorpay/verify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            internalOrderId: data.internalOrderId,
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_signature: response.razorpay_signature
                        })
                    });
                    const verifyData = await verifyRes.json();
                    window.location.href = verifyData.redirectUrl || (verifyData.success ? `/order-success/${data.orderId}` : `/payment-failure/${data.internalOrderId}`);
                } catch (error) {
                    const redirectUrl = await recordRazorpayFailure(data.internalOrderId, 'Payment verification could not be completed.');
                    window.location.href = redirectUrl;
                }
            },
            modal: {
                ondismiss: async function() {
                    if (!paymentFinished) {
                        const redirectUrl = await recordRazorpayFailure(data.internalOrderId, 'Payment window was closed before completion.');
                        window.location.href = redirectUrl;
                    }
                }
            }
        };

        const razorpay = new Razorpay(options);
        razorpay.on('payment.failed', async function(response) {
            paymentFinished = true;
            const reason = response.error && response.error.description ? response.error.description : 'Razorpay payment failed.';
            const redirectUrl = await recordRazorpayFailure(data.internalOrderId, reason);
            window.location.href = redirectUrl;
        });
        razorpay.open();
    }

    if (retryPaymentBtn) {
        retryPaymentBtn.addEventListener('click', async () => {
            if (typeof Razorpay === 'undefined') {
                Swal.fire({
                    icon: 'error',
                    title: 'Payment Unavailable',
                    text: 'Razorpay checkout could not be loaded. Please try again.',
                    confirmButtonColor: '#e6cfa7',
                    background: '#2c3b32',
                    color: '#e6cfa7'
                });
                return;
            }

            const originalText = retryPaymentBtn.textContent;
            retryPaymentBtn.textContent = 'Opening...';
            retryPaymentBtn.disabled = true;

            try {
                const res = await fetch(`/checkout/razorpay/retry/${failedOrderId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await res.json();

                if (data.success) {
                    openRetryCheckout(data);
                } else {
                    retryPaymentBtn.textContent = originalText;
                    retryPaymentBtn.disabled = false;
                    Swal.fire({
                        icon: 'error',
                        title: 'Retry Failed',
                        text: data.message || 'Could not restart the payment.',
                        confirmButtonColor: '#e6cfa7',
                        background: '#2c3b32',
                        color: '#e6cfa7'
                    });
                }
            } catch (error) {
                retryPaymentBtn.textContent = originalText;
                retryPaymentBtn.disabled = false;
                Swal.fire({
                    icon: 'error',
                    title: 'Retry Failed',
                    text: 'Could not restart the payment.',
                    confirmButtonColor: '#e6cfa7',
                    background: '#2c3b32',
                    color: '#e6cfa7'
                });
            }
        });
    }
</script>
