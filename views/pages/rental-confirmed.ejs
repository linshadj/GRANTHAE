<%
    const rental = rentalOrder.rental || {};
    const imageSrc = rental.coverImage || (Array.isArray(rental.images) && rental.images[0]) || '/images/default-book.jpg';
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 });
    const formatDate = (date) => new Date(date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
    const isPendingRequest = rentalOrder.status === 'Requested';
%>

<div class="min-h-[70vh] flex items-center justify-center py-10">
    <div class="max-w-3xl w-full space-y-8 text-center">
        <div class="relative w-24 h-24 mx-auto">
            <div class="absolute inset-0 bg-green-500/10 rounded-full animate-pulse"></div>
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-20 h-20 <%= isPendingRequest ? 'bg-yellow-500 shadow-yellow-500/20' : 'bg-green-500 shadow-green-500/20' %> rounded-full flex items-center justify-center shadow-lg">
                    <i data-lucide="<%= isPendingRequest ? 'clock' : 'check' %>" class="w-10 h-10 text-white stroke-[3]"></i>
                </div>
            </div>
        </div>

        <div>
            <h1 class="text-3xl font-bold text-apple-dark font-serif mb-3"><%= isPendingRequest ? 'Rental Request Sent' : 'Rental Confirmed' %></h1>
            <p class="text-apple-text-gray">
                <%= isPendingRequest
                    ? 'The owner needs to confirm this request before your wallet is charged and the book is marked as rented.'
                    : 'Your wallet payment is complete and this book is now reserved for you.' %>
            </p>
        </div>

        <div class="glass-card p-6 text-left border border-white/10">
            <div class="flex flex-col sm:flex-row gap-6">
                <img src="<%= imageSrc %>" alt="<%= rental.bookTitle %>" class="w-24 h-32 rounded-xl object-cover border border-white/10">
                <div class="flex-1">
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Rental #<%= rentalOrder.rentalCode %></p>
                    <h2 class="text-2xl font-bold text-apple-dark font-serif"><%= rental.bookTitle %></h2>
                    <p class="text-sm text-apple-text-gray mt-1">by <%= rental.author %></p>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
                        <div>
                            <p class="text-xs text-apple-text-gray uppercase tracking-widest">Window</p>
                            <p class="font-bold text-apple-dark mt-1"><%= formatDate(rentalOrder.startDate) %> - <%= formatDate(rentalOrder.endDate) %></p>
                        </div>
                        <div>
                            <p class="text-xs text-apple-text-gray uppercase tracking-widest">Duration</p>
                            <p class="font-bold text-apple-dark mt-1"><%= rentalOrder.durationDays %> days</p>
                        </div>
                        <div>
                            <p class="text-xs text-apple-text-gray uppercase tracking-widest"><%= isPendingRequest ? 'Payable' : 'Paid' %></p>
                            <p class="font-bold text-apple-dark mt-1">&#8377;<%= formatAmount(rentalOrder.totalAmount) %></p>
                        </div>
                    </div>
                    <div class="mt-5 inline-flex px-3 py-1 rounded-full border text-xs font-bold uppercase tracking-wider <%= isPendingRequest ? 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20' : 'bg-green-500/10 text-green-500 border-green-500/20' %>">
                        <%= rentalOrder.status %>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/profile/rentals" class="btn-secondary justify-center">
                My Rentals
            </a>
            <a href="/rental-place" class="btn-primary justify-center shadow-lg shadow-apple-blue/20">
                Continue Browsing
            </a>
        </div>
    </div>
</div>
