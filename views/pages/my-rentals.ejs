<%
    const formatDate = (date) => new Date(date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 });
    const statusClass = (status) => {
        if (status === 'Requested') return 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20';
        if (status === 'Active') return 'bg-green-500/10 text-green-500 border-green-500/20';
        if (status === 'Return Requested') return 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20';
        if (status === 'Returned') return 'bg-apple-blue/10 text-apple-blue border-apple-blue/20';
        return 'bg-red-500/10 text-red-500 border-red-500/20';
    };
%>

<div class="space-y-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">My Rentals</h1>
            <p class="text-apple-text-gray/80 text-sm">Track borrowed books and submit returns.</p>
        </div>

        <form action="/profile/rentals" method="GET" class="relative w-full md:w-80 group">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray/50 group-focus-within:text-apple-blue transition-colors"></i>
            <input type="text" name="search" value="<%= searchQuery || '' %>" placeholder="Search rented books..."
                class="w-full h-10 pl-10 pr-10 rounded-xl bg-white/5 border border-white/10 text-sm text-apple-dark placeholder:text-apple-text-gray/50 focus:outline-none focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue/50 transition-all">
            <% if (searchQuery) { %>
                <a href="/profile/rentals" class="absolute right-3 top-1/2 -translate-y-1/2 text-apple-text-gray/50 hover:text-red-500 transition-colors">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </a>
            <% } %>
        </form>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="px-6 py-4 border-b border-white/10 flex items-center justify-between">
            <h2 class="font-semibold text-apple-dark flex items-center gap-2">
                <i data-lucide="book-open-check" class="w-4 h-4 text-apple-blue"></i>
                Rented Books
            </h2>
            <a href="/rental-place" class="text-xs font-bold text-apple-blue hover:underline uppercase tracking-widest">Rent More</a>
        </div>

        <% if (rentalOrders && rentalOrders.length > 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-left" style="min-width: 860px;">
                    <thead class="bg-white/5 text-xs text-apple-text-gray uppercase tracking-wider">
                        <tr>
                            <th class="px-6 py-4">Book</th>
                            <th class="px-6 py-4">Rental Window</th>
                            <th class="px-6 py-4">Status</th>
                            <th class="px-6 py-4 text-right">Amount</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                        <% rentalOrders.forEach(rentalOrder => { %>
                            <%
                                const rental = rentalOrder.rental || {};
                                const imageSrc = rental.coverImage || (Array.isArray(rental.images) && rental.images[0]) || '/images/default-book.jpg';
                            %>
                            <tr class="hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <img src="<%= imageSrc %>" alt="<%= rental.bookTitle %>" class="w-10 h-14 object-cover rounded-lg border border-white/10">
                                        <div class="min-w-0">
                                            <a href="/rental/<%= rental._id %>" class="font-bold text-apple-dark hover:text-apple-blue line-clamp-1"><%= rental.bookTitle %></a>
                                            <p class="text-xs text-apple-text-gray">by <%= rental.author %></p>
                                            <p class="text-[10px] text-apple-text-gray/60 uppercase tracking-widest mt-1">#<%= rentalOrder.rentalCode %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-apple-text-gray whitespace-nowrap">
                                    <%= formatDate(rentalOrder.startDate) %> - <%= formatDate(rentalOrder.endDate) %>
                                    <p class="text-[10px] uppercase tracking-widest mt-1"><%= rentalOrder.durationDays %> days</p>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex px-3 py-1 rounded-full border text-xs font-bold <%= statusClass(rentalOrder.status) %>">
                                        <%= rentalOrder.status %>
                                    </span>
                                    <% if (rentalOrder.returnTrackingId) { %>
                                        <p class="text-[10px] text-apple-text-gray mt-2 uppercase tracking-widest">Tracking: <%= rentalOrder.returnTrackingId %></p>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-right font-bold text-apple-dark whitespace-nowrap">
                                    &#8377;<%= formatAmount(rentalOrder.totalAmount) %>
                                    <p class="text-[10px] text-apple-text-gray/60 uppercase tracking-widest mt-1"><%= rentalOrder.paymentStatus %></p>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                    <% if (rentalOrder.status === 'Active') { %>
                                        <a href="/profile/rentals/<%= rentalOrder._id %>/return" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-orange-500/10 text-orange-500 border border-orange-500/20 text-xs font-bold hover:bg-orange-500/15 transition-colors">
                                            <i data-lucide="undo-2" class="w-3.5 h-3.5"></i>
                                            Return
                                        </a>
                                    <% } else if (rentalOrder.status === 'Returned') { %>
                                        <a href="/rental/<%= rental._id %>#reviews" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 text-apple-dark border border-white/10 text-xs font-bold hover:bg-white/10 transition-colors">
                                            Review
                                        </a>
                                    <% } else if (rentalOrder.status === 'Requested') { %>
                                        <span class="text-xs text-yellow-500">Waiting for owner confirmation</span>
                                    <% } else if (rentalOrder.status === 'Rejected') { %>
                                        <span class="text-xs text-red-500"><%= rentalOrder.rejectionReason || 'Declined by owner' %></span>
                                    <% } else { %>
                                        <span class="text-xs text-apple-text-gray">No action required</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-12 text-center">
                <div class="w-16 h-16 bg-white/5 text-apple-text-gray/40 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-white/10">
                    <i data-lucide="book-open" class="w-8 h-8"></i>
                </div>
                <h2 class="text-xl font-bold text-apple-dark mb-2">No rentals yet</h2>
                <p class="text-sm text-apple-text-gray mb-6">Books you rent from Rentalplace will appear here.</p>
                <a href="/rental-place" class="btn-primary inline-flex items-center gap-2 px-6 py-3">
                    <i data-lucide="book-open" class="w-4 h-4"></i>
                    Browse Rentalplace
                </a>
            </div>
        <% } %>
    </div>
</div>
