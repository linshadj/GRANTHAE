<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 pt-32">
    <!-- Header/Breadcrumbs -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm font-medium text-apple-text-gray">
                    <li><a href="/home" class="hover:text-apple-dark transition-colors">Home</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li class="text-apple-dark">Marketplace</li>
                </ol>
            </nav>
            <h1 class="text-4xl font-bold text-apple-dark tracking-tight">Marketplace</h1>
            <p class="mt-2 text-apple-text-gray"><%= totalProducts %> matches found</p>
        </div>

        <!-- Search Bar -->
        <div class="relative w-full md:w-96">
            <form action="/shop" method="GET" class="relative group">
                <% if (query.category) { %>
                    <% if (Array.isArray(query.category)) { %>
                        <% query.category.forEach(cat => { %>
                            <input type="hidden" name="category" value="<%= cat %>">
                        <% }) %>
                    <% } else { %>
                        <input type="hidden" name="category" value="<%= query.category %>">
                    <% } %>
                <% } %>
                <% if (query.sort) { %>
                    <input type="hidden" name="sort" value="<%= query.sort %>">
                <% } %>
                <input type="text" name="search" value="<%= query.search || '' %>"
                    placeholder="Search by title or author..."
                    class="w-full pl-12 pr-12 py-3 bg-white border border-gray-200 rounded-2xl focus:ring-2 focus:ring-apple-dark/5 focus:border-apple-dark transition-all shadow-sm group-hover:shadow-md">
                <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-apple-text-gray"></i>
                <% if (query.search) { %>
                    <button type="button" onclick="window.location.href='/shop?<%= new URLSearchParams({...query, search: ''}).toString() %>'"
                        class="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:bg-gray-100 rounded-full transition-colors">
                        <i data-lucide="x" class="w-4 h-4 text-apple-text-gray"></i>
                    </button>
                <% } %>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <!-- Sidebar filters -->
        <aside class="hidden lg:block lg:col-span-1">
            <%- include('../partials/filter-panel') %>
        </aside>

        <!-- Product Grid -->
        <main class="lg:col-span-3">
            <% if (products.length > 0) { %>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
                    <% products.forEach(book => { %>
                        <%- include('../partials/book-card', { book, 
                             book: {
                                 ...book,
                                 title: book.name,
                                 image: book.coverImage || '/images/default-book.jpg',
                                 rating: book.avgRating || '4.5'
                             }
                        }) %>
                    <% }) %>
                </div>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                    <div class="mt-16 flex items-center justify-center gap-2">
                        <% if (currentPage > 1) { %>
                            <a href="/shop?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>"
                                class="p-2 rounded-xl border border-gray-200 hover:bg-white hover:shadow-md transition-all text-apple-dark">
                                <i data-lucide="chevron-left" class="w-5 h-5"></i>
                            </a>
                        <% } %>

                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <a href="/shop?<%= new URLSearchParams({...query, page: i}).toString() %>"
                                class="w-10 h-10 flex items-center justify-center rounded-xl font-medium transition-all
                                <%= currentPage === i ? 'bg-apple-dark text-white shadow-lg' : 'text-apple-text-gray hover:bg-white hover:shadow-md border border-transparent hover:border-gray-100' %>">
                                <%= i %>
                            </a>
                        <% } %>

                        <% if (currentPage < totalPages) { %>
                            <a href="/shop?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>"
                                class="p-2 rounded-xl border border-gray-200 hover:bg-white hover:shadow-md transition-all text-apple-dark">
                                <i data-lucide="chevron-right" class="w-5 h-5"></i>
                            </a>
                        <% } %>
                    </div>
                <% } %>
            <% } else { %>
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center py-20 bg-apple-teal/10 rounded-3xl border border-dashed border-apple-teal/30">
                    <div class="w-20 h-20 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-6">
                        <i data-lucide="search-x" class="w-10 h-10 text-apple-text-gray"></i>
                    </div>
                    <h2 class="text-xl font-bold text-apple-dark mb-2">No books found</h2>
                    <p class="text-apple-text-gray mb-8">Try adjusting your filters or search terms.</p>
                    <a href="/shop" class="btn-primary">Clear all filters</a>
                </div>
            <% } %>
        </main>
    </div>
</div>

<!-- Mobile Filters Overlay (Optional, for now just simple grid) -->
