<%
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', {
        maximumFractionDigits: 2
    });

    const counts = listings.reduce((acc, listing) => {
        acc.total += 1;
        acc[listing.status] = (acc[listing.status] || 0) + 1;
        return acc;
    }, { total: 0 });

    const liveCount = (counts.Available || 0) + (counts.Approved || 0);
    const pendingCount = counts.Pending || 0;
    const rentedCount = counts.Rented || 0;
    const rejectedCount = counts.Rejected || 0;

    const statusMeta = {
        Pending: {
            label: 'Pending Review',
            icon: 'clock-3',
            badge: 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20',
            dot: 'bg-yellow-500 animate-pulse'
        },
        Approved: {
            label: 'Live & Available',
            icon: 'check-circle-2',
            badge: 'bg-green-500/10 text-green-500 border-green-500/20',
            dot: 'bg-green-500'
        },
        Available: {
            label: 'Live & Available',
            icon: 'check-circle-2',
            badge: 'bg-green-500/10 text-green-500 border-green-500/20',
            dot: 'bg-green-500'
        },
        Rejected: {
            label: 'Rejected',
            icon: 'alert-circle',
            badge: 'bg-red-500/10 text-red-500 border-red-500/20',
            dot: 'bg-red-500'
        },
        Rented: {
            label: 'Currently Rented',
            icon: 'book-check',
            badge: 'bg-apple-blue/10 text-apple-blue border-apple-blue/20',
            dot: 'bg-apple-blue'
        },
        Hidden: {
            label: 'Hidden',
            icon: 'eye-off',
            badge: 'bg-white/5 text-apple-text-gray border-white/10',
            dot: 'bg-apple-text-gray'
        }
    };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 space-y-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm font-medium text-apple-text-gray">
                    <li><a href="/home" class="hover:text-apple-dark transition-colors">Home</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li><a href="/profile" class="hover:text-apple-dark transition-colors">Profile</a></li>
                    <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
                    <li class="text-apple-dark">My Listings</li>
                </ol>
            </nav>
            <h1 class="text-4xl font-bold text-apple-dark tracking-tight font-serif">My Listings</h1>
            <p class="mt-2 text-apple-text-gray">Manage listed rental books, review status, and track renter interest.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 lg:justify-end">
            <a href="/profile/my-listings/rental-requests"
                class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-2xl bg-white/5 border border-white/10 text-apple-dark hover:bg-white/10 transition-all font-bold text-sm">
                <i data-lucide="inbox" class="w-4 h-4"></i>
                Incoming Requests
            </a>
            <a href="/list-rental-book"
                class="btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 font-bold shadow-xl shadow-apple-gold/20">
                <i data-lucide="plus" class="w-5 h-5"></i>
                Add New Listing
            </a>
        </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Total Listings</p>
            <p class="text-3xl font-bold text-apple-dark mt-2"><%= counts.total %></p>
        </div>
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Live</p>
            <p class="text-3xl font-bold text-green-500 mt-2"><%= liveCount %></p>
        </div>
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Pending</p>
            <p class="text-3xl font-bold text-yellow-500 mt-2"><%= pendingCount %></p>
        </div>
        <div class="bg-apple-card border border-white/10 rounded-2xl p-5 shadow-sm">
            <p class="text-xs uppercase tracking-widest text-apple-text-gray font-bold">Rejected</p>
            <p class="text-3xl font-bold text-red-500 mt-2"><%= rejectedCount %></p>
        </div>
    </div>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="inline-flex p-1 bg-white/5 border border-white/10 rounded-2xl w-full sm:w-auto">
            <a href="/profile/my-listings"
                class="flex-1 sm:flex-none px-4 py-2 rounded-xl bg-apple-gold text-[#1a231e] font-bold text-sm text-center shadow-lg shadow-apple-gold/10">
                Listings
            </a>
            <a href="/profile/my-listings/rental-requests"
                class="flex-1 sm:flex-none px-4 py-2 rounded-xl text-apple-text-gray hover:text-apple-dark hover:bg-white/5 font-bold text-sm text-center transition-colors">
                Incoming Requests
            </a>
        </div>

        <p class="text-sm text-apple-text-gray"><%= rentedCount %> currently rented</p>
    </div>

    <% if (listings.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% listings.forEach(listing => { %>
                <%
                    const meta = statusMeta[listing.status] || statusMeta.Hidden;
                    const imageSrc = listing.coverImage || (Array.isArray(listing.images) && listing.images[0]) || '';
                %>
                <article class="bg-apple-card border border-white/10 rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all group">
                    <div class="relative aspect-[4/5] bg-white/5 overflow-hidden">
                        <% if (imageSrc) { %>
                            <img src="<%= imageSrc %>" alt="<%= listing.bookTitle %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center bg-white/5">
                                <i data-lucide="book-open" class="w-12 h-12 text-apple-text-gray/40"></i>
                            </div>
                        <% } %>

                        <div class="absolute top-4 left-4 flex items-center gap-2 px-3 py-1.5 rounded-full border <%= meta.badge %> backdrop-blur-md text-xs font-bold uppercase tracking-wider">
                            <span class="w-1.5 h-1.5 rounded-full <%= meta.dot %>"></span>
                            <%= meta.label %>
                        </div>
                    </div>

                    <div class="p-6 space-y-5">
                        <div>
                            <div class="flex items-center gap-2 mb-3">
                                <span class="px-2.5 py-1 bg-apple-blue/10 text-apple-blue rounded-lg text-[10px] font-bold uppercase tracking-wider">
                                    <%= listing.category ? listing.category.name : 'Uncategorized' %>
                                </span>
                                <span class="px-2.5 py-1 bg-white/5 text-apple-text-gray rounded-lg text-[10px] font-bold uppercase tracking-wider">
                                    <%= listing.bookCondition %>
                                </span>
                            </div>
                            <h2 class="text-xl font-bold text-apple-dark line-clamp-2 group-hover:text-apple-blue transition-colors">
                                <%= listing.bookTitle %>
                            </h2>
                            <p class="text-sm text-apple-text-gray mt-1">by <%= listing.author %></p>
                        </div>

                        <div class="grid grid-cols-3 gap-3">
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-3">
                                <p class="text-[10px] uppercase tracking-wider text-apple-text-gray font-bold">Rate</p>
                                <p class="text-sm font-bold text-apple-dark mt-1">&#8377;<%= formatAmount(listing.dailyRate) %></p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-3">
                                <p class="text-[10px] uppercase tracking-wider text-apple-text-gray font-bold">Deposit</p>
                                <p class="text-sm font-bold text-apple-dark mt-1">&#8377;<%= formatAmount(listing.depositAmount) %></p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-3">
                                <p class="text-[10px] uppercase tracking-wider text-apple-text-gray font-bold">Min</p>
                                <p class="text-sm font-bold text-apple-dark mt-1"><%= listing.minRentalDays %> days</p>
                            </div>
                        </div>

                        <% if (listing.status === 'Rejected' && listing.rejectionReason) { %>
                            <button type="button" data-rejection-reason="<%= listing.rejectionReason %>" onclick="showRejectionReason(this)"
                                class="w-full px-4 py-2.5 rounded-xl bg-red-500/10 text-red-500 border border-red-500/20 text-sm font-bold hover:bg-red-500/15 transition-colors">
                                View Rejection Reason
                            </button>
                        <% } %>

                        <div class="flex gap-3 pt-1">
                            <a href="/rental/<%= listing._id %>"
                                class="flex-1 btn-primary inline-flex items-center justify-center gap-2 py-3 font-bold">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                                View
                            </a>
                            <button type="button" onclick="showEditNotice()"
                                class="px-4 py-3 rounded-full bg-white/5 border border-white/10 text-apple-text-gray hover:text-apple-dark hover:bg-white/10 transition-all">
                                <i data-lucide="edit-3" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <div class="bg-apple-card border border-white/10 rounded-3xl p-10 sm:p-16 text-center shadow-lg">
            <div class="w-20 h-20 bg-apple-blue/10 rounded-3xl flex items-center justify-center mx-auto mb-6">
                <i data-lucide="book" class="w-10 h-10 text-apple-blue"></i>
            </div>
            <h3 class="text-2xl font-bold text-apple-dark mb-2 font-serif">No listings yet</h3>
            <p class="text-apple-text-gray mb-8 max-w-sm mx-auto">Start earning by sharing your library with readers nearby.</p>
            <a href="/list-rental-book" class="btn-primary inline-flex items-center gap-2 px-8 py-3 font-bold">
                <i data-lucide="plus" class="w-4 h-4"></i>
                List Your First Book
            </a>
        </div>
    <% } %>
</div>

<script>
    function showRejectionReason(button) {
        Swal.fire({
            title: 'Reason for Rejection',
            text: button.dataset.rejectionReason || 'No reason provided.',
            icon: 'info',
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonColor: '#E6CFA7'
        });
    }

    function showEditNotice() {
        Swal.fire({
            title: 'Edit Listing',
            text: 'Edit listing tools are being prepared.',
            icon: 'info',
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonColor: '#E6CFA7'
        });
    }
</script>
