<%
    const rentalImages = Array.from(new Set([rental.coverImage, ...((rental.images || []))].filter(Boolean)));
    const categoryName = rental.category ? rental.category.name : 'Uncategorized';
    const ownerName = rental.owner ? `${rental.owner.firstName || ''} ${rental.owner.lastName || ''}`.trim() : 'GRANTHAE User';
    const dailyRate = Number(rental.dailyRate || 0);
    const minRentalDays = Number(rental.minRentalDays || 1);
    const depositAmount = Number(rental.depositAmount || 0);
    const minRentalCharge = dailyRate * minRentalDays;
    const requiredWalletBalance = minRentalCharge + depositAmount;
    const walletBalance = wallet ? Number(wallet.balance || 0) : 0;
    const isRentalAvailable = rental.status === 'Available' && !rental.isBlocked && !rental.isDeleted;
    const isOwnListing = typeof isOwner !== 'undefined' && isOwner;
    const canRequestRental = isRentalAvailable && !isOwnListing;
    const rentalReviews = reviewMeta && reviewMeta.reviews ? reviewMeta.reviews : [];
    const rentalRating = Number(reviewMeta ? reviewMeta.avgRating : 0);
    const rentalReviewCount = reviewMeta ? reviewMeta.reviewCount : 0;
    const createdDate = rental.createdAt ? new Date(rental.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'Not available';
    const updatedDate = rental.updatedAt ? new Date(rental.updatedAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'Not available';
    const statusClass = isRentalAvailable
        ? 'bg-green-500/10 text-green-500 border-green-500/20'
        : rental.status === 'Rejected'
            ? 'bg-red-500/10 text-red-500 border-red-500/20'
            : 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20';
%>

<style>
    @media (min-width: 1024px) {
        .rental-price-panel {
            max-height: calc(100vh - 8rem);
            overflow-y: auto;
        }
    }
</style>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-24 lg:pb-36">
    <nav class="flex mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm font-medium text-apple-text-gray">
            <li><a href="/home" class="hover:text-apple-dark transition-colors">Home</a></li>
            <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
            <li><a href="/rental-place" class="hover:text-apple-dark transition-colors">Rentalplace</a></li>
            <li><i data-lucide="chevron-right" class="w-4 h-4"></i></li>
            <li class="text-apple-dark truncate max-w-[220px]"><%= rental.bookTitle %></li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <aside class="space-y-6">
            <div class="space-y-4">
                <div class="aspect-[2/3] w-full rounded-3xl bg-white/5 border border-white/10 overflow-hidden shadow-2xl relative group">
                    <% if (rentalImages.length > 0) { %>
                        <img id="main-rental-image" src="<%= rentalImages[0] %>" alt="<%= rental.bookTitle %>"
                            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center">
                            <i data-lucide="book-open" class="w-16 h-16 text-apple-text-gray/40"></i>
                        </div>
                    <% } %>
                    <div class="absolute top-4 left-4 px-3 py-1.5 rounded-full border <%= statusClass %> backdrop-blur-md text-xs font-bold uppercase tracking-wider">
                        <%= rental.status %>
                    </div>
                </div>

                <% if (rentalImages.length > 1) { %>
                    <div class="grid grid-cols-4 gap-3">
                        <% rentalImages.slice(0, 4).forEach((img, index) => { %>
                            <button type="button" onclick="updateRentalImage(this, '<%= img %>')"
                                class="rental-thumbnail-btn aspect-[2/3] rounded-xl overflow-hidden border-2 p-0.5 transition-all <%= index === 0 ? 'border-apple-gold' : 'border-transparent hover:border-white/20' %>">
                                <img src="<%= img %>" alt="Rental image <%= index + 1 %>" class="w-full h-full object-cover rounded-lg">
                            </button>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <button type="button" onclick="shareRental()"
                    class="flex items-center justify-center gap-2 py-3 border border-white/10 rounded-xl bg-white/5 hover:bg-white/10 transition-all text-sm font-bold text-apple-dark">
                    <i data-lucide="share-2" class="w-4 h-4"></i>
                    Share
                </button>
                <% if (isOwnListing) { %>
                    <a href="/profile/my-listings/<%= rental._id %>/edit"
                        class="flex items-center justify-center gap-2 py-3 border border-white/10 rounded-xl bg-white/5 hover:bg-white/10 transition-all text-sm font-bold text-apple-dark">
                        <i data-lucide="edit-3" class="w-4 h-4"></i>
                        Edit
                    </a>
                <% } else { %>
                    <a href="/rental-place"
                    class="flex items-center justify-center gap-2 py-3 border border-white/10 rounded-xl bg-white/5 hover:bg-white/10 transition-all text-sm font-bold text-apple-dark">
                        <i data-lucide="book-open" class="w-4 h-4"></i>
                        More
                    </a>
                <% } %>
            </div>
        </aside>

        <section class="space-y-8">
            <div>
                <div class="flex flex-wrap items-center gap-3 mb-5">
                    <span class="px-3 py-1 rounded-lg bg-apple-blue/10 text-apple-blue text-xs font-bold uppercase tracking-wider"><%= categoryName %></span>
                    <span class="px-3 py-1 rounded-lg bg-white/5 text-apple-text-gray border border-white/10 text-xs font-bold uppercase tracking-wider"><%= rental.bookCondition %> Condition</span>
                    <% if (rental.isBlocked) { %>
                        <span class="px-3 py-1 rounded-lg bg-red-500/10 text-red-500 border border-red-500/20 text-xs font-bold uppercase tracking-wider">Blocked</span>
                    <% } %>
                </div>

                <h1 class="text-4xl md:text-5xl font-bold text-apple-dark leading-tight font-serif"><%= rental.bookTitle %></h1>
                <p class="text-lg text-apple-text-gray mt-3">by <span class="text-apple-dark font-semibold"><%= rental.author %></span></p>
                <div class="flex flex-wrap items-center gap-4 mt-6">
                    <div class="flex items-center text-yellow-400">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <i data-lucide="star" class="w-5 h-5 <%= i <= Math.round(rentalRating) ? 'fill-current' : 'text-white/20' %>"></i>
                        <% } %>
                    </div>
                    <span class="text-sm text-apple-text-gray font-medium"><%= rentalRating.toFixed(1) %> (<%= rentalReviewCount %> reviews)</span>
                </div>
            </div>

            <div class="text-apple-text-gray leading-relaxed whitespace-pre-line">
                <p><%= rental.description %></p>
            </div>

            <div class="border-y border-white/10 py-6 grid grid-cols-2 gap-y-5 gap-x-6">
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Category</span>
                    <span class="text-sm font-semibold text-apple-dark"><%= categoryName %></span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Condition</span>
                    <span class="text-sm font-semibold text-apple-dark"><%= rental.bookCondition %></span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Status</span>
                    <span class="text-sm font-semibold text-apple-dark"><%= rental.status %></span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Daily Rate</span>
                    <span class="text-sm font-semibold text-apple-dark">&#8377;<%= dailyRate.toLocaleString('en-IN') %></span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Minimum Rental</span>
                    <span class="text-sm font-semibold text-apple-dark"><%= minRentalDays %> days</span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Security Deposit</span>
                    <span class="text-sm font-semibold text-apple-dark">&#8377;<%= depositAmount.toLocaleString('en-IN') %></span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Listed</span>
                    <span class="text-sm font-semibold text-apple-dark"><%= createdDate %></span>
                </div>
                <div>
                    <span class="block text-xs font-bold text-apple-text-gray/70 uppercase tracking-wide">Updated</span>
                    <span class="text-sm font-semibold text-apple-dark"><%= updatedDate %></span>
                </div>
            </div>

            <% if (rental.status === 'Rejected' && rental.rejectionReason) { %>
                <div class="bg-red-500/10 border border-red-500/20 rounded-3xl p-5">
                    <p class="text-xs text-red-500 font-bold uppercase tracking-widest mb-2">Rejection Reason</p>
                    <p class="text-sm text-apple-text-gray"><%= rental.rejectionReason %></p>
                </div>
            <% } %>

            <div class="flex items-center gap-4 p-5 bg-white/5 border border-white/10 rounded-3xl">
                <div class="w-12 h-12 rounded-2xl bg-apple-blue/10 flex items-center justify-center text-apple-blue font-bold">
                    <%= ownerName ? ownerName[0].toUpperCase() : 'U' %>
                </div>
                <div>
                    <p class="text-xs text-apple-text-gray font-bold uppercase tracking-widest">Listed By</p>
                    <p class="text-apple-dark font-bold"><%= ownerName %></p>
                </div>
                <div class="ml-auto hidden sm:block">
                    <div class="flex items-center gap-1 text-green-500 bg-green-500/10 px-3 py-1 rounded-full text-[10px] font-bold">
                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                        Verified Owner
                    </div>
                </div>
            </div>
        </section>

        <aside class="lg:self-start">
            <div class="rental-price-panel glass-card p-6 shadow-2xl lg:sticky lg:top-28">
                <div class="flex justify-between items-end mb-6">
                    <div>
                        <span class="text-4xl font-bold text-apple-dark">&#8377;<%= dailyRate.toLocaleString('en-IN') %></span>
                        <span class="text-apple-text-gray text-sm">/ day</span>
                    </div>
                    <span class="px-3 py-1 rounded-lg border <%= statusClass %> text-xs font-bold uppercase"><%= isRentalAvailable ? 'Available' : rental.status %></span>
                </div>

                <div class="space-y-4 mb-6">
                    <div>
                        <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-wider mb-2">Rental Start Date</label>
                        <input id="rentalStartDate" type="date"
                            class="w-full px-3 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-wider mb-2">Duration</label>
                        <input id="rentalDuration" type="number" min="<%= minRentalDays %>" value="<%= minRentalDays %>"
                            class="w-full px-3 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue outline-none">
                        <p class="text-xs text-apple-text-gray mt-2">Minimum rental period is <%= minRentalDays %> days.</p>
                    </div>
                </div>

                <div class="space-y-3 mb-6 bg-white/5 border border-white/10 rounded-2xl p-4">
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-apple-text-gray">Rental charge</span>
                        <span id="rentalCharge" class="font-bold text-apple-dark">&#8377;<%= minRentalCharge.toLocaleString('en-IN') %></span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-apple-text-gray">Refundable deposit</span>
                        <span class="font-bold text-apple-dark">&#8377;<%= depositAmount.toLocaleString('en-IN') %></span>
                    </div>
                    <div class="pt-3 border-t border-white/10 flex items-center justify-between text-sm">
                        <span class="text-apple-text-gray">Required wallet balance</span>
                        <span id="requiredWalletBalance" class="font-bold text-apple-dark">&#8377;<%= requiredWalletBalance.toLocaleString('en-IN') %></span>
                    </div>
                </div>

                <div class="mb-6 flex items-start gap-3 text-sm <%= isLoggedIn && walletBalance >= requiredWalletBalance ? 'text-green-500 bg-green-500/10 border-green-500/20' : 'text-orange-500 bg-orange-500/10 border-orange-500/20' %> border p-3 rounded-2xl">
                    <i data-lucide="wallet" class="w-5 h-5 shrink-0"></i>
                    <div>
                        <% if (isLoggedIn) { %>
                            <p class="font-bold">Wallet balance: &#8377;<%= walletBalance.toLocaleString('en-IN') %></p>
                            <p class="text-xs opacity-80">Keep this amount available. Payment is captured only after the owner confirms.</p>
                        <% } else { %>
                            <p class="font-bold">Login required</p>
                            <p class="text-xs opacity-80">Sign in to check wallet balance and request this rental.</p>
                        <% } %>
                    </div>
                </div>

                <button type="button" onclick="handleRentalRequest()"
                    class="w-full btn-primary py-3 text-base shadow-lg shadow-apple-gold/20 flex items-center justify-center gap-2 <%= !canRequestRental ? 'opacity-50 cursor-not-allowed' : '' %>"
                    <%= !canRequestRental ? 'disabled' : '' %>>
                    <i data-lucide="calendar" class="w-5 h-5"></i>
                    <%= isOwnListing ? 'Your Listing' : 'Request to Rent' %>
                </button>
                <p class="text-xs text-center text-apple-text-gray mt-3"><%= isOwnListing ? 'You cannot rent a book listed by you.' : 'The owner must confirm before the book is marked as rented.' %></p>

                <div class="mt-6 pt-6 border-t border-white/10 grid grid-cols-2 gap-4">
                    <div class="text-center">
                        <i data-lucide="shield-check" class="w-5 h-5 mx-auto mb-1 text-apple-text-gray"></i>
                        <span class="text-[10px] text-apple-text-gray font-bold uppercase">Rental Protection</span>
                    </div>
                    <div class="text-center">
                        <i data-lucide="rotate-ccw" class="w-5 h-5 mx-auto mb-1 text-apple-text-gray"></i>
                        <span class="text-[10px] text-apple-text-gray font-bold uppercase">Deposit Return</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <% if (relatedRentals && relatedRentals.length > 0) { %>
        <section class="mt-24 pt-12 border-t border-white/10">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-2xl font-bold text-apple-dark font-serif">Related Rental Books</h2>
                <a href="/rental-place?category=<%= rental.category ? rental.category._id : '' %>" class="text-sm font-bold text-apple-blue hover:underline">View more</a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <% relatedRentals.forEach(relRental => { %>
                    <article class="bg-apple-card border border-white/10 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all">
                        <a href="/rental/<%= relRental._id %>" class="block aspect-[2/3] bg-white/5">
                            <img src="<%= relRental.coverImage || (relRental.images && relRental.images[0]) || '/images/default-book.jpg' %>" alt="<%= relRental.bookTitle %>" class="w-full h-full object-cover">
                        </a>
                        <div class="p-4">
                            <p class="text-[10px] text-apple-blue font-bold uppercase tracking-widest mb-2"><%= relRental.category ? relRental.category.name : 'Rental' %></p>
                            <a href="/rental/<%= relRental._id %>" class="font-bold text-apple-dark hover:text-apple-blue line-clamp-2"><%= relRental.bookTitle %></a>
                            <p class="text-xs text-apple-text-gray mt-1">by <%= relRental.author %></p>
                            <div class="mt-4 flex items-center justify-between">
                                <span class="text-sm font-bold text-apple-dark">&#8377;<%= Number(relRental.dailyRate || 0).toLocaleString('en-IN') %>/day</span>
                                <span class="text-[10px] text-green-500 font-bold uppercase tracking-widest">Available</span>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    <% } %>

    <section id="reviews" class="mt-24 pt-12 border-t border-white/10">
        <div class="flex items-center justify-between gap-4 mb-8">
            <h2 class="text-2xl font-bold text-apple-dark font-serif">Rental Reviews</h2>
            <span class="text-sm text-apple-text-gray"><%= rentalReviewCount %> reviews</span>
        </div>

        <% if (reviewMeta && reviewMeta.canReview) { %>
            <form id="rentalReviewForm" class="bg-apple-card border border-white/10 rounded-3xl p-6 mb-8 space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
                    <div class="md:col-span-1">
                        <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Rating</label>
                        <select name="rating" required class="w-full px-3 py-3 bg-white/5 border border-white/10 rounded-xl text-apple-dark outline-none">
                            <option value="">Select</option>
                            <option value="5">5 Stars</option>
                            <option value="4">4 Stars</option>
                            <option value="3">3 Stars</option>
                            <option value="2">2 Stars</option>
                            <option value="1">1 Star</option>
                        </select>
                    </div>
                    <div class="md:col-span-4">
                        <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Review</label>
                        <textarea name="comment" rows="3" required class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-apple-dark outline-none resize-none" placeholder="Share your rental experience..."></textarea>
                    </div>
                </div>
                <div class="flex justify-end">
                    <button type="submit" class="btn-primary px-6 py-3 font-bold">Submit Review</button>
                </div>
            </form>
        <% } else if (reviewMeta && reviewMeta.userReview) { %>
            <div class="bg-green-500/10 border border-green-500/20 rounded-2xl p-4 mb-8 text-sm text-green-600 font-bold">
                You have already reviewed this rental book.
            </div>
        <% } %>

        <% if (rentalReviews.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% rentalReviews.forEach(review => { %>
                    <div class="bg-apple-card border border-white/10 p-6 rounded-3xl shadow-sm">
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-apple-blue/10 text-apple-blue rounded-full flex items-center justify-center font-bold">
                                    <%= review.user?.firstName ? review.user.firstName[0] : 'R' %>
                                </div>
                                <div>
                                    <p class="font-bold text-apple-dark"><%= review.user?.firstName || 'Reader' %> <%= review.user?.lastName || '' %></p>
                                    <p class="text-xs text-apple-text-gray"><%= review.createdAt ? new Date(review.createdAt).toLocaleDateString('en-IN') : '' %></p>
                                </div>
                            </div>
                            <div class="flex">
                                <% for (let i = 1; i <= 5; i++) { %>
                                    <i data-lucide="star" class="w-4 h-4 <%= i <= review.rating ? 'text-yellow-400 fill-current' : 'text-white/20' %>"></i>
                                <% } %>
                            </div>
                        </div>
                        <p class="text-apple-text-gray text-sm leading-relaxed">"<%= review.comment %>"</p>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-12 bg-white/5 rounded-3xl border border-dashed border-white/10">
                <i data-lucide="message-square-quote" class="w-12 h-12 text-apple-text-gray/50 mx-auto mb-4"></i>
                <h3 class="text-lg font-bold text-apple-dark">No rental reviews yet</h3>
                <p class="text-apple-text-gray">Reviews will appear after readers share feedback.</p>
            </div>
        <% } %>
    </section>
</div>

<div id="fund-check-modal" class="fixed inset-0 z-[100000] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="closeCheckModal()"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4 text-center">
            <div class="relative transform overflow-hidden rounded-3xl bg-apple-card text-left shadow-2xl sm:w-full sm:max-w-md p-6 border border-white/10">
                <div class="w-16 h-16 rounded-full bg-red-500/10 flex items-center justify-center text-red-500 mb-4 mx-auto">
                    <i data-lucide="alert-circle" class="w-8 h-8"></i>
                </div>
                <h3 class="text-xl font-bold text-apple-dark text-center mb-2">Insufficient Wallet Balance</h3>
                <p class="text-sm text-apple-text-gray text-center mb-6">Add funds to cover the rental charge and refundable security deposit.</p>

                <div class="space-y-3 mb-6">
                    <div class="bg-white/5 border border-white/10 rounded-xl p-4 flex justify-between items-center">
                        <span class="text-apple-text-gray text-sm">Required</span>
                        <span id="modalRequiredBalance" class="text-lg font-bold text-apple-dark">&#8377;0</span>
                    </div>
                    <div class="bg-white/5 border border-white/10 rounded-xl p-4 flex justify-between items-center">
                        <span class="text-apple-text-gray text-sm">Current Wallet</span>
                        <span id="modalCurrentBalance" class="text-lg font-bold text-apple-dark">&#8377;0</span>
                    </div>
                    <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 flex justify-between items-center">
                        <span class="text-red-500 text-sm font-bold">Shortfall</span>
                        <span id="modalShortfall" class="text-lg font-bold text-red-500">&#8377;0</span>
                    </div>
                </div>

                <div class="space-y-3">
                    <a href="/wallet/add-funds" class="block w-full btn-primary py-3 text-center shadow-lg shadow-apple-gold/20">Add Funds</a>
                    <button type="button" onclick="closeCheckModal()"
                        class="block w-full py-3 rounded-xl border border-white/10 text-apple-text-gray hover:text-apple-dark hover:bg-white/5 transition-colors font-bold">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const rentalDailyRate = <%= dailyRate %>;
    const rentalDeposit = <%= depositAmount %>;
    const minimumRentalDays = <%= minRentalDays %>;
    const currentWalletBalance = <%= walletBalance %>;
    const userLoggedIn = <%= isLoggedIn ? 'true' : 'false' %>;
    const rentalAvailable = <%= isRentalAvailable ? 'true' : 'false' %>;
    const rentalOwnedByUser = <%= isOwnListing ? 'true' : 'false' %>;

    const rentalDuration = document.getElementById('rentalDuration');
    const rentalStartDate = document.getElementById('rentalStartDate');
    const rentalCharge = document.getElementById('rentalCharge');
    const requiredWalletBalance = document.getElementById('requiredWalletBalance');

    function formatRupees(amount) {
        return `₹${Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 })}`;
    }

    function getSelectedDuration() {
        const duration = Number(rentalDuration?.value || minimumRentalDays);
        return Math.max(minimumRentalDays, duration);
    }

    function getRequiredBalance() {
        return (getSelectedDuration() * rentalDailyRate) + rentalDeposit;
    }

    function updateRentalTotals() {
        const duration = getSelectedDuration();
        const charge = duration * rentalDailyRate;
        const required = charge + rentalDeposit;

        if (rentalDuration && Number(rentalDuration.value) < minimumRentalDays) {
            rentalDuration.value = minimumRentalDays;
        }
        if (rentalCharge) rentalCharge.textContent = formatRupees(charge);
        if (requiredWalletBalance) requiredWalletBalance.textContent = formatRupees(required);
    }

    async function handleRentalRequest() {
        updateRentalTotals();

        if (!userLoggedIn) {
            window.location.href = '/sign-in?status=error&message=Please%20login';
            return;
        }

        if (rentalOwnedByUser) {
            Swal.fire({
                title: 'Own Listing',
                text: 'You cannot rent a book listed by you.',
                icon: 'info',
                background: '#1e2a22',
                color: '#E6CFA7',
                confirmButtonColor: '#E6CFA7'
            });
            return;
        }

        if (!rentalAvailable) {
            Swal.fire({
                title: 'Rental Unavailable',
                text: 'This listing is not available for new rental requests right now.',
                icon: 'info',
                background: '#1e2a22',
                color: '#E6CFA7',
                confirmButtonColor: '#E6CFA7'
            });
            return;
        }

        if (!rentalStartDate?.value) {
            Swal.fire({
                title: 'Select Start Date',
                text: 'Choose when you want the rental to begin.',
                icon: 'warning',
                background: '#1e2a22',
                color: '#E6CFA7',
                confirmButtonColor: '#E6CFA7'
            });
            return;
        }

        const required = getRequiredBalance();
        if (currentWalletBalance < required) {
            document.getElementById('modalRequiredBalance').textContent = formatRupees(required);
            document.getElementById('modalCurrentBalance').textContent = formatRupees(currentWalletBalance);
            document.getElementById('modalShortfall').textContent = formatRupees(required - currentWalletBalance);
            document.getElementById('fund-check-modal').classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
            return;
        }

        const result = await Swal.fire({
            title: 'Send Rental Request?',
            text: `${formatRupees(required)} should remain available. Your wallet is charged only after owner confirmation.`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Send Request',
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonColor: '#E6CFA7'
        });

        if (!result.isConfirmed) return;

        try {
            const response = await fetch('/rentals/<%= rental._id %>/request', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    startDate: rentalStartDate.value,
                    durationDays: getSelectedDuration()
                })
            });
            const data = await response.json();

            if (data.success) {
                window.location.href = data.redirectUrl;
                return;
            }

            Swal.fire({
                title: 'Request Failed',
                text: data.message || 'Could not send this rental request.',
                icon: 'error',
                background: '#1e2a22',
                color: '#E6CFA7',
                confirmButtonColor: '#E6CFA7'
            });
        } catch (error) {
            Swal.fire({
                title: 'Request Failed',
                text: 'Could not send this rental request.',
                icon: 'error',
                background: '#1e2a22',
                color: '#E6CFA7',
                confirmButtonColor: '#E6CFA7'
            });
        }
    }

    function closeCheckModal() {
        document.getElementById('fund-check-modal').classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
    }

    function updateRentalImage(button, src) {
        const mainImage = document.getElementById('main-rental-image');
        if (!mainImage) return;

        mainImage.style.opacity = '0';
        setTimeout(() => {
            mainImage.src = src;
            mainImage.style.opacity = '1';
        }, 150);

        document.querySelectorAll('.rental-thumbnail-btn').forEach((thumb) => {
            thumb.classList.remove('border-apple-gold');
            thumb.classList.add('border-transparent');
        });
        button.classList.add('border-apple-gold');
        button.classList.remove('border-transparent');
    }

    function shareRental() {
        if (navigator.share) {
            navigator.share({
                title: '<%= rental.bookTitle %>',
                text: 'View this rental book on GRANTHAE',
                url: window.location.href
            });
            return;
        }
        navigator.clipboard?.writeText(window.location.href);
        showToast('success', 'Link copied');
    }

    if (rentalStartDate) {
        rentalStartDate.min = new Date().toISOString().split('T')[0];
    }

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !document.getElementById('fund-check-modal').classList.contains('hidden')) {
            closeCheckModal();
        }
    });

    rentalDuration?.addEventListener('input', updateRentalTotals);
    updateRentalTotals();

    const rentalReviewForm = document.getElementById('rentalReviewForm');
    rentalReviewForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = Object.fromEntries(new FormData(rentalReviewForm).entries());

        try {
            const response = await fetch('/rental/<%= rental._id %>/reviews', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });
            const data = await response.json();

            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Review Submitted',
                    text: data.message,
                    background: '#1e2a22',
                    color: '#E6CFA7',
                    confirmButtonColor: '#E6CFA7'
                }).then(() => window.location.reload());
                return;
            }

            Swal.fire({ icon: 'error', title: 'Review Failed', text: data.message || 'Could not submit review.' });
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Review Failed', text: 'Could not submit review.' });
        }
    });
</script>
