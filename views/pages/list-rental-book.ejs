<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-apple-dark font-serif">List a Book for Rental</h1>
            <p class="text-apple-text-gray mt-2">Share your library with others and earn from your collection.</p>
        </div>
        <a href="/home" class="px-4 py-2 border border-white/10 rounded-lg text-sm text-apple-text-gray hover:text-white hover:bg-white/5 transition-colors">
            Cancel
        </a>
    </div>

    <form id="rentalListingForm" class="space-y-8">
        <!-- 1. Book Details -->
        <div class="bg-apple-card/50 backdrop-blur-md border border-white/10 rounded-3xl p-8 shadow-xl">
            <h3 class="text-xl font-bold text-apple-dark mb-6 flex items-center gap-2">
                <i data-lucide="book" class="w-5 h-5 text-apple-blue"></i>
                1. Book Details
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-apple-text-gray mb-1">Book Title <span class="text-red-500">*</span></label>
                        <input type="text" id="bookTitle" name="bookTitle" placeholder="Enter full book title" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                        <span id="bookTitleError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-text-gray mb-1">Author <span class="text-red-500">*</span></label>
                        <input type="text" id="author" name="author" placeholder="Author name" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                        <span id="authorError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-text-gray mb-1">ISBN <span class="text-apple-text-gray/50 text-xs font-normal ml-1">(Optional)</span></label>
                        <input type="text" id="isbn" name="isbn" placeholder="10 or 13 digit ISBN" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                        <span id="isbnError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-text-gray mb-1">Category / Genre <span class="text-red-500">*</span></label>
                        <select id="category" name="category" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                            <option value="" class="bg-apple-card">Select Category...</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat._id %>" class="bg-apple-card"><%= cat.name %></option>
                            <% }) %>
                        </select>
                        <span id="categoryError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-apple-text-gray mb-1">Description <span class="text-red-500">*</span></label>
                    <textarea id="description" name="description" rows="9" placeholder="Describe the book content, edition, and any interesting facts..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all h-[245px] resize-none"></textarea>
                    <span id="descriptionError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                </div>
            </div>
        </div>

        <!-- 2. Rental Settings -->
        <div class="bg-apple-card/50 backdrop-blur-md border border-white/10 rounded-3xl p-8 shadow-xl">
            <h3 class="text-xl font-bold text-apple-dark mb-6 flex items-center gap-2">
                <i data-lucide="settings" class="w-5 h-5 text-apple-blue"></i>
                2. Rental Settings
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div>
                    <label class="block text-sm font-medium text-apple-text-gray mb-1">Daily Rate (₹) <span class="text-red-500">*</span></label>
                    <input type="number" id="dailyRate" name="dailyRate" min="0" step="1" placeholder="0" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                    <span id="dailyRateError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-apple-text-gray mb-1">Condition <span class="text-red-500">*</span></label>
                    <select id="bookCondition" name="bookCondition" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                        <option value="" class="bg-apple-card">Select Condition...</option>
                        <option value="New" class="bg-apple-card">New (Unread)</option>
                        <option value="Fine" class="bg-apple-card">Fine (As new)</option>
                        <option value="Very Good" class="bg-apple-card">Very Good</option>
                        <option value="Good" class="bg-apple-card">Good</option>
                        <option value="Fair" class="bg-apple-card">Fair (Worn)</option>
                        <option value="Poor" class="bg-apple-card">Poor</option>
                    </select>
                    <span id="bookConditionError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-apple-text-gray mb-1">Min Rental (Days) <span class="text-red-500">*</span></label>
                    <input type="number" id="minRentalDays" name="minRentalDays" min="1" placeholder="1" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                    <span id="minRentalDaysError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-apple-text-gray mb-1">Deposit Amount (₹) <span class="text-red-500">*</span></label>
                    <input type="number" id="depositAmount" name="depositAmount" min="0" step="1" placeholder="0" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:border-apple-blue/50 transition-all">
                    <span id="depositAmountError" class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                </div>
            </div>
        </div>

        <!-- 3. Images -->
        <div class="bg-apple-card/50 backdrop-blur-md border border-white/10 rounded-3xl p-8 shadow-xl">
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
                <div>
                    <h3 class="text-xl font-bold text-apple-dark flex items-center gap-2">
                        <i data-lucide="image" class="w-5 h-5 text-apple-blue"></i>
                        3. Images
                    </h3>
                    <p class="text-xs text-apple-text-gray mt-1">Upload at least 3 high-quality images of the book. Star the best one for the cover.</p>
                </div>
                
                <label class="inline-flex items-center gap-2 px-6 py-3 bg-apple-blue text-white rounded-xl cursor-pointer hover:bg-apple-blue/90 transition-all shadow-lg shadow-apple-blue/20 group">
                    <i data-lucide="plus" class="w-5 h-5 group-hover:rotate-90 transition-transform"></i>
                    <span class="font-bold">Add Images</span>
                    <input type="file" id="imageInput" accept="image/jpeg, image/png, image/webp" class="hidden">
                </label>
            </div>

            <!-- Gallery Grid -->
            <div id="imageGallery" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                <!-- Empty state placeholder -->
                <div id="emptyGallery" class="col-span-full py-12 flex items-center justify-center border-2 border-dashed border-white/10 rounded-2xl text-apple-text-gray/50">
                    <i data-lucide="upload-cloud" class="w-12 h-12 mb-2"></i>
                    <br>
                    <p>No images uploaded yet</p>
                </div>
            </div>
            <span id="galleryError" class="error-msg text-red-500 text-xs mt-4 block hidden text-center"></span>
        </div>

        <div class="flex flex-col items-center gap-4 pt-4">
            <button type="submit" id="submitBtn" class="w-full md:w-auto px-12 py-4 bg-apple-blue text-white rounded-2xl font-bold text-lg hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-apple-blue/20 flex items-center justify-center gap-3">
                <i data-lucide="send" class="w-5 h-5"></i>
                Request to Publish
            </button>
            <p class="text-xs text-apple-text-gray text-center max-w-md">By publishing, you agree to our Terms of Service for rental listings. Your request will be reviewed by our team within 24-48 hours.</p>
        </div>
    </form>
</div>

<!-- Cropper Modal (Reused from admin) -->
<div id="cropperModal" class="hidden fixed inset-0 bg-black/90 backdrop-blur-md z-[100] flex items-center justify-center p-4">
    <div class="bg-apple-card border border-white/10 rounded-3xl w-full max-w-2xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
        <div class="p-6 border-b border-white/10 flex justify-between items-center">
            <h3 class="font-bold text-xl text-apple-dark">Adjust Image</h3>
            <button id="closeCropperBtn" type="button" class="p-2 text-apple-text-gray hover:text-apple-dark transition-colors rounded-full hover:bg-white/5">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>
        
        <div class="p-4 bg-black/20 flex-1 overflow-hidden min-h-[400px] flex items-center justify-center">
            <img id="cropperImage" class="max-w-full max-h-full block">
        </div>
        
        <div class="p-6 border-t border-white/10 flex justify-end gap-3">
            <button type="button" id="cancelCropBtn" class="px-6 py-2.5 font-bold text-apple-text-gray hover:text-apple-dark transition-colors">Cancel</button>
            <button type="button" id="confirmCropBtn" class="px-8 py-2.5 bg-apple-blue text-white rounded-xl font-bold hover:bg-apple-blue/90 transition-all">Crop & Apply</button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">

<script>
    let cropper;
    const croppedImagesBlobs = []; 
    let coverImageIndex = 0;

    const imageInput = document.getElementById('imageInput');
    const cropperModal = document.getElementById('cropperModal');
    const cropperImage = document.getElementById('cropperImage');
    const closeCropperBtn = document.getElementById('closeCropperBtn');
    const cancelCropBtn = document.getElementById('cancelCropBtn');
    const confirmCropBtn = document.getElementById('confirmCropBtn');
    const imageGallery = document.getElementById('imageGallery');
    const emptyGallery = document.getElementById('emptyGallery');
    const form = document.getElementById('rentalListingForm');
    const submitBtn = document.getElementById('submitBtn');

    function resetCropper() {
        if(cropper) {
            cropper.destroy();
            cropper = null;
        }
        imageInput.value = '';
        cropperModal.classList.add('hidden');
    }

    [closeCropperBtn, cancelCropBtn].forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            resetCropper();
        });
    });

    imageInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if(!file) return;

        const url = URL.createObjectURL(file);
        cropperImage.src = url;
        cropperModal.classList.remove('hidden');

        if(cropper) cropper.destroy();

        cropper = new Cropper(cropperImage, {
            aspectRatio: 3/4, // Book ratio
            viewMode: 2,
            background: false,
            autoCropArea: 0.9,
            zoomable: true
        });
    });

    confirmCropBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if(!cropper) return;

        cropper.getCroppedCanvas({
            width: 900,
            height: 1200,
            imageSmoothingEnabled: true,
            imageSmoothingQuality: 'high'
        }).toBlob((blob) => {
            blob.name = `rental-${Date.now()}.webp`; 
            croppedImagesBlobs.push(blob);
            if(croppedImagesBlobs.length === 1) coverImageIndex = 0;
            updateGallery();
            resetCropper();
        }, 'image/webp', 0.8);
    });

    window.setCover = (index) => {
        coverImageIndex = index;
        updateGallery();
    };

    function updateGallery() {
        if (croppedImagesBlobs.length > 0) {
            emptyGallery.classList.add('hidden');
        } else {
            emptyGallery.classList.remove('hidden');
        }

        // Keep the placeholder if empty, but clear actual images
        const existingItems = imageGallery.querySelectorAll('.gallery-item');
        existingItems.forEach(item => item.remove());
        
        croppedImagesBlobs.forEach((blob, index) => {
            const url = URL.createObjectURL(blob);
            const div = document.createElement('div');
            div.className = 'gallery-item relative group aspect-[3/4] rounded-2xl overflow-hidden shadow-lg border-2 ' + 
                            (coverImageIndex === index ? 'border-apple-blue bg-apple-blue/5' : 'border-white/10 bg-white/5');
            
            div.innerHTML = `
                <img src="${url}" class="w-full h-full object-cover">
                <button type="button" onclick="setCover(${index})" title="Set as Cover" class="absolute top-3 left-3 w-8 h-8 rounded-full ${coverImageIndex === index ? 'bg-apple-blue text-white' : 'bg-black/40 text-white hover:bg-apple-blue'} flex items-center justify-center shadow-lg transition-all z-20">
                    <i data-lucide="star" class="w-4 h-4 ${coverImageIndex === index ? 'fill-current' : ''}"></i>
                </button>
                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center p-4">
                    <button type="button" onclick="removeImage(${index})" class="w-10 h-10 rounded-full bg-red-500 hover:bg-red-600 text-white flex items-center justify-center shadow-lg transition-transform hover:scale-110">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                    </button>
                </div>
            `;
            imageGallery.appendChild(div);
        });
        if(typeof lucide !== 'undefined') lucide.createIcons();
        
        if (croppedImagesBlobs.length >= 3) {
            document.getElementById('galleryError').classList.add('hidden');
        }
    }

    window.removeImage = (index) => {
        croppedImagesBlobs.splice(index, 1);
        if(coverImageIndex === index) coverImageIndex = 0;
        else if (coverImageIndex > index) coverImageIndex--;
        updateGallery();
    };

    // Validation
    async function validateForm() {
        const errors = {};
        const requiredFields = ['bookTitle', 'author', 'category', 'description', 'dailyRate', 'bookCondition', 'minRentalDays', 'depositAmount'];
        
        requiredFields.forEach(field => {
            const el = document.getElementById(field);
            const errorEl = document.getElementById(field + 'Error');
            errorEl.classList.add('hidden');
            el.classList.remove('border-red-500');

            if (!el.value.trim()) {
                errors[field] = 'This field is required.';
            }
        });

        const numericFields = ['dailyRate', 'minRentalDays', 'depositAmount'];
        numericFields.forEach(field => {
            const el = document.getElementById(field);
            if (el.value !== '' && parseFloat(el.value) < 0) {
                errors[field] = 'Value cannot be negative.';
            }
        });

        if (croppedImagesBlobs.length < 3) {
            errors.gallery = 'Minimum 3 images of the book are required.';
        }

        // Display errors
        for (const [key, msg] of Object.entries(errors)) {
            const errorEl = document.getElementById(key + 'Error');
            if (errorEl) {
                errorEl.textContent = msg;
                errorEl.classList.remove('hidden');
                document.getElementById(key).classList.add('border-red-500');
            }
        }

        if (Object.keys(errors).length > 0) {
            if (errors.gallery) {
                Swal.fire({ icon: 'warning', title: 'Images Required', text: errors.gallery, background: '#1e2a22', color: '#E6CFA7' });
            } else {
                Swal.fire({ icon: 'warning', title: 'Check Fields', text: 'Please fill all required fields correctly.', background: '#1e2a22', color: '#E6CFA7' });
            }
            return false;
        }
        return true;
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const isValid = await validateForm();
        if (!isValid) return;

        const formData = new FormData();
        formData.append('bookTitle', document.getElementById('bookTitle').value);
        formData.append('author', document.getElementById('author').value);
        formData.append('isbn', document.getElementById('isbn').value);
        formData.append('category', document.getElementById('category').value);
        formData.append('description', document.getElementById('description').value);
        formData.append('dailyRate', document.getElementById('dailyRate').value);
        formData.append('bookCondition', document.getElementById('bookCondition').value);
        formData.append('minRentalDays', document.getElementById('minRentalDays').value);
        formData.append('depositAmount', document.getElementById('depositAmount').value);
        formData.append('coverImageIndex', coverImageIndex);

        croppedImagesBlobs.forEach((blob) => {
            formData.append('images', blob, blob.name);
        });

        const origText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i data-lucide="loader" class="w-5 h-5 animate-spin"></i> Submitting...';
        submitBtn.disabled = true;

        try {
            const res = await fetch('/list-rental-book', {
                method: 'POST',
                body: formData
            });
            
            const data = await res.json();
            if(data.success) {
                Swal.fire({ 
                    icon: 'success', 
                    title: 'Submitted!', 
                    text: data.message, 
                    background: '#1e2a22', 
                    color: '#E6CFA7',
                    confirmButtonColor: '#007AFF'
                }).then(() => {
                    window.location.href = data.redirectUrl || '/home';
                });
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: data.message, background: '#1e2a22', color: '#E6CFA7' });
                submitBtn.innerHTML = origText;
                submitBtn.disabled = false;
                if(typeof lucide !== 'undefined') lucide.createIcons();
            }
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Please try again.', background: '#1e2a22', color: '#E6CFA7' });
            submitBtn.innerHTML = origText;
            submitBtn.disabled = false;
            if(typeof lucide !== 'undefined') lucide.createIcons();
        }
    });
</script>
