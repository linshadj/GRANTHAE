<%
    const rental = rentalOrder.rental || {};
    const imageSrc = rental.coverImage || (Array.isArray(rental.images) && rental.images[0]) || '/images/default-book.jpg';
    const formatDate = (date) => new Date(date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 });
%>

<div class="max-w-3xl mx-auto space-y-8 py-4">
    <div>
        <a href="/profile/rentals" class="text-[10px] font-bold text-apple-text-gray/60 hover:text-apple-blue flex items-center gap-2 mb-4 uppercase tracking-widest transition-colors">
            <i data-lucide="arrow-left" class="w-3 h-3"></i>
            Back to Rentals
        </a>
        <h1 class="text-3xl font-bold text-apple-dark font-serif">Return Rental</h1>
        <p class="text-apple-text-gray mt-2">Rental #<%= rentalOrder.rentalCode %> &bull; Due by <%= formatDate(rentalOrder.endDate) %></p>
    </div>

    <form id="rentalReturnForm" class="space-y-8">
        <div class="glass-card flex gap-6 p-6 items-center">
            <img src="<%= imageSrc %>" alt="<%= rental.bookTitle %>" class="w-20 h-28 object-cover rounded-lg shadow-sm bg-gray-200">
            <div>
                <h3 class="text-xl font-bold text-apple-dark"><%= rental.bookTitle %></h3>
                <p class="text-apple-text-gray mb-1"><%= rental.author %></p>
                <div class="flex items-center gap-2 mt-2">
                    <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-600 border border-green-500/20">Active Rental</span>
                    <span class="text-xs text-orange-500 font-medium">Deposit: &#8377;<%= formatAmount(rentalOrder.depositAmount) %></span>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 space-y-6">
            <h3 class="font-semibold text-apple-dark">Return Details</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Book Condition</label>
                    <select name="returnCondition" required
                        class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-apple-dark focus:ring-2 focus:ring-apple-blue/20 outline-none">
                        <option value="">Select condition</option>
                        <option value="Excellent">Excellent (same as received)</option>
                        <option value="Good">Good (minor wear)</option>
                        <option value="Fair">Fair (visible wear)</option>
                        <option value="Damaged">Damaged</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Return Method</label>
                    <div class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-apple-text-gray">
                        Ship via courier partner
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-apple-dark mb-2">Courier Tracking ID</label>
                <input type="text" name="returnTrackingId" placeholder="e.g. TRK-99002211" required
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-apple-dark focus:ring-2 focus:ring-apple-blue/20 outline-none transition-all">
                <p class="text-xs text-apple-text-gray mt-2">Share the courier tracking ID so the owner can confirm receipt.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-apple-dark mb-2">Comments</label>
                <textarea name="returnComments" rows="3"
                    class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-apple-dark focus:ring-2 focus:ring-apple-blue/20 outline-none resize-none"
                    placeholder="Any notes for the owner?"></textarea>
            </div>
        </div>

        <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 flex-shrink-0">
                <i data-lucide="shield-check" class="w-5 h-5"></i>
            </div>
            <div>
                <h4 class="font-bold text-apple-dark text-sm mb-1">Security Deposit Refund</h4>
                <p class="text-xs text-apple-text-gray">
                    Your security deposit of <span class="font-bold text-apple-dark">&#8377;<%= formatAmount(rentalOrder.depositAmount) %></span>
                    will be refunded to your wallet after the owner confirms the return.
                </p>
            </div>
        </div>

        <div class="flex gap-4">
            <a href="/profile/rentals"
                class="flex-1 px-6 py-3 rounded-xl border border-white/10 text-apple-dark font-medium hover:bg-white/5 transition-colors text-center">
                Cancel
            </a>
            <button type="submit" id="returnSubmitBtn" class="flex-1 btn-primary py-3 shadow-lg shadow-apple-blue/20">
                Confirm Return
            </button>
        </div>
    </form>
</div>

<script>
    const rentalReturnForm = document.getElementById('rentalReturnForm');
    const returnSubmitBtn = document.getElementById('returnSubmitBtn');

    rentalReturnForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const originalText = returnSubmitBtn.innerHTML;
        returnSubmitBtn.disabled = true;
        returnSubmitBtn.innerHTML = 'Submitting...';

        try {
            const formData = Object.fromEntries(new FormData(rentalReturnForm).entries());
            const response = await fetch('/profile/rentals/<%= rentalOrder._id %>/return', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });
            const data = await response.json();

            if (data.success) {
                window.location.href = data.redirectUrl;
                return;
            }

            Swal.fire({ icon: 'error', title: 'Return Failed', text: data.message || 'Could not submit return.' });
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Return Failed', text: 'Could not submit return.' });
        } finally {
            returnSubmitBtn.disabled = false;
            returnSubmitBtn.innerHTML = originalText;
        }
    });
</script>
