<div class="space-y-6">
    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Pending</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2 font-serif">12</h3>
                </div>
                <div class="p-3 bg-yellow-500/10 rounded-xl text-apple-gold">
                    <i data-lucide="clock" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
        <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Approved Today</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2 font-serif">45</h3>
                </div>
                <div class="p-3 bg-green-500/10 rounded-xl text-green-500">
                    <i data-lucide="check-circle" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
        <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Rejected</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2 font-serif">3</h3>
                </div>
                <div class="p-3 bg-red-500/10 rounded-xl text-red-500">
                    <i data-lucide="x-circle" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Requests Table -->
    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Incoming Requests</h3>
            <div class="flex gap-2">
                <button
                    class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5">
                    Filter: All
                </button>
                <div class="relative">
                    <i data-lucide="search"
                        class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray"></i>
                    <input type="text" placeholder="Search ISBN..."
                        class="pl-9 pr-4 py-2 text-xs bg-white/5 border border-white/5 rounded-lg focus:outline-none focus:ring-2 focus:ring-apple-gold/50 text-apple-dark placeholder-apple-text-gray/50">
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full whitespace-nowrap">
                <thead class="bg-white/5">
                    <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                        <th class="px-6 py-4">Book Details</th>
                        <th class="px-6 py-4">User</th>
                        <th class="px-6 py-4">Submitted</th>
                        <th class="px-6 py-4">Condition</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <!-- Row 1 -->
                    <tr class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <img src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=800"
                                    class="w-12 h-16 object-cover rounded shadow-sm opacity-90 group-hover:opacity-100"
                                    alt="Book">
                                <div>
                                    <div class="font-bold text-apple-dark">The Midnight Library</div>
                                    <div class="text-xs text-apple-text-gray">Matt Haig • Fiction</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <div
                                    class="w-6 h-6 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center text-[10px] font-bold">
                                    SJ</div>
                                <span class="text-sm font-medium text-apple-text-gray">Sarah Jenkins</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-apple-text-gray">2 mins ago</td>
                        <td class="px-6 py-4">
                            <span
                                class="px-2 py-1 text-xs font-bold text-green-400 bg-green-500/10 rounded-lg">New</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                                <button
                                    class="px-3 py-1.5 bg-apple-gold text-[#1a231e] text-xs font-bold rounded-lg shadow hover:brightness-110 transition-all">Approve</button>
                                <button
                                    class="px-3 py-1.5 border border-white/10 text-apple-text-gray text-xs font-bold rounded-lg hover:bg-red-500/10 hover:text-red-400 hover:border-red-500/20 transition-all">Reject</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 2 -->
                    <tr class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <img src="https://images.unsplash.com/photo-1592496431122-2349e0fbc666?auto=format&fit=crop&q=80&w=800"
                                    class="w-12 h-16 object-cover rounded shadow-sm opacity-90 group-hover:opacity-100"
                                    alt="Book">
                                <div>
                                    <div class="font-bold text-apple-dark">Atomic Habits</div>
                                    <div class="text-xs text-apple-text-gray">James Clear • Self Help</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <div
                                    class="w-6 h-6 rounded-full bg-purple-500/20 text-purple-400 flex items-center justify-center text-[10px] font-bold">
                                    MK</div>
                                <span class="text-sm font-medium text-apple-text-gray">Mike K.</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-apple-text-gray">1 hour ago</td>
                        <td class="px-6 py-4">
                            <span
                                class="px-2 py-1 text-xs font-bold text-yellow-400 bg-yellow-500/10 rounded-lg">Good</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                                <button
                                    class="px-3 py-1.5 bg-apple-gold text-[#1a231e] text-xs font-bold rounded-lg shadow hover:brightness-110 transition-all">Approve</button>
                                <button
                                    class="px-3 py-1.5 border border-white/10 text-apple-text-gray text-xs font-bold rounded-lg hover:bg-red-500/10 hover:text-red-400 hover:border-red-500/20 transition-all">Reject</button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>