<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">Edit Coupon</h1>
            <p class="text-apple-text-gray/80 text-sm">Manage discount code details.</p>
        </div>
        <div class="flex gap-3">
            <a href="/admin/coupons"
                class="px-4 py-2 text-sm font-medium text-apple-text-gray hover:text-apple-dark hover:bg-gray-100 rounded-lg transition-colors">Cancel</a>
            <button class="btn-primary flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i> Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Form -->
        <div class="lg:col-span-2 space-y-6">
            <div class="glass-card p-6 space-y-6">
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Coupon Code</label>
                        <input type="text" value="WELCOME20"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all uppercase font-mono tracking-wider">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Discount Type</label>
                        <select
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                            <option value="percentage">Percentage (%)</option>
                            <option value="fixed">Fixed Amount ($)</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Discount Value</label>
                    <input type="number" value="20"
                        class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Min Purchase Amount ($)</label>
                        <input type="number" value="0"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Max Discount ($)</label>
                        <input type="number" value="0"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Start Date</label>
                        <input type="date" value="2026-01-01"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Expiry Date</label>
                        <input type="date" value="2026-12-31"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
            <div class="glass-card p-6 space-y-4">
                <h3 class="font-semibold text-apple-dark">Usage Limits</h3>

                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Usage Limit Per Coupon</label>
                    <input type="number" value="1000"
                        class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Usage Limit Per User</label>
                    <input type="number" value="1"
                        class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                </div>
            </div>
        </div>
    </div>
</div>