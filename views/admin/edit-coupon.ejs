<%
    const isEdit = mode === 'edit';
    const data = coupon || {};
    const dateValue = (date, fallback = '') => date ? new Date(date).toISOString().slice(0, 10) : fallback;
    const today = new Date().toISOString().slice(0, 10);
    const defaultExpiry = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
%>

<div class="max-w-4xl mx-auto space-y-8 pb-12">
    <div class="flex items-center justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-apple-dark"><%= isEdit ? 'Edit Coupon' : 'Add Coupon' %></h2>
            <p class="text-apple-text-gray text-sm mt-1">Configure coupon codes, redemption windows, and usage limits.</p>
        </div>
        <a href="/admin/coupons" class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-apple-text-gray hover:text-white transition-all text-sm flex items-center gap-2">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to List
        </a>
    </div>

    <form id="couponForm" class="space-y-8">
        <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden p-6 space-y-6">
            <div class="flex items-center gap-3 border-b border-white/5 pb-4">
                <div class="p-2 bg-blue-500/10 rounded-lg">
                    <i data-lucide="ticket" class="w-5 h-5 text-blue-400"></i>
                </div>
                <h3 class="font-bold text-lg text-apple-dark">Coupon Details</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Coupon Code</label>
                    <input type="text" id="code" name="code" value="<%= data.code || '' %>" placeholder="WELCOME10"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark uppercase font-mono tracking-wider focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <span id="codeError" class="error-msg text-red-500 text-[10px] mt-1 hidden"></span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Discount Type</label>
                    <select id="discountType" name="discountType" class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                        <option value="percentage" <%= data.discountType !== 'fixed' ? 'selected' : '' %>>Percentage</option>
                        <option value="fixed" <%= data.discountType === 'fixed' ? 'selected' : '' %>>Fixed Amount</option>
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="Short internal note for this coupon"
                    class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all resize-none"><%= data.description || '' %></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Discount Value</label>
                    <input type="number" id="discountValue" name="discountValue" min="0" step="0.01" value="<%= data.discountValue || '' %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <span id="discountValueError" class="error-msg text-red-500 text-[10px] mt-1 hidden"></span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Minimum Order</label>
                    <input type="number" id="minPurchaseAmount" name="minPurchaseAmount" min="0" step="0.01" value="<%= data.minPurchaseAmount || 0 %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                </div>
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Max Discount</label>
                    <input type="number" id="maxDiscountAmount" name="maxDiscountAmount" min="0" step="0.01" value="<%= data.maxDiscountAmount || 0 %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <p class="text-[10px] text-apple-text-gray/60 mt-1">Use 0 for no cap.</p>
                </div>
            </div>
        </div>

        <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden p-6 space-y-6">
            <div class="flex items-center gap-3 border-b border-white/5 pb-4">
                <div class="p-2 bg-green-500/10 rounded-lg">
                    <i data-lucide="settings-2" class="w-5 h-5 text-green-400"></i>
                </div>
                <h3 class="font-bold text-lg text-apple-dark">Availability & Limits</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Start Date</label>
                    <input type="date" id="startDate" name="startDate" value="<%= dateValue(data.startDate, today) %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <span id="startDateError" class="error-msg text-red-500 text-[10px] mt-1 hidden"></span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Expiry Date</label>
                    <input type="date" id="expiresAt" name="expiresAt" value="<%= dateValue(data.expiresAt, defaultExpiry) %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <span id="expiresAtError" class="error-msg text-red-500 text-[10px] mt-1 hidden"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Total Usage Limit</label>
                    <input type="number" id="usageLimit" name="usageLimit" min="0" step="1" value="<%= data.usageLimit || 0 %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <p class="text-[10px] text-apple-text-gray/60 mt-1">Use 0 for unlimited total redemptions.</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-widest mb-2">Usage Limit Per User</label>
                    <input type="number" id="usageLimitPerUser" name="usageLimitPerUser" min="0" step="1" value="<%= data.usageLimitPerUser ?? 1 %>"
                        class="w-full bg-white/5 border border-white/5 rounded-xl px-4 py-3 text-apple-dark focus:outline-none focus:ring-1 focus:ring-apple-gold/50 transition-all">
                    <p class="text-[10px] text-apple-text-gray/60 mt-1">Use 0 for unlimited per-user redemptions.</p>
                </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-white/5 border border-white/5 rounded-xl">
                <div>
                    <p class="text-sm font-bold text-apple-dark">Active Status</p>
                    <p class="text-[10px] text-apple-text-gray">Inactive coupons cannot be redeemed.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="isActive" <%= data.isActive === false ? '' : 'checked' %> class="sr-only peer">
                    <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-apple-text-gray after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500 peer-checked:after:bg-white"></div>
                </label>
            </div>
        </div>

        <div class="flex justify-end gap-3 pt-6 border-t border-white/5">
            <a href="/admin/coupons" class="px-6 py-2.5 rounded-xl border border-white/5 text-apple-text-gray font-bold text-sm hover:bg-white/5 transition-all">
                Discard
            </a>
            <button type="submit" id="couponSubmitBtn" class="px-8 py-2.5 rounded-xl bg-apple-gold text-[#1a231e] font-bold text-sm hover:bg-yellow-600 transition-all shadow-lg shadow-apple-gold/20 flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i>
                <%= isEdit ? 'Update Coupon' : 'Save Coupon' %>
            </button>
        </div>
    </form>
</div>

<script>
    const form = document.getElementById('couponForm');
    const submitBtn = document.getElementById('couponSubmitBtn');
    const codeInput = document.getElementById('code');

    codeInput.addEventListener('input', () => {
        codeInput.value = codeInput.value.toUpperCase().replace(/\s+/g, '');
    });

    function setError(id, message) {
        const errorEl = document.getElementById(`${id}Error`);
        const inputEl = document.getElementById(id);
        if (errorEl) {
            errorEl.textContent = message;
            errorEl.classList.toggle('hidden', !message);
        }
        if (inputEl) inputEl.classList.toggle('border-red-500', Boolean(message));
    }

    function validateForm() {
        let isValid = true;
        document.querySelectorAll('.error-msg').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('input, textarea, select').forEach(el => el.classList.remove('border-red-500'));

        const required = ['code', 'discountValue', 'startDate', 'expiresAt'];
        required.forEach(id => {
            if (!document.getElementById(id).value.trim()) {
                setError(id, 'This field is required.');
                isValid = false;
            }
        });

        const discountType = document.getElementById('discountType').value;
        const discountValue = Number(document.getElementById('discountValue').value);
        if (discountValue <= 0) {
            setError('discountValue', 'Discount value must be greater than zero.');
            isValid = false;
        } else if (discountType === 'percentage' && discountValue > 100) {
            setError('discountValue', 'Percentage discount cannot exceed 100%.');
            isValid = false;
        }

        const startDate = document.getElementById('startDate').value;
        const expiresAt = document.getElementById('expiresAt').value;
        if (startDate && expiresAt && new Date(expiresAt) < new Date(startDate)) {
            setError('expiresAt', 'Expiry date cannot be before start date.');
            isValid = false;
        }

        return isValid;
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!validateForm()) {
            Swal.fire({ icon: 'error', title: 'Validation Failed', text: 'Please check the highlighted fields.', background: '#1e2a22', color: '#E6CFA7' });
            return;
        }

        const payload = {
            code: document.getElementById('code').value.trim(),
            description: document.getElementById('description').value.trim(),
            discountType: document.getElementById('discountType').value,
            discountValue: Number(document.getElementById('discountValue').value),
            minPurchaseAmount: Number(document.getElementById('minPurchaseAmount').value || 0),
            maxDiscountAmount: Number(document.getElementById('maxDiscountAmount').value || 0),
            usageLimit: Number(document.getElementById('usageLimit').value || 0),
            usageLimitPerUser: Number(document.getElementById('usageLimitPerUser').value || 0),
            startDate: document.getElementById('startDate').value,
            expiresAt: document.getElementById('expiresAt').value,
            isActive: document.getElementById('isActive').checked
        };

        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i data-lucide="loader" class="w-4 h-4 animate-spin"></i> Saving...';
        submitBtn.disabled = true;

        try {
            const res = await fetch('<%= isEdit ? `/admin/coupons/edit/${data._id}` : '/admin/coupons/add' %>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await res.json();
            if (result.success) {
                Swal.fire({ icon: 'success', title: 'Saved', text: result.message, background: '#1e2a22', color: '#E6CFA7' }).then(() => {
                    window.location.href = result.redirectUrl || '/admin/coupons';
                });
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: result.message, background: '#1e2a22', color: '#E6CFA7' });
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
                lucide.createIcons();
            }
        } catch (error) {
            Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong', background: '#1e2a22', color: '#E6CFA7' });
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
            lucide.createIcons();
        }
    });
</script>
