<%
    const encodedSearchQuery = encodeURIComponent(searchQuery || '');
    const encodedSelectedSort = encodeURIComponent(selectedSort || 'newest');
    const encodedSelectedFilter = encodeURIComponent(typeof selectedFilter !== 'undefined' ? selectedFilter : 'all');
%>
<div class="space-y-8">
    <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-white font-serif">Inventory management</h2>
        <div class="flex gap-2">
            <a href="/admin/products/add" class="flex items-center gap-2 px-4 py-2 bg-apple-gold text-[#1a231e] rounded-lg hover:bg-yellow-600 transition-all font-bold text-sm shadow-lg shadow-apple-gold/20">
                <i data-lucide="plus" class="w-4 h-4"></i>
                Add New Product
            </a>
        </div>
    </div>

    <!-- Inventory Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-apple-card rounded-2xl border border-white/5 p-6 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-500">
                <i data-lucide="package" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-apple-text-gray uppercase tracking-wider">Total Products</p>
                <p class="text-2xl font-bold text-white"><%= totalProducts %></p>
            </div>
        </div>
        <div class="bg-apple-card rounded-2xl border border-white/5 p-6 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-apple-text-gray uppercase tracking-wider">Low Stock</p>
                <p class="text-2xl font-bold text-white"><%= totalLowStock %></p>
            </div>
        </div>
        <div class="bg-apple-card rounded-2xl border border-white/5 p-6 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500">
                <i data-lucide="check-circle" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-apple-text-gray uppercase tracking-wider">In Stock</p>
                <p class="text-2xl font-bold text-white"><%= totalInStock %></p>
            </div>
        </div>
    </div>

    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col lg:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Stock Levels</h3>
            
            <div class="flex flex-wrap items-center justify-center sm:justify-end gap-3 w-full sm:w-auto">

                <!-- Search -->
                <div class="relative items-center flex w-full sm:w-auto">
                    <i data-lucide="search" class="absolute left-3 w-4 h-4 text-apple-text-gray"></i>
                    <input id="inventorySearch" type="text" value="<%= searchQuery || '' %>"
                        placeholder="Search products..."
                        class="pl-10 pr-4 py-2.5 h-10 w-full sm:w-64 text-sm bg-white/5 border border-white/5 rounded-xl focus:outline-none focus:ring-2 focus:ring-apple-gold/50 text-white placeholder-apple-text-gray transition-all">
                </div>


                <!-- Filter Dropdown -->
                <div class="relative" id="invFilterWrap">
                    <button onclick="document.getElementById('invFilterMenu').classList.toggle('hidden')" class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5 h-10 min-w-max whitespace-nowrap">
                        <i data-lucide="filter" class="w-3.5 h-3.5"></i>
                        <span id="invFilterLabel">
                            <% const filterLabels = { 'all': 'All', 'in-stock': 'In Stock', 'low-stock': 'Low Stock', 'out-of-stock': 'Out of Stock' }; %>
                            <%= typeof selectedFilter !== 'undefined' ? filterLabels[selectedFilter] || 'Filter By' : 'Filter By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="invFilterMenu" class="hidden absolute right-0 mt-2 w-48 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/inventory?page=1&sort=<%= encodedSelectedSort %>&search=<%= encodedSearchQuery %>&filter=all" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="layers" class="w-3.5 h-3.5"></i> All
                        </a>
                        <a href="/admin/inventory?page=1&sort=<%= encodedSelectedSort %>&search=<%= encodedSearchQuery %>&filter=in-stock" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="check-circle" class="w-3.5 h-3.5 text-green-400"></i> In Stock
                        </a>
                        <a href="/admin/inventory?page=1&sort=<%= encodedSelectedSort %>&search=<%= encodedSearchQuery %>&filter=low-stock" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="alert-triangle" class="w-3.5 h-3.5 text-yellow-400"></i> Low Stock
                        </a>
                        <a href="/admin/inventory?page=1&sort=<%= encodedSelectedSort %>&search=<%= encodedSearchQuery %>&filter=out-of-stock" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="x-circle" class="w-3.5 h-3.5 text-red-400"></i> Out of Stock
                        </a>
                    </div>
                </div>

                <!-- Sort Dropdown -->
                <div class="relative" id="invSortWrap">
                    <button onclick="document.getElementById('invSortMenu').classList.toggle('hidden')" class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5 h-10 min-w-max whitespace-nowrap">
                        <i data-lucide="arrow-up-down" class="w-3.5 h-3.5"></i>
                        <span id="invSortLabel">
                            <% const sortLabels = { 'newest': 'Newest First', 'stock-low': 'Stock: Low to High', 'stock-high': 'Stock: High to Low' }; %>
                            <%= sortLabels[selectedSort] || 'Sort By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="invSortMenu" class="hidden absolute right-0 mt-2 w-48 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/inventory?page=<%= currentPage %>&search=<%= encodedSearchQuery %>&filter=<%= encodedSelectedFilter %>&sort=newest" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="calendar-clock" class="w-3.5 h-3.5"></i> Newest First
                        </a>
                        <a href="/admin/inventory?page=<%= currentPage %>&search=<%= encodedSearchQuery %>&filter=<%= encodedSelectedFilter %>&sort=stock-low" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="arrow-down" class="w-3.5 h-3.5"></i> Stock: Low to High
                        </a>
                        <a href="/admin/inventory?page=<%= currentPage %>&search=<%= encodedSearchQuery %>&filter=<%= encodedSelectedFilter %>&sort=stock-high" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="arrow-up" class="w-3.5 h-3.5"></i> Stock: High to Low
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-white/5">
                    <tr class="text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                        <th class="px-6 py-4">Product Inventory</th>
                        <th class="px-6 py-4">Category</th>
                        <th class="px-6 py-4">Current Stock</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% products.forEach(product => { %>
                        <tr class="hover:bg-white/5 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-black/20 p-1 border border-white/5 overflow-hidden">
                                        <img src="<%= product.coverImage %>" class="w-full h-full object-contain" alt="">
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-white font-medium truncate max-w-[200px]"><%= product.name %></span>
                                        <span class="text-[10px] text-apple-text-gray uppercase tracking-tighter">SKU: <%= product._id.toString().slice(-6).toUpperCase() %></span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-apple-text-gray">
                                <%= product.category ? product.category.name : 'Uncategorized' %>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <span class="text-white font-bold text-lg"><%= product.totalStock %></span>
                                    <% if (product.totalStock <= 5) { %>
                                        <span class="text-[10px] bg-red-500/20 text-red-400 px-1.5 py-0.5 rounded font-black uppercase">Low</span>
                                    <% } %>
                                </div>
                                <% if (product.variants && product.variants.length > 0) { %>
                                    <div class="mt-2 space-y-1">
                                        <% product.variants.forEach(variant => { %>
                                            <div class="flex items-center justify-between text-[10px] bg-white/5 rounded px-2 py-1 border border-white/5">
                                                <span class="text-apple-text-gray font-medium"><%= variant.name %>:</span>
                                                <div class="flex items-center gap-2">
                                                    <span class="<%= variant.stock <= 5 ? 'text-red-400' : 'text-white' %> font-bold"><%= variant.stock %></span>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } %>
                            </td>
                            <td class="px-6 py-4">
                                <% if (product.totalStock === 0) { %>
                                    <span class="inline-flex items-center gap-1.5 text-red-500 font-bold text-xs uppercase">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                        Out of Stock
                                    </span>
                                <% } else if (product.totalStock <= 5) { %>
                                    <span class="inline-flex items-center gap-1.5 text-yellow-500 font-bold text-xs uppercase">
                                        <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
                                        Critical
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center gap-1.5 text-green-500 font-bold text-xs uppercase">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                        Healthy
                                    </span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex justify-end">
                                    <% if (product.variants && product.variants.length > 0) { %>
                                        <button type="button"
                                                class="js-edit-variant-stock w-10 h-10 flex items-center justify-center bg-white/5 text-apple-gold border border-white/10 rounded-xl hover:bg-apple-gold hover:text-[#1a231e] hover:border-apple-gold transition-all shadow-lg group"
                                                data-product-id="<%= product._id %>"
                                                data-product-name="<%= product.name %>"
                                                data-variants="<%= JSON.stringify(product.variants || []) %>"
                                                title="Edit Variant Stock">
                                            <i data-lucide="edit-3" class="w-5 h-5 transition-transform group-hover:scale-110"></i>
                                        </button>
                                    <% } else { %>
                                        <span class="text-[10px] text-apple-text-gray italic">No variants</span>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="p-6 border-t border-white/5 flex items-center justify-between font-serif">
                <p class="text-sm text-apple-text-gray">
                    Showing <span class="text-white font-medium"><%= (currentPage - 1) * 10 + 1 %></span> to <%= Math.min(currentPage * 10, totalProducts) %> products
                </p>
                <div class="flex gap-1">
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <a href="?page=<%= i %>&search=<%= encodedSearchQuery %>&filter=<%= encodedSelectedFilter %>&sort=<%= encodedSelectedSort %>" 
                           class="w-8 h-8 flex items-center justify-center rounded-lg border border-white/5 transition-all text-xs
                           <%= i === currentPage ? 'bg-apple-gold text-[#1a231e] font-bold' : 'bg-white/5 text-white hover:bg-white/10' %>">
                           <%= i %>
                        </a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script>
    const htmlEscapeMap = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
    };

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, (char) => htmlEscapeMap[char]);
    }

    async function showVariantStockManager(productId, productName, variants) {
        const variantList = Array.isArray(variants) ? variants : [];
        const variantsHtml = variantList.map((v, index) => {
            const stock = Number(v.stock || 0);
            return `
            <div class="flex items-center justify-between p-3 bg-white/5 border border-white/10 rounded-xl mb-2 hover:border-apple-gold/30 transition-colors">
                <div class="flex flex-col items-start">
                    <span class="text-white font-bold text-sm">${escapeHtml(v.name)}</span>
                    <span class="text-[10px] text-apple-text-gray uppercase tracking-wider">Current: <span class="${stock <= 5 ? 'text-red-400' : 'text-green-400'} font-black">${stock}</span></span>
                </div>
                <button type="button"
                        data-variant-index="${index}"
                        class="variant-stock-option px-3 py-1.5 bg-apple-gold text-[#1a231e] rounded-lg text-[10px] font-black uppercase hover:bg-white transition-colors">
                    Edit Stock
                </button>
            </div>
            `;
        }).join('');

        await Swal.fire({
            title: '<span class="font-serif">Manage Inventory</span>',
            html: `
                <div class="mt-4">
                    <p class="text-[10px] text-apple-text-gray mb-6 text-left uppercase tracking-widest font-bold">Select a variant for <strong>${escapeHtml(productName)}</strong></p>
                    <div class="max-h-[350px] overflow-y-auto pr-2 custom-scrollbar">
                        ${variantsHtml || '<p class="text-sm text-apple-text-gray text-left">No variants found.</p>'}
                    </div>
                </div>
            `,
            showConfirmButton: false,
            showCancelButton: true,
            cancelButtonText: 'Cancel',
            background: '#1a231e',
            color: '#fff',
            customClass: {
                popup: 'rounded-3xl border border-white/10 shadow-2xl',
                cancelButton: 'bg-white/5 border border-white/10 text-white rounded-xl px-6 py-2 text-xs font-bold'
            },
            didOpen: (popup) => {
                popup.querySelectorAll('.variant-stock-option').forEach((button) => {
                    button.addEventListener('click', () => {
                        const variant = variantList[Number(button.dataset.variantIndex)];
                        if (!variant) return;
                        Swal.close();
                        quickUpdateStock(productId, variant.stock, `${productName} (${variant.name})`, variant.name);
                    });
                });
            }
        });
    }

    async function quickUpdateStock(id, currentStock, name, variantName = null) {
        const { value: newStock } = await Swal.fire({
            title: 'Update Stock',
            text: `Updating inventory for "${name}"`,
            input: 'number',
            inputLabel: 'Enter new stock level',
            inputValue: currentStock,
            showCancelButton: true,
            background: '#1a231e',
            color: '#fff',
            confirmButtonColor: '#E6CFA7',
            confirmButtonText: 'Update Now',
            inputAttributes: {
                min: 0,
                step: 1
            },
            customClass: {
                input: 'bg-white/5 border-white/10 text-white rounded-xl'
            }
        });

        if (newStock !== undefined) {
            try {
                const response = await fetch(`/admin/inventory/update-stock/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ stock: newStock, variantName: variantName })
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Inventory updated successfully',
                        background: '#1a231e',
                        color: '#fff',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Update Failed',
                    text: error.message,
                    background: '#1a231e',
                    color: '#fff'
                });
            }
        }
    }

    document.addEventListener('click', function (e) {
        const sortWrap = document.getElementById('invSortWrap');
        if (sortWrap && !sortWrap.contains(e.target)) {
            const sortMenu = document.getElementById('invSortMenu');
            if (sortMenu) sortMenu.classList.add('hidden');
        }

        const filterWrap = document.getElementById('invFilterWrap');
        if (filterWrap && !filterWrap.contains(e.target)) {
            const filterMenu = document.getElementById('invFilterMenu');
            if (filterMenu) filterMenu.classList.add('hidden');
        }
    });

    document.querySelectorAll('.js-edit-variant-stock').forEach((button) => {
        button.addEventListener('click', () => {
            let variants = [];
            try {
                variants = JSON.parse(button.dataset.variants || '[]');
            } catch (error) {
                variants = [];
            }

            showVariantStockManager(
                button.dataset.productId,
                button.dataset.productName || '',
                variants
            );
        });
    });

    const inventorySearch = document.getElementById('inventorySearch');
    
    const triggerUpdate = () => {
        const sort = '<%= typeof selectedSort !== 'undefined' ? selectedSort : 'newest' %>';
        const filter = '<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>';
        const params = new URLSearchParams({
            page: '1',
            search: inventorySearch.value,
            sort,
            filter
        });
        window.location.href = `/admin/inventory?${params.toString()}`;
    };

    inventorySearch.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') triggerUpdate();
    });
</script>
