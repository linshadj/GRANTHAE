<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">Edit Offer</h1>
            <p class="text-apple-text-gray/80 text-sm">Manage promotional offer details.</p>
        </div>
        <div class="flex gap-3">
            <a href="/admin/offers"
                class="px-4 py-2 text-sm font-medium text-apple-text-gray hover:text-apple-dark hover:bg-gray-100 rounded-lg transition-colors">Cancel</a>
            <button class="btn-primary flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i> Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Form -->
        <div class="lg:col-span-2 space-y-6">
            <div class="glass-card p-6 space-y-6">
                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Offer Title</label>
                    <input type="text" value="Summer Reading Festival"
                        class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                </div>

                <div>
                    <label class="block text-sm font-medium text-apple-dark mb-2">Offer Description</label>
                    <textarea rows="3"
                        class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">Get 50% off on all Sci-Fi rentals this summer!</textarea>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Discount Percentage</label>
                        <div class="relative">
                            <input type="number" value="50"
                                class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all pr-12">
                            <div
                                class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-apple-text-gray">
                                %</div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">Start Date</label>
                        <input type="date" value="2025-06-01"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-apple-dark mb-2">End Date</label>
                        <input type="date" value="2025-08-31"
                            class="w-full px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-apple-dark/20 focus:border-apple-dark outline-none transition-all">
                    </div>
                </div>
            </div>

            <!-- Applicable Categories (Mock) -->
            <div class="glass-card p-6">
                <h3 class="font-semibold text-apple-dark mb-4">Applicable Categories</h3>
                <div class="space-y-3">
                    <label class="flex items-center gap-3">
                        <input type="checkbox" checked
                            class="w-4 h-4 text-apple-dark rounded border-gray-300 focus:ring-apple-dark">
                        <span class="text-sm text-apple-dark">Science Fiction</span>
                    </label>
                    <label class="flex items-center gap-3">
                        <input type="checkbox"
                            class="w-4 h-4 text-apple-dark rounded border-gray-300 focus:ring-apple-dark">
                        <span class="text-sm text-apple-dark">Fantasy</span>
                    </label>
                    <!-- More generic options -->
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
            <div class="glass-card p-6 text-center">
                <div
                    class="w-full h-40 bg-gray-100 rounded-lg flex items-center justify-center mb-4 border border-dashed border-gray-300 overflow-hidden relative">
                    <img src="/images/book1.jpg" class="absolute inset-0 w-full h-full object-cover opacity-50">
                    <div class="relative z-10 bg-white/80 px-3 py-1 rounded text-xs font-bold">Banner Preview</div>
                </div>
                <button class="text-sm text-apple-blue font-medium hover:underline">Upload Banner</button>
            </div>
        </div>
    </div>
</div>