<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Add Product Variant</h1>
            <p class="text-gray-400">Add a new format or version for an existing product.</p>
        </div>
        <a href="/admin/products"
            class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 transition-colors">
            Cancel
        </a>
    </div>

    <form class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Info -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm space-y-4">
                <h3 class="text-lg font-bold text-white mb-4">Variant Details</h3>

                <!-- Product Selection (Mock) -->
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Parent Product</label>
                    <select
                        class="w-full input-dark outline-none appearance-none bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white">
                        <option>The Design of Everyday Things</option>
                        <option>Steve Jobs</option>
                        <option>Clean Code</option>
                        <option>Zero to One</option>
                    </select>
                </div>

                <!-- Variant Specifics -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">Variant Type Name</label>
                        <input type="text" placeholder="e.g. Special Edition Hardcover"
                            class="w-full input-dark outline-none" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">SKU / ID</label>
                        <input type="text" placeholder="SKU-123-VAR" class="w-full input-dark outline-none">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">Price ($)</label>
                        <input type="number" step="0.01" placeholder="0.00" class="w-full input-dark outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">Stock Quantity</label>
                        <input type="number" placeholder="50" class="w-full input-dark outline-none">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Description (Optional)</label>
                    <textarea rows="3" placeholder="Specific details for this variant..."
                        class="w-full input-dark outline-none resize-none"></textarea>
                </div>
            </div>
        </div>

        <!-- Right Column: Media -->
        <div class="space-y-6">
            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
                <h3 class="text-lg font-bold text-white mb-4">Variant Image</h3>

                <div
                    class="border-2 border-dashed border-white/10 rounded-xl p-8 text-center hover:bg-white/5 transition-colors cursor-pointer group">
                    <div
                        class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-3 text-gray-400 group-hover:text-white transition-all shadow-sm">
                        <i data-lucide="image-plus" class="w-6 h-6"></i>
                    </div>
                    <p class="text-sm font-medium text-gray-300">Upload Image</p>
                    <p class="text-xs text-gray-500 mt-1">If different from parent</p>
                </div>
            </div>

            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
                <h3 class="text-lg font-bold text-white mb-4">Status</h3>
                <label
                    class="flex items-center justify-between p-3 rounded-xl border border-white/10 hover:bg-white/5 cursor-pointer">
                    <span class="text-sm font-medium text-gray-300">Active</span>
                    <input type="checkbox" checked
                        class="w-4 h-4 text-apple-blue bg-white/10 border-white/20 rounded focus:ring-apple-blue focus:ring-offset-gray-900">
                </label>
            </div>

            <button type="submit" class="w-full btn-primary py-3 shadow-lg shadow-apple-gold/20">
                Save Variant
            </button>
        </div>
    </form>
</div>