<%
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 });
%>

<div class="space-y-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark font-serif">Admin Overview</h1>
            <p class="text-apple-text-gray text-sm">Live platform performance and action queues.</p>
        </div>
        <div class="flex gap-2">
            <a href="/admin/reports" class="px-4 py-2 bg-white/5 border border-white/10 text-apple-text-gray rounded-xl hover:bg-white/10 transition-all flex items-center gap-2 text-xs font-bold">
                <i data-lucide="download" class="w-4 h-4"></i> Export Report
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card p-6 border-l-4 border-apple-blue">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Total Users</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2"><%= dashboard.totalUsers.toLocaleString('en-IN') %></h3>
                    <p class="text-sm text-gray-500 mt-1 flex items-center">
                        <i data-lucide="users" class="w-4 h-4 mr-1"></i> Registered customers
                    </p>
                </div>
                <div class="p-3 bg-blue-50/50 rounded-xl text-apple-blue">
                    <i data-lucide="users" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border-l-4 border-purple-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Active Rentals</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2"><%= dashboard.activeRentals.toLocaleString('en-IN') %></h3>
                    <p class="text-sm text-gray-500 mt-1 flex items-center">
                        <i data-lucide="book-open-check" class="w-4 h-4 mr-1"></i> Approved, available, or rented
                    </p>
                </div>
                <div class="p-3 bg-purple-50/50 rounded-xl text-purple-600">
                    <i data-lucide="book-open-check" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border-l-4 border-orange-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Return Requests</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2"><%= dashboard.pendingReturnRequests.toLocaleString('en-IN') %></h3>
                    <p class="text-sm text-orange-600 mt-1 flex items-center">
                        <i data-lucide="undo-2" class="w-4 h-4 mr-1"></i> Awaiting admin confirmation
                    </p>
                </div>
                <div class="p-3 bg-orange-500/10 rounded-xl text-orange-500">
                    <i data-lucide="rotate-ccw" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="glass-card p-6 border border-white/5">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Net Sales</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2">₹<%= formatAmount(dashboard.revenue) %></h3>
                    <p class="text-sm text-green-600 mt-1 flex items-center">
                        <i data-lucide="indian-rupee" class="w-4 h-4 mr-1"></i> Non-cancelled orders
                    </p>
                </div>
                <div class="p-3 bg-green-500/10 rounded-xl text-green-500">
                    <i data-lucide="trending-up" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border border-white/5">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Pending Orders</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2"><%= dashboard.pendingOrders.toLocaleString('en-IN') %></h3>
                    <p class="text-sm text-gray-500 mt-1 flex items-center">
                        <i data-lucide="list-todo" class="w-4 h-4 mr-1"></i> Awaiting fulfillment
                    </p>
                </div>
                <div class="p-3 bg-apple-blue/10 rounded-xl text-apple-blue">
                    <i data-lucide="shopping-cart" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border border-white/5">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Products</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2"><%= dashboard.totalProducts.toLocaleString('en-IN') %></h3>
                    <p class="text-sm text-gray-500 mt-1 flex items-center">
                        <i data-lucide="package" class="w-4 h-4 mr-1"></i> Active catalog records
                    </p>
                </div>
                <div class="p-3 bg-purple-500/10 rounded-xl text-purple-500">
                    <i data-lucide="boxes" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex justify-between items-center">
            <h3 class="font-bold text-lg text-apple-dark">Recent Orders</h3>
            <a href="/admin/orders" class="text-xs font-bold text-apple-gold hover:underline uppercase tracking-widest">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-white/5 text-xs text-apple-text-gray uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Order</th>
                        <th class="px-6 py-4">Customer</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% if (dashboard.recentOrders.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-6 py-10 text-center text-apple-text-gray">No orders yet.</td>
                        </tr>
                    <% } %>
                    <% dashboard.recentOrders.forEach(order => { %>
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4">
                                <a href="/admin/orders/view/<%= order._id %>" class="font-bold text-apple-dark hover:text-apple-gold"><%= order.orderID %></a>
                                <div class="text-[10px] text-apple-text-gray"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></div>
                            </td>
                            <td class="px-6 py-4 text-apple-text-gray">
                                <%= order.user ? `${order.user.firstName} ${order.user.lastName}` : `${order.shippingAddress.firstName || ''} ${order.shippingAddress.lastName || ''}` %>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 text-xs font-bold rounded-full <%= order.orderStatus === 'Cancelled' || order.paymentStatus === 'Failed' ? 'bg-red-500/10 text-red-400' : order.orderStatus === 'Delivered' ? 'bg-green-500/10 text-green-400' : 'bg-yellow-500/10 text-yellow-400' %>">
                                    <%= order.paymentStatus === 'Failed' ? 'Failed' : order.orderStatus %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right font-bold text-apple-dark">₹<%= formatAmount(order.totalAmount) %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
