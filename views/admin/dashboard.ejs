<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">Admin Overview</h1>
            <p class="text-apple-text-gray text-sm">Platform performance and management.</p>
        </div>
        <div class="flex gap-2">
            <button class="btn-outline flex items-center gap-2 text-xs">
                <i data-lucide="download" class="w-4 h-4"></i> Export Report
            </button>
        </div>
    </div>

    <!-- Admin Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card p-6 border-l-4 border-apple-blue">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Total Users</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2">2,543</h3>
                    <p class="text-sm text-green-600 mt-1 flex items-center">
                        <i data-lucide="trending-up" class="w-4 h-4 mr-1"></i> +12% this month
                    </p>
                </div>
                <div class="p-3 bg-blue-50/50 rounded-xl text-apple-blue">
                    <i data-lucide="users" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border-l-4 border-purple-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Active Rentals</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2">856</h3>
                    <p class="text-sm text-green-600 mt-1 flex items-center">
                        <i data-lucide="trending-up" class="w-4 h-4 mr-1"></i> +5% this week
                    </p>
                </div>
                <div class="p-3 bg-purple-50/50 rounded-xl text-purple-600">
                    <i data-lucide="book-open-check" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border-l-4 border-red-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Overdue Books</p>
                    <h3 class="text-3xl font-bold text-apple-dark mt-2">42</h3>
                    <p class="text-sm text-red-600 mt-1 flex items-center">
                        <i data-lucide="alert-circle" class="w-4 h-4 mr-1"></i> Action needed
                    </p>
                </div>
                <div class="p-3 bg-red-50/50 rounded-xl text-red-600">
                    <i data-lucide="clock" class="w-6 h-6"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- System Overview Stats -->
    <div class="mt-8">
        <h3 class="font-bold text-lg text-apple-dark mb-4">System Overview</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="glass-card p-6 border border-white/5">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Server Status</p>
                        <h3 class="text-3xl font-bold text-apple-dark mt-2">Optimal</h3>
                        <p class="text-sm text-green-600 mt-1 flex items-center">
                            <i data-lucide="check-circle-2" class="w-4 h-4 mr-1"></i> 99.9% Uptime
                        </p>
                    </div>
                    <div class="p-3 bg-green-500/10 rounded-xl text-green-500">
                        <i data-lucide="activity" class="w-6 h-6"></i>
                    </div>
                </div>
            </div>

            <div class="glass-card p-6 border border-white/5">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Pending Tasks</p>
                        <h3 class="text-3xl font-bold text-apple-dark mt-2">18</h3>
                        <p class="text-sm text-gray-500 mt-1 flex items-center">
                            <i data-lucide="list-todo" class="w-4 h-4 mr-1"></i> Across all admins
                        </p>
                    </div>
                    <div class="p-3 bg-apple-blue/10 rounded-xl text-apple-blue">
                        <i data-lucide="layers" class="w-6 h-6"></i>
                    </div>
                </div>
            </div>

            <div class="glass-card p-6 border border-white/5">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Storage Used</p>
                        <h3 class="text-3xl font-bold text-apple-dark mt-2">45%</h3>
                        <p class="text-sm text-gray-500 mt-1 flex items-center">
                            <i data-lucide="database" class="w-4 h-4 mr-1"></i> 112GB / 250GB
                        </p>
                    </div>
                    <div class="p-3 bg-purple-500/10 rounded-xl text-purple-500">
                        <i data-lucide="hard-drive" class="w-6 h-6"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>