<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div class="flex gap-2">
            <button
                class="right-0 px-4 py-2 bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors text-sm">Export</button>
        </div>
    </div>

    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Registered Users</h3>
            <div class="flex gap-2">
                <!-- Sort Dropdown -->
                <div class="relative" id="userSortWrap">
                    <button onclick="document.getElementById('userSortMenu').classList.toggle('hidden')"
                        class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5">
                        <i data-lucide="arrow-up-down" class="w-3.5 h-3.5"></i>
                        <span id="userSortLabel">
                            <% const sortLabels={ 'a-z' : 'Name (A-Z)' , 'z-a' : 'Name (Z-A)' , 'newest'
                                : 'Newest First' , 'oldest' : 'Oldest First' }; %>
                                <%= sortLabels[userDb.selectedSort] || 'Sort By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="userSortMenu"
                        class="hidden absolute right-0 mt-2 w-48 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=a-z"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="a-arrow-down" class="w-3.5 h-3.5"></i> Name (A-Z)
                        </a>
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=z-a"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="a-arrow-up" class="w-3.5 h-3.5"></i> Name (Z-A)
                        </a>
                        <div class="border-t border-white/5 my-1"></div>
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=newest"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="calendar-clock" class="w-3.5 h-3.5"></i> Newest First
                        </a>
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=oldest"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="calendar" class="w-3.5 h-3.5"></i> Oldest First
                        </a>
                    </div>
                </div>

                <!-- Filter Dropdown -->
                <div class="relative" id="userFilterWrap">
                    <button onclick="document.getElementById('userFilterMenu').classList.toggle('hidden')"
                        class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5">
                        <i data-lucide="filter" class="w-3.5 h-3.5"></i>
                        <span id="userFilterLabel">
                            <% const filterLabels={ 'all' : 'All' , 'active' : 'Active' , 'blocked' : 'Blocked' , 'user'
                                : 'User' , 'admin' : 'Admin' }; %>
                                <%= filterLabels[userDb.selectedFilter] || 'All' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="userFilterMenu"
                        class="hidden absolute right-0 mt-2 w-40 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=all"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="layers" class="w-3.5 h-3.5"></i> All
                        </a>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=active"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="check-circle" class="w-3.5 h-3.5 text-green-400"></i> Active
                        </a>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=blocked"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="ban" class="w-3.5 h-3.5 text-red-400"></i> Blocked
                        </a>
                        <div class="border-t border-white/5 my-1"></div>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=user"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="user" class="w-3.5 h-3.5 text-blue-400"></i> User
                        </a>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=admin"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-apple-dark transition-colors flex items-center gap-2">
                            <i data-lucide="shield" class="w-3.5 h-3.5 text-purple-400"></i> Admin
                        </a>
                    </div>
                </div>
                <div class="relative flex items-center">
                    <i data-lucide="search" class="absolute left-3 w-3.5 h-3.5 text-apple-text-gray"></i>
                    <input id="searchInput" type="text" value="<%= userDb.searchQuery || '' %>"
                        placeholder="Search Users..."
                        class="pl-10 pr-20 py-3 w-64 text-xs bg-white/5 border border-white/5 rounded-lg focus:outline-none focus:ring-1 focus:ring-apple-gold/50 text-apple-dark placeholder-apple-text-gray/50 transition-all hover:bg-white/10">
                    <!-- Clear button -->
                    <button id="clearSearchBtn"
                        class="hidden absolute right-2 top-1/2 -translate-y-1/2 px-3 py-1 text-xs font-semibold rounded-lg text-apple-text-gray hover:bg-white/10 transition-colors"
                        title="Clear search">
                        <i data-lucide="x" class="w-3.5 h-3.5"></i>
                    </button>
            </div>

        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="bg-white/5">
                <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                    <th class="px-6 py-4">User</th>
                    <th class="px-6 py-4">Role</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Joined</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                <% if (userDb.totalFilteredUser===0) { %>
                    <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-apple-text-gray">No users found</td>
                    </tr>
                    <% } else { %>
                        <% userDb.users.forEach(user=> { %>
                            <tr data-userid="<%= user._id %>"
                                onclick="window.location.href='/admin/users/<%= user._id %>'"
                                class="group hover:bg-white/5 transition-colors cursor-pointer">
                                <td class="px-6 py-4 flex items-center gap-3">
                                    <div
                                        class="w-8 h-8 bg-[#1C2A3A] rounded-full relative overflow-hidden group shadow-lg">
                                        <img id="avatarPreview" src="<%= user.avatar %>"
                                            class="w-full h-full object-cover">
                                    </div>
                                    <div class="font-medium text-apple-dark">
                                        <%= user.firstName %>
                                            <%= user.lastName %>
                                    </div>
                                    <div class="text-xs text-apple-text-gray">
                                        <%= user.email %>
                                    </div>
    </div>
    </td>
    <td class="px-6 py-4 text-apple-text-gray">
        <%= user.role %>
    </td>
    <td class="px-6 py-4">
        <span
            class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold <%= user.isBlocked ? 'bg-red-500/10 text-red-400' : 'bg-green-500/10 text-green-400' %>">
            <%= user.isBlocked ? 'Blocked' : 'Active' %>
        </span>
    </td>
    <td class="px-6 py-4 text-apple-text-gray">
        <%= user.createdAt.toLocaleDateString() %>
    </td>
    <td class="px-6 py-4 text-right">
        <button onclick="event.stopPropagation(); toggleBlock(this)" data-blocked="<%= user.isBlocked %>"
            class="px-3 py-1.5 text-xs font-bold rounded-lg transition-all border <%= user.isBlocked ? 'border-green-500/20 bg-green-500/10 text-green-400 hover:bg-green-500/20' : 'border-red-500/20 bg-red-500/10 text-red-400 hover:bg-red-500/20' %>">
            <% if (user.isBlocked) { %>
                <i data-lucide="shield-check" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i>Unblock
                <% } else { %>
                    <i data-lucide="ban" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i>Block
                    <% } %>
        </button>
    </td>
    </tr>
    <% }) %>
        <% } %>
            </tbody>
            </table>
</div>

<!-- Pagination -->
<div class="p-4 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-xs text-apple-text-gray">Showing <span class="font-bold text-apple-dark">
            <% if(userDb.totalFilteredUser===0) { %>0<% } else { %>
                    <%= (userDb.currentPage - 1) * userDb.limit + 1 %>-<%= Math.min(userDb.currentPage * userDb.limit,
                            userDb.totalFilteredUser) %>
                            <% } %>
        </span> of <span class="font-bold text-apple-dark">
            <%= userDb.totalFilteredUser %>
        </span> users</p>
    <div class="flex items-center gap-1">
        <% for(let i=1; i <=userDb.totalPages; i++) { %>
            <a href="/admin/users?page=<%= i %>&sort=<%= userDb.selectedSort || '' %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>"
                class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-colors 
       <%= i === userDb.currentPage ? 'bg-apple-gold text-[#1a231e] font-bold' : 'text-apple-text-gray hover:bg-white/10' %>">
                <%= i %>
            </a>
            <% } %>

    </div>
</div>
</div>
</div>

<script>

    const searchInput = document.getElementById('searchInput');
    const clearSearchBtn = document.getElementById('clearSearchBtn');

    function updateClearBtnVisibility() {
        if (!clearSearchBtn) return;
        clearSearchBtn.classList.toggle('hidden', !searchInput.value.trim());
    }

    searchInput.addEventListener('input', updateClearBtnVisibility);
    updateClearBtnVisibility();

    searchInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            const searchQuery = searchInput.value.trim();
            const currentPage = 1; // Reset to first page on new search
            const currentSort = '<%= userDb.selectedSort || '' %>';
            const currentFilter = '<%= userDb.selectedFilter || '' %>';
            window.location.href = `/admin/users?page=${currentPage}&sort=${currentSort}&filter=${currentFilter}&search=${encodeURIComponent(searchQuery)}`;
        }
    });

    if (clearSearchBtn) {
        clearSearchBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            e.preventDefault();
            searchInput.value = '';
            updateClearBtnVisibility();

            const currentPage = 1;
            const currentSort = '<%= userDb.selectedSort || '' %>';
            const currentFilter = '<%= userDb.selectedFilter || '' %>';
            
            window.location.href = `/admin/users?page=${currentPage}&sort=${currentSort}&filter=${currentFilter}&search=`;
        });
    }


    window.toggleBlock = async (btn) => {
        
        const rawBlocked = btn.getAttribute('data-blocked');
        const isBlocked = rawBlocked === 'true' || rawBlocked === true;

        const action = isBlocked ? 'Unblock' : 'Block';
        const confirmBtnColor = isBlocked ? '#22c55e' : '#ef4444'; 

        Swal.fire({
            title: `Are you sure?`,
            text: `Do you really want to ${action.toLowerCase()} this user?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: confirmBtnColor,
            cancelButtonColor: '#1a231e',
            confirmButtonText: `Yes, ${action} User`,
            background: '#1e2a22',
            color: '#E6CFA7',
            customClass: {
                popup: 'border border-white/10 rounded-2xl shadow-xl',
                confirmButton: 'px-4 py-2 text-sm font-bold rounded-lg',
                cancelButton: 'px-4 py-2 text-sm font-bold rounded-lg border border-white/10 text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors'
            }
        }).then(async (result) => {
            if (result.isConfirmed) {

                try {
                    const data = await fetch(`/admin/users/toggle-block/${btn.closest('tr').dataset.userid}/${isBlocked ? 'unblock' : 'block'}`, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ isBlocked: !isBlocked })
                    });

                    const res = await data.json();

                    if (res.success) {
                        const newStatus = !isBlocked;

                        // Simulate backend update logic
                        const row = btn.closest('tr');
                        const statusBadge = row.querySelector('td:nth-child(3) span');

                        // Update button state immediately
                        btn.setAttribute('data-blocked', newStatus.toString());

                        if (isBlocked) {
                            // Unblock → set to Active
                            btn.className = 'px-3 py-1.5 text-xs font-bold rounded-lg transition-all border border-red-500/20 bg-red-500/10 text-red-400 hover:bg-red-500/20';
                            btn.innerHTML = '<i data-lucide="ban" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i>Block';
                            if (statusBadge) {
                                statusBadge.className = 'inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-green-500/10 text-green-400';
                                statusBadge.textContent = 'Active';
                            }
                            window.location.href = '/admin/users?status=success&message=User unblocked successfully';
                        } else {
                            // Block → set to Blocked
                            btn.className = 'px-3 py-1.5 text-xs font-bold rounded-lg transition-all border border-green-500/20 bg-green-500/10 text-green-400 hover:bg-green-500/20';
                            btn.innerHTML = '<i data-lucide="shield-check" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i>Unblock';
                            if (statusBadge) {
                                statusBadge.className = 'inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-red-500/10 text-red-400';
                                statusBadge.textContent = 'Blocked';
                            }
                            window.location.href = '/admin/users?status=success&message=User blocked successfully';
                        }

                        if (typeof lucide !== 'undefined') lucide.createIcons();
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: res.message || 'An error occurred while updating user status.',
                            icon: 'error',
                            background: '#1e2a22',
                            color: '#E6CFA7',
                            showConfirmButton: false,
                            timer: 2000,
                            customClass: { popup: 'border border-white/10 rounded-2xl shadow-xl' }
                        });
                    }
                } catch (error) {
                    console.error('Error toggling user block status:', error);
                }
            }
        });
    }


    document.addEventListener('click', function (e) {
        const filterWrap = document.getElementById('userFilterWrap');
        if (filterWrap && !filterWrap.contains(e.target)) {
            document.getElementById('userFilterMenu').classList.add('hidden');
        }

        const sortWrap = document.getElementById('userSortWrap');
        if (sortWrap && !sortWrap.contains(e.target)) {
            document.getElementById('userSortMenu').classList.add('hidden');
        }
    });
</script>