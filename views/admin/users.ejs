<div class="space-y-8">
    <!-- Stat Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-apple-card rounded-2xl border border-white/5 p-6 flex items-center gap-4 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl bg-apple-gold/10 flex items-center justify-center text-apple-gold">
                <i data-lucide="users" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-apple-text-gray uppercase tracking-wider font-semibold">Total Users</p>
                <p class="text-2xl font-bold text-white"><%= userDb.totalUsers %></p>
            </div>
        </div>
        <div class="bg-apple-card rounded-2xl border border-white/5 p-6 flex items-center gap-4 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500">
                <i data-lucide="user-check" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-apple-text-gray uppercase tracking-wider font-semibold">Active Users</p>
                <p class="text-2xl font-bold text-white"><%= userDb.activeUsers %></p>
            </div>
        </div>
        <div class="bg-apple-card rounded-2xl border border-white/5 p-6 flex items-center gap-4 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500">
                <i data-lucide="user-minus" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-apple-text-gray uppercase tracking-wider font-semibold">Blocked Users</p>
                <p class="text-2xl font-bold text-white"><%= userDb.blockedUsers %></p>
            </div>
        </div>
    </div>

    <!-- Top Action Bar -->
    <div class="flex items-center justify-between">
        <div class="flex gap-2">
            <button
                class="px-4 py-2 bg-white/5 text-apple-text-gray border border-white/10 rounded-lg hover:bg-white/10 transition-colors text-sm flex items-center gap-2">
                <i data-lucide="download" class="w-4 h-4"></i> Export Data
            </button>
        </div>
    </div>

    <!-- Main List Card -->
    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Registered Users</h3>
            <div class="flex flex-wrap items-center justify-center sm:justify-end gap-3 w-full sm:w-auto">
                <!-- Search -->
                <div class="relative items-center flex w-full sm:w-auto">
                    <i data-lucide="search" class="absolute left-3 w-3.5 h-3.5 text-apple-text-gray"></i>
                    <input id="searchInput" type="text" value="<%= userDb.searchQuery || '' %>"
                        placeholder="Search Users..."
                        class="pl-10 pr-10 py-3 h-10 w-full sm:w-64 text-sm bg-white/5 border border-white/5 rounded-xl focus:outline-none focus:ring-2 focus:ring-apple-gold/50 text-white placeholder-apple-text-gray transition-all hover:bg-white/10">

                    <button id="clearSearchBtn"
                        class="hidden absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 text-xs font-semibold rounded-lg text-apple-text-gray hover:bg-white/10 transition-colors"
                        title="Clear search">
                        <i data-lucide="x" class="w-4 h-4"></i>
                    </button>
                </div>

                <!-- Sort Dropdown -->
                <div class="relative" id="userSortWrap">
                    <button onclick="document.getElementById('userSortMenu').classList.toggle('hidden')"
                        class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5 h-10 min-w-max whitespace-nowrap">
                        <i data-lucide="arrow-up-down" class="w-3.5 h-3.5"></i>
                        <span id="userSortLabel">
                            <% const sortLabels={ 'a-z' : 'Name (A-Z)' , 'z-a' : 'Name (Z-A)' , 'newest'
                                : 'Newest First' , 'oldest' : 'Oldest First' }; %>
                                <%= sortLabels[userDb.selectedSort] || 'Sort By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="userSortMenu"
                        class="hidden absolute right-0 mt-2 w-48 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=a-z"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="a-arrow-down" class="w-3.5 h-3.5"></i> Name (A-Z)
                        </a>
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=z-a"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="a-arrow-up" class="w-3.5 h-3.5"></i> Name (Z-A)
                        </a>
                        <div class="border-t border-white/5 my-1"></div>
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=newest"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="calendar-clock" class="w-3.5 h-3.5"></i> Newest First
                        </a>
                        <a href="/admin/users?page=<%= userDb.currentPage %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>&sort=oldest"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="calendar" class="w-3.5 h-3.5"></i> Oldest First
                        </a>
                    </div>
                </div>

                <!-- Filter Dropdown -->
                <div class="relative" id="userFilterWrap">
                    <button onclick="document.getElementById('userFilterMenu').classList.toggle('hidden')"
                        class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5 h-10 min-w-max whitespace-nowrap">
                        <i data-lucide="filter" class="w-3.5 h-3.5"></i>
                        <span id="userFilterLabel">
                            <% const filterLabels={ 'all' : 'All' , 'active' : 'Active' , 'blocked' : 'Blocked' , 'user'
                                : 'Users' , 'admin' : 'Admins' }; %>
                                <%= typeof userDb.selectedFilter !=='undefined' ? filterLabels[userDb.selectedFilter]
                                    || 'Filter By' : 'Filter By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="userFilterMenu"
                        class="hidden absolute right-0 mt-2 w-40 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=all"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="layers" class="w-3.5 h-3.5"></i> All
                        </a>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=active"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="check-circle" class="w-3.5 h-3.5 text-green-400"></i> Active
                        </a>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=blocked"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="ban" class="w-3.5 h-3.5 text-red-400"></i> Blocked
                        </a>
                        <div class="border-t border-white/5 my-1"></div>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=user"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="user" class="w-3.5 h-3.5 text-blue-400"></i> User
                        </a>
                        <a href="/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&search=<%= userDb.searchQuery || '' %>&filter=admin"
                            class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="shield" class="w-3.5 h-3.5 text-purple-400"></i> Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-white/5">
                    <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                        <th class="px-6 py-4">User</th>
                        <th class="px-6 py-4">Role</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Joined</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody" class="divide-y divide-white/5">
                    <% if (userDb.totalFilteredUser === 0) { %>
                    <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-apple-text-gray">No users found</td>
                    </tr>
                    <% } else { %>
                        <% userDb.users.forEach(user => { %>
                        <tr data-userid="<%= user._id %>" class="group hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 overflow-hidden flex items-center justify-center shadow-inner">
                                        <% if (user.avatar) { %>
                                            <img src="<%= user.avatar %>" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <div class="w-full h-full bg-apple-gold/10 flex items-center justify-center text-apple-gold font-bold text-lg">
                                                <%= user.firstName.charAt(0).toUpperCase() %>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-semibold text-white group-hover:text-apple-gold transition-colors">
                                            <%= user.firstName %> <%= user.lastName %>
                                        </span>
                                        <span class="text-xs text-apple-text-gray">
                                            <%= user.email %>
                                        </span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="capitalize px-2 py-1 bg-white/5 rounded-md text-apple-text-gray border border-white/5 text-xs"><%= user.role %></span>
                            </td>
                            <td class="px-6 py-4">
                                <% if (user.isBlocked) { %>
                                    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-red-500/10 text-red-500 border border-red-500/20 uppercase tracking-wider">
                                        Blocked
                                    </span>
                                <% } else { %>
                                    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-green-500/10 text-green-500 border border-green-500/20 uppercase tracking-wider">
                                        Active
                                    </span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-apple-text-gray text-xs">
                                <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <button onclick="toggleBlock(this)" data-blocked="<%= user.isBlocked %>" 
                                        class="p-2 bg-white/5 text-<%= user.isBlocked ? 'green' : 'red' %>-500 hover:bg-white/10 rounded-lg transition-colors border border-white/5" 
                                        title="<%= user.isBlocked ? 'Unblock' : 'Block' %> User">
                                        <i data-lucide="<%= user.isBlocked ? 'shield-check' : 'ban' %>" class="w-4 h-4"></i>
                                    </button>
                                    <a href="/admin/users/view/<%= user._id %>" class="p-2 bg-white/5 text-apple-gold hover:bg-white/10 rounded-lg transition-colors border border-white/5" title="View Details">
                                        <i data-lucide="eye" class="w-4 h-4"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination Section -->
        <div class="p-4 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 bg-white/2">
            <p class="text-xs text-apple-text-gray">
                Showing <span class="font-bold text-apple-dark">
                    <% if(userDb.totalFilteredUser === 0) { %>0<% } else { %>
                        <%= (userDb.currentPage - 1) * userDb.limit + 1 %> - <%= Math.min(userDb.currentPage * userDb.limit, userDb.totalFilteredUser) %>
                    <% } %>
                </span> of <span class="font-bold text-apple-dark"><%= userDb.totalFilteredUser %></span> users
            </p>
            <div class="flex items-center gap-1">
                <% for(let i=1; i <= userDb.totalPages; i++) { %>
                    <a href="/admin/users?page=<%= i %>&sort=<%= userDb.selectedSort || '' %>&filter=<%= userDb.selectedFilter || '' %>&search=<%= userDb.searchQuery || '' %>"
                        class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-colors 
                        <%= i === userDb.currentPage ? 'bg-apple-gold text-[#1a231e] font-bold shadow-lg shadow-apple-gold/20' : 'text-apple-text-gray hover:bg-white/10' %>">
                        <%= i %>
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const clearSearchBtn = document.getElementById('clearSearchBtn');
    const usersTableBody = document.getElementById("usersTableBody");
    const paginationSection = document.querySelector(".p-4.border-t");

    function updateClearBtnVisibility() {
        if (!clearSearchBtn) return;
        clearSearchBtn.classList.toggle('hidden', !searchInput.value.trim());
    }

    searchInput.addEventListener('input', updateClearBtnVisibility);
    updateClearBtnVisibility();

    function debounce(func, delay) {
        let timeout;
        return function (...args) {
            clearTimeout(timeout);
            timeout = setTimeout(() => { func.apply(this, args); }, delay);
        };
    }

    async function liveSearch() {
        const searchQuery = searchInput.value.trim();
        const currentSort = "<%= userDb.selectedSort || '' %>";
        const currentFilter = "<%= userDb.selectedFilter || '' %>";

        try {
            const res = await fetch(`/admin/users/live?search=${encodeURIComponent(searchQuery)}&sort=${currentSort}&filter=${currentFilter}`);
            const data = await res.json();

            usersTableBody.innerHTML = "";

            if (!data.success || data.users.length === 0) {
                usersTableBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-apple-text-gray">No users found</td></tr>`;
                paginationSection.style.display = "none";
                return;
            }

            data.users.forEach(user => {
                const date = new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                const avatarContent = user.avatar 
                    ? `<img src="${user.avatar}" class="w-full h-full object-cover">`
                    : `<div class="w-full h-full bg-apple-gold/10 flex items-center justify-center text-apple-gold font-bold text-lg">${user.firstName.charAt(0).toUpperCase()}</div>`;

                usersTableBody.innerHTML += `
                    <tr data-userid="${user._id}" class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 overflow-hidden flex items-center justify-center shadow-inner">
                                    ${avatarContent}
                                </div>
                                <div class="flex flex-col">
                                    <span class="font-semibold text-white group-hover:text-apple-gold transition-colors">${user.firstName} ${user.lastName}</span>
                                    <span class="text-xs text-apple-text-gray">${user.email}</span>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="capitalize px-2 py-1 bg-white/5 rounded-md text-apple-text-gray border border-white/5 text-xs">${user.role}</span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-bold ${user.isBlocked ? 'bg-red-500/10 text-red-500 border-red-500/20' : 'bg-green-500/10 text-green-500 border-green-500/20'} uppercase tracking-wider">
                                ${user.isBlocked ? 'Blocked' : 'Active'}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-apple-text-gray text-xs">${date}</td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <button onclick="toggleBlock(this)" data-blocked="${user.isBlocked}" 
                                    class="p-2 bg-white/5 text-${user.isBlocked ? 'green' : 'red'}-500 hover:bg-white/10 rounded-lg transition-colors border border-white/5" 
                                    title="${user.isBlocked ? 'Unblock' : 'Block'} User">
                                    <i data-lucide="${user.isBlocked ? 'shield-check' : 'ban'}" class="w-4 h-4"></i>
                                </button>
                                <a href="/admin/users/view/${user._id}" class="p-2 bg-white/5 text-apple-gold hover:bg-white/10 rounded-lg transition-colors border border-white/5" title="View Details">
                                    <i data-lucide="eye" class="w-4 h-4"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                `;
            });
            
            if (typeof lucide !== 'undefined') lucide.createIcons();
            paginationSection.style.display = searchQuery ? "none" : "flex";

        } catch (error) {
            console.error("Live search error:", error);
        }
    }

    const debouncedSearch = debounce(liveSearch, 400);
    searchInput.addEventListener("input", debouncedSearch);

    if (clearSearchBtn) {
        clearSearchBtn.addEventListener('click', function () {
            searchInput.value = '';
            updateClearBtnVisibility();
            window.location.href = `/admin/users?page=1&sort=<%= userDb.selectedSort || '' %>&filter=<%= userDb.selectedFilter || '' %>&search=`;
        });
    }

    window.toggleBlock = async (btn) => {
        const isBlocked = btn.getAttribute('data-blocked') === 'true';
        const action = isBlocked ? 'Unblock' : 'Block';
        const confirmBtnColor = isBlocked ? '#22c55e' : '#ef4444'; 

        Swal.fire({
            title: `Are you sure?`,
            text: `Do you really want to ${action.toLowerCase()} this user?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: confirmBtnColor,
            cancelButtonColor: '#1a231e',
            confirmButtonText: `Yes, ${action} User`,
            background: '#1e2a22',
            color: '#E6CFA7',
            customClass: {
                popup: 'border border-white/10 rounded-2xl shadow-xl'
            }
        }).then(async (result) => {
            if (result.isConfirmed) {
                try {
                    const res = await fetch(`/admin/users/toggle-block/${btn.closest('tr').dataset.userid}/${isBlocked ? 'unblock' : 'block'}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const data = await res.json();
                    if (data.success) {
                        window.location.reload();
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: data.message, background: '#1e2a22', color: '#E6CFA7' });
                    }
                } catch (error) {
                    console.error('Error toggling block status:', error);
                }
            }
        });
    }

    document.addEventListener('click', function (e) {
        const filterWrap = document.getElementById('userFilterWrap');
        if (filterWrap && !filterWrap.contains(e.target)) document.getElementById('userFilterMenu').classList.add('hidden');
        const sortWrap = document.getElementById('userSortWrap');
        if (sortWrap && !sortWrap.contains(e.target)) document.getElementById('userSortMenu').classList.add('hidden');
    });
</script>