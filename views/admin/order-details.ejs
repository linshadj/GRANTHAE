<div class="space-y-6">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-xs text-apple-text-gray mb-1">
                <a href="/admin/orders" class="hover:text-apple-gold transition-colors">Orders</a>
                <i data-lucide="chevron-right" class="w-3 h-3"></i>
                <span>Details</span>
            </div>
            <h1 class="text-2xl font-bold text-apple-dark flex items-center gap-3">
                Order #ORD-7728
                <span
                    class="px-2 py-0.5 rounded text-xs font-bold bg-yellow-500/10 text-yellow-500 border border-yellow-500/20">Pending</span>
            </h1>
            <p class="text-apple-text-gray text-sm">Placed on Oct 24, 2026 at 10:42 AM</p>
        </div>
        <div class="flex gap-2">
            <button
                class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-2">
                <i data-lucide="printer" class="w-4 h-4"></i> Print Invoice
            </button>
            <button
                class="bg-apple-gold text-apple-gray px-4 py-2 rounded-lg font-bold text-sm shadow-lg shadow-apple-gold/20 hover:brightness-110 transition-all flex items-center gap-2">
                <i data-lucide="truck" class="w-4 h-4"></i> Mark as Shipped
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content (Items) -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Order Items -->
            <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-white/5">
                    <h3 class="font-bold text-lg text-apple-dark">Order Items</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-white/5">
                            <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                                <th class="px-6 py-4">Product</th>
                                <th class="px-6 py-4 text-center">Price</th>
                                <th class="px-6 py-4 text-center">Quantity</th>
                                <th class="px-6 py-4 text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <tr>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-4">
                                        <img src="/images/book1.jpg"
                                            class="w-12 h-16 object-cover rounded shadow-sm opacity-90" alt="Book">
                                        <div>
                                            <div class="font-bold text-apple-dark">The Design of Everyday Things</div>
                                            <div class="text-xs text-apple-text-gray">SKU: BK-2938</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center text-apple-text-gray">$28.00</td>
                                <td class="px-6 py-4 text-center text-apple-dark font-medium">1</td>
                                <td class="px-6 py-4 text-right font-bold text-apple-dark">$28.00</td>
                            </tr>
                            <tr>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-4">
                                        <img src="/images/book3.jpg"
                                            class="w-12 h-16 object-cover rounded shadow-sm opacity-90" alt="Book">
                                        <div>
                                            <div class="font-bold text-apple-dark">Clean Code</div>
                                            <div class="text-xs text-apple-text-gray">SKU: BK-5521</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center text-apple-text-gray">$17.00</td>
                                <td class="px-6 py-4 text-center text-apple-dark font-medium">1</td>
                                <td class="px-6 py-4 text-right font-bold text-apple-dark">$17.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payment & Totals -->
            <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm p-6">
                <h3 class="font-bold text-lg text-apple-dark mb-4">Payment Summary</h3>
                <div class="flex flex-col md:flex-row justify-between gap-6">
                    <div class="space-y-2">
                        <p class="text-sm text-apple-text-gray">Payment Method</p>
                        <div class="flex items-center gap-2 font-medium text-apple-dark">
                            <i data-lucide="credit-card" class="w-4 h-4"></i> Visa ending in 4242
                        </div>
                    </div>
                    <div class="w-full md:w-64 space-y-3">
                        <div class="flex justify-between text-sm">
                            <span class="text-apple-text-gray">Subtotal</span>
                            <span class="text-apple-dark font-medium">$45.00</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-apple-text-gray">Shipping</span>
                            <span class="text-apple-dark font-medium">$5.00</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-apple-text-gray">Tax (5%)</span>
                            <span class="text-apple-dark font-medium">$2.25</span>
                        </div>
                        <div class="border-t border-white/10 pt-3 flex justify-between items-center">
                            <span class="font-bold text-apple-dark">Total</span>
                            <span class="font-bold text-xl text-apple-gold">$52.25</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="space-y-6">
            <!-- Customer Info -->
            <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm p-6">
                <h3 class="font-bold text-lg text-apple-dark mb-4">Customer</h3>
                <div class="flex items-center gap-3 mb-4">
                    <div
                        class="w-10 h-10 rounded-full bg-apple-blue/20 flex items-center justify-center text-sm text-apple-blue font-bold">
                        JD</div>
                    <div class="overflow-hidden">
                        <div class="font-bold text-apple-dark truncate">John Doe</div>
                        <div class="text-xs text-apple-text-gray truncate">john.doe@example.com</div>
                    </div>
                </div>
                <div class="py-4 border-t border-white/5">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-xs text-apple-text-gray font-bold uppercase tracking-wider">Contact</span>
                    </div>
                    <div class="text-sm text-apple-dark">+1 (555) 123-4567</div>
                </div>
                <div class="pt-2">
                    <a href="/admin/users"
                        class="text-xs text-apple-blue hover:text-apple-gold transition-colors font-medium">View
                        Profile</a>
                </div>
            </div>

            <!-- Shipping Info -->
            <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm p-6">
                <h3 class="font-bold text-lg text-apple-dark mb-4">Shipping Address</h3>
                <address class="not-italic text-sm text-apple-text-gray leading-relaxed">
                    <span class="block text-apple-dark font-medium mb-1">Home</span>
                    123 Apple Park Way<br>
                    Cupertino, CA 95014<br>
                    United States
                </address>
                <div class="mt-4 pt-4 border-t border-white/5">
                    <h4 class="text-xs text-apple-text-gray font-bold uppercase tracking-wider mb-2">Billing Address
                    </h4>
                    <p class="text-xs text-apple-text-gray">Same as shipping address</p>
                </div>
            </div>
        </div>
    </div>
</div>