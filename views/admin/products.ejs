<div class="space-y-6">
    <!-- Header Actions -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">Product Management</h1>
            <p class="text-apple-text-gray text-sm">Manage books available for purchase.</p>
        </div>
        <a href="/admin/products/add"
            class="bg-apple-gold text-apple-gray px-4 py-2 rounded-lg font-bold text-sm shadow-lg shadow-apple-gold/20 hover:brightness-110 transition-all flex items-center gap-2">
            <i data-lucide="plus" class="w-4 h-4"></i> Add New Product
        </a>
    </div>

    <!-- Products Table -->
    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Marketplace Inventory</h3>
            <div class="flex gap-2">
                <button
                    class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5">
                    Filter: All
                </button>
                <div class="relative">
                    <i data-lucide="search"
                        class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray"></i>
                    <input type="text" placeholder="Search Products..."
                        class="pl-9 pr-4 py-2 text-xs bg-white/5 border border-white/5 rounded-lg focus:outline-none focus:ring-2 focus:ring-apple-gold/50 text-apple-dark placeholder-apple-text-gray/50">
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-white/5">
                    <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                        <th class="px-6 py-4">Product Details</th>
                        <th class="px-6 py-4">Category</th>
                        <th class="px-6 py-4">Price</th>
                        <th class="px-6 py-4">Stock</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <!-- Row 1 -->
                    <tr class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <img src="/images/book1.jpg"
                                    class="w-10 h-14 object-cover rounded shadow-sm opacity-90 group-hover:opacity-100"
                                    alt="Book">
                                <div>
                                    <div class="font-bold text-apple-dark">The Design of Everyday Things</div>
                                    <div class="text-xs text-apple-text-gray">SKU: BK-2938</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-apple-text-gray">Design</td>
                        <td class="px-6 py-4 font-bold text-apple-dark">$28.00</td>
                        <td class="px-6 py-4 text-apple-text-gray">124</td>
                        <td class="px-6 py-4">
                            <span
                                class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-green-500/10 text-green-400">In
                                Stock</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <button class="text-apple-text-gray hover:text-apple-gold transition-colors">
                                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                                </button>
                                <button class="text-apple-text-gray hover:text-red-400 transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <img src="/images/book2.jpg"
                                    class="w-10 h-14 object-cover rounded shadow-sm opacity-90 group-hover:opacity-100"
                                    alt="Book">
                                <div>
                                    <div class="font-bold text-apple-dark">Steve Jobs</div>
                                    <div class="text-xs text-apple-text-gray">SKU: BK-9921</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-apple-text-gray">Biography</td>
                        <td class="px-6 py-4 font-bold text-apple-dark">$35.00</td>
                        <td class="px-6 py-4 text-apple-text-gray">12</td>
                        <td class="px-6 py-4">
                            <span
                                class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-yellow-500/10 text-yellow-500">Low
                                Stock</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <button class="text-apple-text-gray hover:text-apple-gold transition-colors">
                                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                                </button>
                                <button class="text-apple-text-gray hover:text-red-400 transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>