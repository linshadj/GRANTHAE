<%
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', {
        maximumFractionDigits: 2
    });

    const reportQuery = new URLSearchParams({
        period: filters.period,
        startDate: filters.startDate,
        endDate: filters.endDate
    }).toString();

    const paymentBadgeClass = (status) => {
        if (status === 'Success' || status === 'Refunded') return 'text-green-600 bg-green-500/10 border-green-500/20';
        if (status === 'Failed') return 'text-red-600 bg-red-500/10 border-red-500/20';
        return 'text-yellow-600 bg-yellow-500/10 border-yellow-500/20';
    };
%>

<div class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark font-serif">Sales Reports</h1>
            <p class="text-sm text-apple-text-gray mt-1">
                <%= new Date(report.startDate).toLocaleDateString('en-IN') %> to <%= new Date(report.endDate).toLocaleDateString('en-IN') %>
            </p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="/admin/reports/download/pdf?<%= reportQuery %>"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 text-apple-dark border border-white/10 hover:bg-white/10 transition-colors text-xs font-bold">
                <i data-lucide="file-text" class="w-4 h-4"></i>
                PDF
            </a>
            <a href="/admin/reports/download/excel?<%= reportQuery %>"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 text-apple-dark border border-white/10 hover:bg-white/10 transition-colors text-xs font-bold">
                <i data-lucide="table" class="w-4 h-4"></i>
                Excel
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-apple-card border border-white/10 p-6 rounded-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Net Sales</p>
                    <h3 class="text-2xl font-bold text-apple-dark mt-2">&#8377;<%= formatAmount(report.summary.netSales) %></h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-apple-gold/10 flex items-center justify-center text-apple-gold">
                    <i data-lucide="indian-rupee" class="w-5 h-5"></i>
                </div>
            </div>
        </div>
        <div class="bg-apple-card border border-white/10 p-6 rounded-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Sales Count</p>
                    <h3 class="text-2xl font-bold text-apple-dark mt-2"><%= report.summary.salesCount %></h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-apple-blue/10 flex items-center justify-center text-apple-blue">
                    <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                </div>
            </div>
        </div>
        <div class="bg-apple-card border border-white/10 p-6 rounded-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Coupon Deductions</p>
                    <h3 class="text-2xl font-bold text-purple-600 mt-2">&#8377;<%= formatAmount(report.summary.couponDiscount) %></h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-500">
                    <i data-lucide="ticket" class="w-5 h-5"></i>
                </div>
            </div>
        </div>
        <div class="bg-apple-card border border-white/10 p-6 rounded-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Total Discounts</p>
                    <h3 class="text-2xl font-bold text-red-600 mt-2">&#8377;<%= formatAmount(report.summary.totalDiscount) %></h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500">
                    <i data-lucide="badge-percent" class="w-5 h-5"></i>
                </div>
            </div>
        </div>
    </div>

    <form method="GET" action="/admin/reports" class="bg-apple-card border border-white/10 rounded-2xl p-5">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-4 items-end">
            <div class="lg:col-span-3">
                <label for="report-period" class="block text-xs font-bold text-apple-text-gray uppercase tracking-wider mb-2">Period</label>
                <select name="period" id="report-period"
                    class="w-full h-11 px-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark focus:ring-2 focus:ring-apple-gold/20 focus:border-apple-gold outline-none">
                    <option class="text-black" value="daily" <%= filters.period === 'daily' ? 'selected' : '' %>>Daily</option>
                    <option class="text-black" value="weekly" <%= filters.period === 'weekly' ? 'selected' : '' %>>Weekly</option>
                    <option class="text-black" value="yearly" <%= filters.period === 'yearly' ? 'selected' : '' %>>Yearly</option>
                    <option class="text-black" value="custom" <%= filters.period === 'custom' ? 'selected' : '' %>>Custom</option>
                </select>
            </div>

            <div class="lg:col-span-3">
                <label for="startDate" class="block text-xs font-bold text-apple-text-gray uppercase tracking-wider mb-2">Start Date</label>
                <input id="startDate" type="date" name="startDate" value="<%= filters.startDate %>"
                    class="w-full h-11 px-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark focus:ring-2 focus:ring-apple-gold/20 focus:border-apple-gold outline-none">
            </div>

            <div class="lg:col-span-3">
                <label for="endDate" class="block text-xs font-bold text-apple-text-gray uppercase tracking-wider mb-2">End Date</label>
                <input id="endDate" type="date" name="endDate" value="<%= filters.endDate %>"
                    class="w-full h-11 px-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark focus:ring-2 focus:ring-apple-gold/20 focus:border-apple-gold outline-none">
            </div>

            <div class="lg:col-span-1">
                <label class="block text-xs font-bold text-apple-text-gray uppercase tracking-wider mb-2">Rows</label>
                <div class="h-11 px-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark flex items-center">
                    <%= report.rows.length %>
                </div>
            </div>

            <div class="lg:col-span-2">
                <button type="submit"
                    class="w-full h-11 px-4 bg-apple-gold text-black text-sm font-bold rounded-xl hover:brightness-110 transition-all flex items-center justify-center gap-2 whitespace-nowrap">
                    <i data-lucide="bar-chart-2" class="w-4 h-4"></i>
                    Generate
                </button>
            </div>
        </div>
    </form>

    <div class="bg-apple-card border border-white/10 rounded-2xl overflow-hidden">
        <div class="p-6 border-b border-white/10 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h2 class="text-lg font-bold text-apple-dark font-serif">Order Breakdown</h2>
                <p class="text-xs text-apple-text-gray mt-1">Discounts include product/category offers and coupon deductions.</p>
            </div>
            <span class="text-xs font-bold uppercase tracking-widest text-apple-text-gray">
                <%= report.rows.length %> order<%= report.rows.length === 1 ? '' : 's' %>
            </span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left" style="min-width: 1120px;">
                <thead class="bg-white/5 text-xs text-apple-text-gray uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Order</th>
                        <th class="px-6 py-4">Date</th>
                        <th class="px-6 py-4">Customer</th>
                        <th class="px-6 py-4">Payment</th>
                        <th class="px-6 py-4 text-right">Order Amount</th>
                        <th class="px-6 py-4 text-right">Offer Discount</th>
                        <th class="px-6 py-4 text-right">Coupon</th>
                        <th class="px-6 py-4 text-right">Net Sales</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/10">
                    <% if (report.rows.length === 0) { %>
                        <tr>
                            <td colspan="8" class="px-6 py-14 text-center text-apple-text-gray">
                                <i data-lucide="file-search" class="w-10 h-10 mx-auto mb-3 opacity-40"></i>
                                No sales found for this range.
                            </td>
                        </tr>
                    <% } %>

                    <% report.rows.forEach(row => { %>
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4">
                                <a href="/admin/orders/view/<%= row.mongoId %>" class="font-bold text-apple-dark hover:text-apple-gold">
                                    <%= row.orderId %>
                                </a>
                                <div class="text-xs text-apple-text-gray mt-0.5"><%= row.status %></div>
                            </td>
                            <td class="px-6 py-4 text-sm text-apple-text-gray whitespace-nowrap">
                                <%= new Date(row.date).toLocaleDateString('en-IN') %>
                            </td>
                            <td class="px-6 py-4 text-sm text-apple-dark">
                                <span class="block max-w-xs truncate"><%= row.customerName || 'Customer' %></span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full border text-xs font-bold whitespace-nowrap <%= paymentBadgeClass(row.paymentStatus) %>">
                                    <%= row.paymentMethod %> / <%= row.paymentStatus %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right text-sm font-semibold text-apple-dark whitespace-nowrap">
                                &#8377;<%= formatAmount(row.subtotal) %>
                            </td>
                            <td class="px-6 py-4 text-right text-sm font-semibold text-red-600 whitespace-nowrap">
                                &#8377;<%= formatAmount(row.offerDiscount) %>
                            </td>
                            <td class="px-6 py-4 text-right text-sm font-semibold text-purple-600 whitespace-nowrap">
                                &#8377;<%= formatAmount(row.couponDiscount) %>
                            </td>
                            <td class="px-6 py-4 text-right text-sm font-bold text-apple-dark whitespace-nowrap">
                                &#8377;<%= formatAmount(row.totalAmount) %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
                <tfoot class="bg-white/5 border-t border-white/10">
                    <tr class="text-xs font-bold uppercase tracking-wider">
                        <td colspan="4" class="px-6 py-4 text-right text-apple-text-gray">Totals</td>
                        <td class="px-6 py-4 text-right text-apple-dark whitespace-nowrap">&#8377;<%= formatAmount(report.summary.orderAmount) %></td>
                        <td class="px-6 py-4 text-right text-red-600 whitespace-nowrap">&#8377;<%= formatAmount(Number(report.summary.totalDiscount || 0) - Number(report.summary.couponDiscount || 0)) %></td>
                        <td class="px-6 py-4 text-right text-purple-600 whitespace-nowrap">&#8377;<%= formatAmount(report.summary.couponDiscount) %></td>
                        <td class="px-6 py-4 text-right text-apple-dark whitespace-nowrap">&#8377;<%= formatAmount(report.summary.netSales) %></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
