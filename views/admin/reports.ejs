<%
    const formatAmount = (amount) => Number(amount || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 });
    const reportQuery = new URLSearchParams({
        period: filters.period,
        startDate: filters.startDate,
        endDate: filters.endDate
    }).toString();
%>

<div class="space-y-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-apple-card border border-white/5 p-6 rounded-2xl">
            <div class="flex justify-between">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Net Sales</p>
                    <h3 class="text-2xl font-bold text-apple-dark mt-1">₹<%= formatAmount(report.summary.netSales) %></h3>
                </div>
                <i data-lucide="indian-rupee" class="w-5 h-5 text-apple-gold"></i>
            </div>
            <div class="mt-4 h-1 w-full bg-white/5 rounded-full overflow-hidden">
                <div class="h-full bg-apple-gold w-3/4"></div>
            </div>
        </div>
        <div class="bg-apple-card border border-white/5 p-6 rounded-2xl">
            <div class="flex justify-between">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Sales Count</p>
                    <h3 class="text-2xl font-bold text-apple-dark mt-1"><%= report.summary.salesCount %></h3>
                </div>
                <i data-lucide="shopping-cart" class="w-5 h-5 text-apple-blue"></i>
            </div>
            <div class="mt-4 h-1 w-full bg-white/5 rounded-full overflow-hidden">
                <div class="h-full bg-apple-blue w-1/2"></div>
            </div>
        </div>
        <div class="bg-apple-card border border-white/5 p-6 rounded-2xl">
            <div class="flex justify-between">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Coupon Deductions</p>
                    <h3 class="text-2xl font-bold text-apple-dark mt-1">₹<%= formatAmount(report.summary.couponDiscount) %></h3>
                </div>
                <i data-lucide="ticket" class="w-5 h-5 text-purple-400"></i>
            </div>
            <div class="mt-4 h-1 w-full bg-white/5 rounded-full overflow-hidden">
                <div class="h-full bg-purple-400 w-2/3"></div>
            </div>
        </div>
        <div class="bg-apple-card border border-white/5 p-6 rounded-2xl">
            <div class="flex justify-between">
                <div>
                    <p class="text-xs font-bold text-apple-text-gray uppercase tracking-widest">Total Discounts</p>
                    <h3 class="text-2xl font-bold text-apple-dark mt-1">₹<%= formatAmount(report.summary.totalDiscount) %></h3>
                </div>
                <i data-lucide="badge-percent" class="w-5 h-5 text-red-400"></i>
            </div>
            <div class="mt-4 h-1 w-full bg-white/5 rounded-full overflow-hidden">
                <div class="h-full bg-red-400 w-[70%]"></div>
            </div>
        </div>
    </div>

    <div class="bg-apple-card border border-white/5 rounded-2xl overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col lg:flex-row justify-between gap-4 lg:items-center">
            <div>
                <h3 class="text-lg font-bold text-apple-dark font-serif">Sales Report</h3>
                <p class="text-xs text-apple-text-gray mt-1">
                    <%= new Date(report.startDate).toLocaleDateString('en-IN') %> to <%= new Date(report.endDate).toLocaleDateString('en-IN') %>
                </p>
            </div>
            <div class="flex flex-wrap gap-2">
                <a href="/admin/reports/download/pdf?<%= reportQuery %>" class="px-4 py-2 bg-white/5 text-apple-text-gray border border-white/10 rounded-lg hover:bg-white/10 transition-colors text-xs font-bold flex items-center gap-2">
                    <i data-lucide="file-text" class="w-4 h-4"></i> PDF
                </a>
                <a href="/admin/reports/download/excel?<%= reportQuery %>" class="px-4 py-2 bg-white/5 text-apple-text-gray border border-white/10 rounded-lg hover:bg-white/10 transition-colors text-xs font-bold flex items-center gap-2">
                    <i data-lucide="table" class="w-4 h-4"></i> Excel
                </a>
            </div>
        </div>

        <form method="GET" action="/admin/reports" class="p-6 border-b border-white/5 space-y-4">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <div class="lg:col-span-3 w-full">
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5">Period</label>
                    <select name="period" id="report-period" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white focus:ring-2 focus:ring-apple-gold/20 outline-none">
                        <option class="text-black" value="daily" <%= filters.period === 'daily' ? 'selected' : '' %>>Daily</option>
                        <option class="text-black" value="weekly" <%= filters.period === 'weekly' ? 'selected' : '' %>>Weekly</option>
                        <option class="text-black" value="yearly" <%= filters.period === 'yearly' ? 'selected' : '' %>>Yearly</option>
                        <option class="text-black" value="custom" <%= filters.period === 'custom' ? 'selected' : '' %>>Custom</option>
                    </select>
                </div>
                <div class="lg:col-span-5 w-full">
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5">Date Range</label>
                    <div class="flex items-center gap-2">
                        <input type="date" name="startDate" value="<%= filters.startDate %>" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white focus:ring-2 focus:ring-apple-gold/20 outline-none">
                        <span class="text-gray-400">-</span>
                        <input type="date" name="endDate" value="<%= filters.endDate %>" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white focus:ring-2 focus:ring-apple-gold/20 outline-none">
                    </div>
                </div>
                <div class="lg:col-span-2 w-full">
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5">Rows</label>
                    <div class="px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white h-[38px]"><%= report.rows.length %> orders</div>
                </div>
                <div class="lg:col-span-2 flex items-end w-full">
                    <button type="submit" class="w-full px-4 py-2 bg-apple-gold text-black text-sm font-bold rounded-lg hover:brightness-110 transition-all shadow-lg flex items-center justify-center gap-2 h-[38px] whitespace-nowrap">
                        <i data-lucide="bar-chart-2" class="w-4 h-4"></i> Generate
                    </button>
                </div>
            </div>
        </form>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-white/5 text-xs text-apple-text-gray uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Order</th>
                        <th class="px-6 py-4">Date</th>
                        <th class="px-6 py-4">Customer</th>
                        <th class="px-6 py-4">Payment</th>
                        <th class="px-6 py-4 text-right">Order Amount</th>
                        <th class="px-6 py-4 text-right">Discounts</th>
                        <th class="px-6 py-4 text-right">Coupon</th>
                        <th class="px-6 py-4 text-right">Net Sales</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% if (report.rows.length === 0) { %>
                        <tr>
                            <td colspan="8" class="px-6 py-12 text-center text-apple-text-gray">
                                <i data-lucide="file-search" class="w-10 h-10 mx-auto mb-3 opacity-30"></i>
                                No sales found for this range.
                            </td>
                        </tr>
                    <% } %>
                    <% report.rows.forEach(row => { %>
                        <tr class="group hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4">
                                <a href="/admin/orders/view/<%= row.mongoId %>" class="font-bold text-apple-dark hover:text-apple-gold"><%= row.orderId %></a>
                                <div class="text-[10px] text-apple-text-gray"><%= row.status %></div>
                            </td>
                            <td class="px-6 py-4 text-sm text-apple-text-gray"><%= new Date(row.date).toLocaleDateString('en-IN') %></td>
                            <td class="px-6 py-4 text-sm text-apple-text-gray"><%= row.customerName || 'Customer' %></td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 text-xs font-bold rounded-full <%= row.paymentStatus === 'Success' || row.paymentStatus === 'Refunded' ? 'text-green-400 bg-green-500/10' : 'text-yellow-400 bg-yellow-500/10' %>">
                                    <%= row.paymentMethod %> / <%= row.paymentStatus %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right text-sm text-apple-text-gray">₹<%= formatAmount(row.subtotal) %></td>
                            <td class="px-6 py-4 text-right text-sm text-red-400">₹<%= formatAmount(row.offerDiscount + row.couponDiscount) %></td>
                            <td class="px-6 py-4 text-right text-sm text-purple-400">₹<%= formatAmount(row.couponDiscount) %></td>
                            <td class="px-6 py-4 text-right text-sm font-bold text-apple-dark">₹<%= formatAmount(row.totalAmount) %></td>
                        </tr>
                    <% }) %>
                </tbody>
                <tfoot class="bg-white/5">
                    <tr class="text-xs font-bold uppercase tracking-wider">
                        <td colspan="4" class="px-6 py-4 text-right text-apple-text-gray">Totals</td>
                        <td class="px-6 py-4 text-right text-apple-dark">₹<%= formatAmount(report.summary.orderAmount) %></td>
                        <td class="px-6 py-4 text-right text-red-400">₹<%= formatAmount(report.summary.totalDiscount) %></td>
                        <td class="px-6 py-4 text-right text-purple-400">₹<%= formatAmount(report.summary.couponDiscount) %></td>
                        <td class="px-6 py-4 text-right text-apple-dark">₹<%= formatAmount(report.summary.netSales) %></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
