<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div class="flex gap-2">
            <a href="/admin/categories/add" class="px-4 py-2 bg-apple-gold text-[#1a231e] font-bold rounded-lg hover:bg-yellow-600 transition-colors text-sm flex items-center gap-2">
                <i data-lucide="plus" class="w-4 h-4"></i> Add Category
            </a>
        </div>
    </div>

    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Categories List</h3>
            <div class="flex gap-2">
                <!-- Filter Dropdown -->
                <div class="relative" id="catFilterWrap">
                    <button onclick="document.getElementById('catFilterMenu').classList.toggle('hidden')" class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5 h-10 min-w-max whitespace-nowrap">
                        <i data-lucide="filter" class="w-3.5 h-3.5"></i>
                        <span id="catFilterLabel">
                            <% const filterLabels = { 'all': 'All', 'active': 'Active', 'inactive': 'Inactive', 'deleted': 'Soft Deleted' }; %>
                            <%= typeof selectedFilter !== 'undefined' ? filterLabels[selectedFilter] || 'Filter By' : 'Filter By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="catFilterMenu" class="hidden absolute right-0 mt-2 w-48 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/categories?page=1&sort=<%= selectedSort || '' %>&search=<%= searchQuery || '' %>&filter=all" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="layers" class="w-3.5 h-3.5"></i> All
                        </a>
                        <a href="/admin/categories?page=1&sort=<%= selectedSort || '' %>&search=<%= searchQuery || '' %>&filter=active" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="check-circle" class="w-3.5 h-3.5 text-green-400"></i> Active
                        </a>
                        <a href="/admin/categories?page=1&sort=<%= selectedSort || '' %>&search=<%= searchQuery || '' %>&filter=inactive" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="x-circle" class="w-3.5 h-3.5 text-orange-400"></i> Inactive
                        </a>
                        <a href="/admin/categories?page=1&sort=<%= selectedSort || '' %>&search=<%= searchQuery || '' %>&filter=deleted" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="trash" class="w-3.5 h-3.5 text-red-400"></i> Soft Deleted
                        </a>
                    </div>
                </div>

                <!-- Sort Dropdown -->
                <div class="relative" id="catSortWrap">
                    <button onclick="document.getElementById('catSortMenu').classList.toggle('hidden')" class="px-4 py-2 text-xs font-semibold bg-white/5 text-apple-text-gray rounded-lg hover:bg-white/10 transition-colors border border-white/5 flex items-center gap-1.5 h-10 min-w-max whitespace-nowrap">
                        <i data-lucide="arrow-up-down" class="w-3.5 h-3.5"></i>
                        <span id="catSortLabel">
                            <% const sortLabels = { 'a-z': 'Name (A-Z)', 'z-a': 'Name (Z-A)', 'newest': 'Newest First', 'oldest': 'Oldest First' }; %>
                            <%= sortLabels[selectedSort] || 'Sort By' %>
                        </span>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </button>
                    <div id="catSortMenu" class="hidden absolute right-0 mt-2 w-48 bg-[#1e2a22] border border-white/10 rounded-xl shadow-2xl z-50 py-1">
                        <a href="/admin/categories?page=<%= currentPage %>&search=<%= searchQuery || '' %>&filter=<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>&sort=a-z" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="a-arrow-down" class="w-3.5 h-3.5"></i> Name (A-Z)
                        </a>
                        <a href="/admin/categories?page=<%= currentPage %>&search=<%= searchQuery || '' %>&filter=<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>&sort=z-a" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="a-arrow-up" class="w-3.5 h-3.5"></i> Name (Z-A)
                        </a>
                        <div class="border-t border-white/5 my-1"></div>
                        <a href="/admin/categories?page=<%= currentPage %>&search=<%= searchQuery || '' %>&filter=<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>&sort=newest" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="calendar-clock" class="w-3.5 h-3.5"></i> Newest First
                        </a>
                        <a href="/admin/categories?page=<%= currentPage %>&search=<%= searchQuery || '' %>&filter=<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>&sort=oldest" class="w-full text-left px-4 py-2 text-xs text-apple-text-gray hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2">
                            <i data-lucide="calendar" class="w-3.5 h-3.5"></i> Oldest First
                        </a>
                    </div>
                </div>

                <div class="relative flex items-center">
                    <i data-lucide="search" class="absolute left-3 w-3.5 h-3.5 text-apple-text-gray"></i>
                    <input id="searchInput" type="text" value="<%= searchQuery || '' %>" placeholder="Search Categories..."
                        class="pl-10 pr-10 py-3 text-xs h-10 w-64 bg-white/5 border border-white/5 rounded-lg focus:outline-none focus:ring-1 focus:ring-apple-gold/50 text-white placeholder-apple-text-gray/50 transition-all hover:bg-white/10">
                    <button id="clearSearchBtn" class="hidden absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 text-xs font-semibold rounded-lg text-apple-text-gray hover:bg-white/10 transition-colors" title="Clear search">
                        <i data-lucide="x" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-white/5">
                    <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                        <th class="px-6 py-4">Image</th>
                        <th class="px-6 py-4">Name</th>
                        <th class="px-6 py-4">Slug</th>
                        <th class="px-6 py-4">Featured</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="categoriesTableBody" class="divide-y divide-white/5">
                    <% if (categories.length === 0) { %>
                        <tr>
                            <td colspan="6" class="px-6 py-4 text-center text-apple-text-gray">No categories found</td>
                        </tr>
                    <% } else { %>
                        <% categories.forEach(category => { %>
                            <tr class="group hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="w-10 h-10 rounded overflow-hidden bg-white/5 flex items-center justify-center">
                                        <% if(category.coverImage) { %>
                                            <img src="<%= category.coverImage %>" alt="<%= category.name %>" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <i data-lucide="image" class="w-5 h-5 text-gray-500"></i>
                                        <% } %>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-medium text-apple-dark whitespace-nowrap">
                                    <%= category.name %>
                                </td>
                                <td class="px-6 py-4 text-apple-text-gray text-xs">
                                    <%= category.slug %>
                                </td>
                                <td class="px-6 py-4">
                                    <% if(category.isFeatured) { %>
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-amber-500/10 text-amber-500 border border-amber-500/20">
                                            Featured
                                        </span>
                                    <% } else { %>
                                        <span class="text-apple-text-gray/30 text-[10px]">No</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold <%= category.isDeleted ? 'bg-red-500/10 text-red-400' : (category.isBlocked ? 'bg-orange-500/10 text-orange-400' : 'bg-green-500/10 text-green-400') %>">
                                        <%= category.isDeleted ? 'Soft Deleted' : (category.isBlocked ? 'Inactive' : 'Active') %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right space-x-2 w-64">
                                    <a href="/admin/categories/edit/<%= category._id %>"
                                        class="px-3 py-1.5 inline-block text-xs font-bold rounded-lg transition-all border border-blue-500/20 bg-blue-500/10 text-blue-400 hover:bg-blue-500/20">
                                        <i data-lucide="edit" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i> Edit
                                    </a>
                                    
                                    <% if (category.isDeleted) { %>
                                        <button onclick="toggleDelete('<%= category._id %>', false)"
                                            class="px-3 py-1.5 text-xs font-bold rounded-lg transition-all border border-green-500/20 bg-green-500/10 text-green-400 hover:bg-green-500/20">
                                            <i data-lucide="rotate-ccw" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i> Restore
                                        </button>
                                    <% } else { %>
                                        <button onclick="toggleDelete('<%= category._id %>', true)"
                                            class="px-3 py-1.5 text-xs font-bold rounded-lg transition-all border border-red-500/20 bg-red-500/10 text-red-400 hover:bg-red-500/20">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5 inline-block align-middle mr-1"></i> Delete
                                        </button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 0) { %>
        <div class="p-4 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-xs text-apple-text-gray">
                Showing <span class="font-bold text-apple-dark"><%= (currentPage - 1) * 10 + 1 %></span> 
                to <span class="font-bold text-apple-dark"><%= Math.min(currentPage * 10, totalCategories) %></span> 
                of <span class="font-bold text-apple-dark"><%= totalCategories %></span> results
            </p>
            <div class="flex items-center gap-1">
                <% for(let i=1; i <=totalPages; i++) { %>
                    <a href="/admin/categories?page=<%= i %>&sort=<%= selectedSort || '' %>&filter=<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>&search=<%= searchQuery || '' %>"
                        class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-colors <%= i === currentPage ? 'bg-apple-gold text-[#1a231e] font-bold' : 'text-apple-text-gray hover:bg-white/10' %>">
                        <%= i %>
                    </a>
                <% } %>
            </div>
        </div>
        <% } %>
    </div>
</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const clearSearchBtn = document.getElementById('clearSearchBtn');

    function updateClearBtnVisibility() {
        if (!clearSearchBtn) return;
        clearSearchBtn.classList.toggle('hidden', !searchInput.value.trim());
    }

    searchInput.addEventListener('input', updateClearBtnVisibility);
    updateClearBtnVisibility();

    function debounce(func, delay) {
        let timeout;
        return function (...args) {
            clearTimeout(timeout);
            timeout = setTimeout(() => { func.apply(this, args); }, delay);
        };
    }

    async function liveSearch() {
        const query = searchInput.value.trim();
        const sort = '<%= selectedSort || '' %>';
        const filter = '<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>';
        
        if(query === '') {
            window.location.href = `/admin/categories?page=1&sort=${sort}&filter=${filter}&search=`;
            return;
        }

        window.location.href = `/admin/categories?page=1&sort=${sort}&filter=${filter}&search=${encodeURIComponent(query)}`;
    }

    const debouncedSearch = debounce(liveSearch, 600);

    searchInput.addEventListener("input", function () {
        updateClearBtnVisibility();
        debouncedSearch();
    });

    if (clearSearchBtn) {
        clearSearchBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            e.preventDefault();
            searchInput.value = '';
            const filter = '<%= typeof selectedFilter !== 'undefined' ? selectedFilter : 'all' %>';
            window.location.href = `/admin/categories?page=1&sort=<%= selectedSort || '' %>&filter=${filter}&search=`;
        });
    }

    document.addEventListener('click', function (e) {
        const sortWrap = document.getElementById('catSortWrap');
        if (sortWrap && !sortWrap.contains(e.target)) {
            document.getElementById('catSortMenu').classList.add('hidden');
        }

        const filterWrap = document.getElementById('catFilterWrap');
        if (filterWrap && !filterWrap.contains(e.target)) {
            document.getElementById('catFilterMenu').classList.add('hidden');
        }
    });

    window.toggleDelete = async (id, isDeleting) => {
        const actionText = isDeleting ? 'Delete' : 'Restore';
        const color = isDeleting ? '#ef4444' : '#22c55e';
        
        Swal.fire({
            title: 'Are you sure?',
            text: `Do you want to ${actionText} this category?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: color,
            background: '#1e2a22',
            color: '#E6CFA7',
            confirmButtonText: `Yes, ${actionText}`
        }).then(async (result) => {
            if (result.isConfirmed) {
                try {
                    const res = await fetch(`/admin/categories/toggle-status/${id}/${isDeleting ? 'delete' : 'restore'}`, {
                        method: 'PATCH'
                    });
                    const data = await res.json();
                    if(data.success) {
                        window.location.reload();
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: data.message, background: '#1e2a22', color: '#E6CFA7' });
                    }
                } catch(e) { console.error(e); }
            }
        });
    };
</script>
