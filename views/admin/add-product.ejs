<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Add New Product</h1>
            <p class="text-gray-400">List a new book in the library collection.</p>
        </div>
        <a href="/admin/products"
            class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 transition-colors">
            Cancel
        </a>
    </div>

    <form class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Column: Main Info -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Details -->
            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm space-y-4">
                <h3 class="text-lg font-bold text-white mb-4">Basic Information</h3>

                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Book Title</label>
                    <input type="text" placeholder="e.g. The Design of Everyday Things"
                        class="w-full input-dark outline-none">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">Author</label>
                        <input type="text" placeholder="Author Name" class="w-full input-dark outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">ISBN (Optional)</label>
                        <input type="text" placeholder="ISBN-13" class="w-full input-dark outline-none">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Description</label>
                    <textarea rows="4" placeholder="Book synopsis and details..."
                        class="w-full input-dark outline-none resize-none"></textarea>
                </div>
            </div>

            <!-- Pricing & Inventory -->
            <!-- Product Categorization -->
            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm space-y-4">
                <h3 class="text-lg font-bold text-white mb-4">Product Categorization</h3>

                <div class="grid grid-cols-1 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-1.5">Category</label>
                        <select class="w-full input-dark outline-none appearance-none">
                            <option>Design</option>
                            <option>Technology</option>
                            <option>Business</option>
                            <option>Fiction</option>
                            <option>Biography</option>
                        </select>
                    </div>
                </div>
            </div>
            <!-- Product Variants -->
            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm space-y-4">
                <div class="flex justify-between items-center mb-2">
                    <h3 class="text-lg font-bold text-white">Product Variants</h3>
                    <button type="button" class="text-xs font-bold text-apple-blue hover:underline">+ Add
                        Variant</button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-white/5 text-xs text-gray-400 uppercase tracking-wider">
                            <tr>
                                <th class="px-4 py-2 rounded-l-lg">Type</th>
                                <th class="px-4 py-2">Price ($)</th>
                                <th class="px-4 py-2">SKU</th>
                                <th class="px-4 py-2">Stock</th>
                                <th class="px-4 py-2 rounded-r-lg text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5 text-sm">
                            <tr>
                                <td class="px-4 py-3">
                                    <input type="text" value="Hardcover"
                                        class="bg-transparent border-none text-white focus:ring-0 p-0 w-full placeholder-gray-500"
                                        placeholder="Variant Name">
                                </td>
                                <td class="px-4 py-3">
                                    <input type="number" value="28.00"
                                        class="bg-transparent border-none text-white focus:ring-0 p-0 w-20 placeholder-gray-500"
                                        placeholder="0.00">
                                </td>
                                <td class="px-4 py-3">
                                    <input type="text" value="BK-HC-001"
                                        class="bg-transparent border-none text-apple-text-gray focus:ring-0 p-0 w-24 placeholder-gray-500"
                                        placeholder="SKU-123">
                                </td>
                                <td class="px-4 py-3">
                                    <input type="number" value="15"
                                        class="bg-transparent border-none text-white focus:ring-0 p-0 w-16 placeholder-gray-500"
                                        placeholder="0">
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <button type="button" class="text-gray-500 hover:text-red-400"><i
                                            data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-3">
                                    <input type="text" value="Paperback"
                                        class="bg-transparent border-none text-white focus:ring-0 p-0 w-full placeholder-gray-500"
                                        placeholder="Variant Name">
                                </td>
                                <td class="px-4 py-3">
                                    <input type="number" value="18.50"
                                        class="bg-transparent border-none text-white focus:ring-0 p-0 w-20 placeholder-gray-500"
                                        placeholder="0.00">
                                </td>
                                <td class="px-4 py-3">
                                    <input type="text" value="BK-PB-002"
                                        class="bg-transparent border-none text-apple-text-gray focus:ring-0 p-0 w-24 placeholder-gray-500"
                                        placeholder="SKU-123">
                                </td>
                                <td class="px-4 py-3">
                                    <input type="number" value="42"
                                        class="bg-transparent border-none text-white focus:ring-0 p-0 w-16 placeholder-gray-500"
                                        placeholder="0">
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <button type="button" class="text-gray-500 hover:text-red-400"><i
                                            data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <p class="text-xs text-gray-500 italic mt-2">Default price will be used if no variants are defined.</p>
            </div>
        </div>

        <!-- Right Column: Media -->
        <div class="space-y-6">
            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
                <h3 class="text-lg font-bold text-white mb-4">Cover Image</h3>

                <div
                    class="border-2 border-dashed border-white/10 rounded-xl p-8 text-center hover:bg-white/5 transition-colors cursor-pointer group">
                    <div
                        class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-3 text-gray-400 group-hover:text-white transition-all shadow-sm">
                        <i data-lucide="image-plus" class="w-6 h-6"></i>
                    </div>
                    <p class="text-sm font-medium text-gray-300">Click to upload</p>
                    <p class="text-xs text-gray-500 mt-1">PNG, JPG up to 5MB</p>
                </div>


            </div>

            <div class="bg-apple-card p-6 rounded-2xl border border-white/5 shadow-sm">
                <h3 class="text-lg font-bold text-white mb-4">Visibility</h3>
                <div class="space-y-3">
                    <label
                        class="flex items-center justify-between p-3 rounded-xl border border-white/10 hover:bg-white/5 cursor-pointer">
                        <span class="text-sm font-medium text-gray-300">Published</span>
                        <input type="checkbox" checked
                            class="w-4 h-4 text-apple-blue bg-white/10 border-white/20 rounded focus:ring-apple-blue focus:ring-offset-gray-900">
                    </label>
                    <label
                        class="flex items-center justify-between p-3 rounded-xl border border-white/10 hover:bg-white/5 cursor-pointer">
                        <span class="text-sm font-medium text-gray-300">Featured</span>
                        <input type="checkbox"
                            class="w-4 h-4 text-apple-blue bg-white/10 border-white/20 rounded focus:ring-apple-blue focus:ring-offset-gray-900">
                    </label>
                </div>
            </div>

            <button type="submit" class="w-full btn-primary py-3 shadow-lg shadow-apple-gold/20">
                Publish Product
            </button>
        </div>
    </form>
</div>