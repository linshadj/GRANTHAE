<div class="space-y-6">
    <!-- Header Actions -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-apple-dark">Offers</h1>
            <p class="text-apple-text-gray text-sm">Manage sales and promotional discounts.</p>
        </div>
        <button
            class="bg-apple-gold text-apple-gray px-4 py-2 rounded-lg font-bold text-sm shadow-lg shadow-apple-gold/20 hover:brightness-110 transition-all flex items-center gap-2">
            <i data-lucide="plus" class="w-4 h-4"></i> Create Offer
        </button>
    </div>

    <!-- Offers Table -->
    <div class="bg-apple-card rounded-2xl border border-white/5 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
            <h3 class="font-bold text-lg text-apple-dark">Active Offers</h3>
            <div class="relative">
                <i data-lucide="search"
                    class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-apple-text-gray"></i>
                <input type="text" placeholder="Search Offers..."
                    class="pl-9 pr-4 py-2 text-xs bg-white/5 border border-white/5 rounded-lg focus:outline-none focus:ring-2 focus:ring-apple-gold/50 text-apple-dark placeholder-apple-text-gray/50">
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-white/5">
                    <tr class="text-left text-xs font-bold text-apple-text-gray uppercase tracking-wider">
                        <th class="px-6 py-4">Title</th>
                        <th class="px-6 py-4">Discount</th>
                        <th class="px-6 py-4">Duration</th>
                        <th class="px-6 py-4">Applicable To</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <tr class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="font-bold text-apple-dark">Black Friday Sale</div>
                            <div class="text-xs text-apple-text-gray">Site-wide discount</div>
                        </td>
                        <td class="px-6 py-4 font-bold text-red-400">50% OFF</td>
                        <td class="px-6 py-4 text-apple-text-gray">
                            Nov 24 - Nov 30
                        </td>
                        <td class="px-6 py-4 text-apple-text-gray">All Products</td>
                        <td class="px-6 py-4">
                            <span
                                class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-green-500/10 text-green-400">Active</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <button class="text-apple-text-gray hover:text-apple-gold transition-colors">
                                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                                </button>
                                <button class="text-apple-text-gray hover:text-red-400 transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr class="group hover:bg-white/5 transition-colors">
                        <td class="px-6 py-4">
                            <div class="font-bold text-apple-dark">Summer Reading</div>
                            <div class="text-xs text-apple-text-gray">Discount on fiction</div>
                        </td>
                        <td class="px-6 py-4 font-bold text-blue-400">20% OFF</td>
                        <td class="px-6 py-4 text-apple-text-gray">
                            Jun 01 - Jun 30
                        </td>
                        <td class="px-6 py-4 text-apple-text-gray">Fiction Category</td>
                        <td class="px-6 py-4">
                            <span
                                class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-gray-500/10 text-gray-400">Expired</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <button class="text-apple-text-gray hover:text-apple-gold transition-colors">
                                    <i data-lucide="edit-3" class="w-4 h-4"></i>
                                </button>
                                <button class="text-apple-text-gray hover:text-red-400 transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>