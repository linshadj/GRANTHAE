<div class="max-w-4xl space-y-8">

    <!-- General Settings -->
    <div class="bg-apple-card border border-white/5 rounded-2xl p-8 shadow-sm">
        <div class="flex items-center gap-4 mb-6">
            <div class="p-3 bg-apple-blue/10 rounded-xl text-apple-blue">
                <i data-lucide="globe" class="w-6 h-6"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-apple-dark font-serif">General Information</h2>
                <p class="text-sm text-apple-text-gray">Platform identity and SEO settings.</p>
            </div>
        </div>

        <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label
                        class="block text-xs font-semibold text-apple-text-gray uppercase tracking-wider mb-2">Platform
                        Name</label>
                    <input type="text" value="GRANTHAE"
                        class="w-full px-4 py-2.5 bg-apple-gray border border-white/10 rounded-xl text-apple-dark focus:border-apple-gold focus:ring-1 focus:ring-apple-gold outline-none transition-all">
                </div>
                <div>
                    <label
                        class="block text-xs font-semibold text-apple-text-gray uppercase tracking-wider mb-2">Support
                        Email</label>
                    <input type="email" value="support@granthae.com"
                        class="w-full px-4 py-2.5 bg-apple-gray border border-white/10 rounded-xl text-apple-dark focus:border-apple-gold focus:ring-1 focus:ring-apple-gold outline-none transition-all">
                </div>
            </div>
            <div>
                <label class="block text-xs font-semibold text-apple-text-gray uppercase tracking-wider mb-2">Meta
                    Description</label>
                <textarea rows="3"
                    class="w-full px-4 py-2.5 bg-apple-gray border border-white/10 rounded-xl text-apple-dark focus:border-apple-gold focus:ring-1 focus:ring-apple-gold outline-none transition-all">Peer-to-peer library and book rental platform.</textarea>
            </div>
            <div class="flex justify-end">
                <button type="button"
                    class="px-6 py-2 bg-apple-gold text-apple-gray font-bold rounded-lg hover:brightness-110 transition-all">Save
                    Changes</button>
            </div>
        </form>
    </div>

    <!-- Security & Maintenance -->
    <div class="bg-apple-card border border-white/5 rounded-2xl p-8 shadow-sm">
        <div class="flex items-center gap-4 mb-6">
            <div class="p-3 bg-red-500/10 rounded-xl text-red-400">
                <i data-lucide="shield-alert" class="w-6 h-6"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-apple-dark font-serif">System Control</h2>
                <p class="text-sm text-apple-text-gray">Maintenance mode and access restriction.</p>
            </div>
        </div>

        <div class="space-y-6">
            <div class="flex items-center justify-between p-4 bg-apple-gray rounded-xl border border-white/5">
                <div>
                    <h3 class="font-medium text-apple-dark">Maintenance Mode</h3>
                    <p class="text-xs text-apple-text-gray mt-1">Dissable public access to the platform.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" value="" class="sr-only peer">
                    <div
                        class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-apple-gold">
                    </div>
                </label>
            </div>

            <div class="flex items-center justify-between p-4 bg-apple-gray rounded-xl border border-white/5">
                <div>
                    <h3 class="font-medium text-apple-dark">Allow New Registrations</h3>
                    <p class="text-xs text-apple-text-gray mt-1">Pause new user signups temporarily.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" value="" class="sr-only peer" checked>
                    <div
                        class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-apple-gold">
                    </div>
                </label>
            </div>
        </div>
    </div>
</div>