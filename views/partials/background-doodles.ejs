<!-- Background Doodles -->
<div id="doodle-container" class="absolute inset-0 pointer-events-none overflow-hidden z-0 opacity-60"
    aria-hidden="true">

    <!-- Graduation Cap (Left-Center) -->
    <svg class="parallax-layer absolute top-[8%] left-[15%] w-24 h-24 text-apple-dark/10 stroke-current rotate-[-5deg] hidden md:block"
        data-speed="0.04" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
        <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
    </svg>

    <!-- Scroll/Diploma (Right Edge) -->
    <svg class="parallax-layer absolute top-[18%] right-[5%] w-20 h-20 text-apple-gold/10 stroke-current rotate-[10deg] hidden lg:block"
        data-speed="0.03" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M8 2h8a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"></path>
        <path d="M12 18v-2"></path>
    </svg>

    <!-- Open Book (Center) -->
    <svg class="parallax-layer absolute top-[32%] left-[45%] w-32 h-32 text-apple-blue/5 stroke-current rotate-6 hidden xl:block"
        data-speed="0.02" viewBox="0 0 24 24" fill="none" stroke-width="1" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
    </svg>

    <!-- 1. Top Section (Global Doodles - Shifted to avoid Hero text/Big Doodle collision) -->
    <!-- Removed large abstract path here as it duplicates the Home Page main doodle -->

    <svg class="parallax-layer absolute top-[15%] right-[45%] w-24 h-24 text-apple-dark/10 stroke-current rotate-[-12deg]"
        data-speed="0.05" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
    </svg>

    <!-- 2. Mid-Top Section (25-35%) -->
    <svg class="parallax-layer absolute top-[28%] left-[8%] w-32 h-32 text-apple-gold/10 stroke-current rotate-[25deg] hidden md:block"
        data-speed="0.03" viewBox="0 0 24 24" fill="none" stroke-width="1" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path>
        <line x1="16" y1="8" x2="2" y2="22"></line>
        <line x1="17.5" y1="15" x2="9" y2="15"></line>
    </svg>

    <svg class="parallax-layer absolute top-[38%] right-[15%] w-24 h-24 text-apple-blue/5 stroke-current hidden sm:block"
        data-speed="0.02" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1 4-10 15.3 15.3 0 0 1 4-10z"></path>
    </svg>

    <!-- 3. Middle Section (45-55%) -->
    <svg class="parallax-layer absolute top-[52%] left-[60%] w-24 h-24 text-apple-blue/10 stroke-current rotate-[15deg] hidden md:block"
        data-speed="0.04" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round">
        <circle cx="6" cy="15" r="4"></circle>
        <circle cx="18" cy="15" r="4"></circle>
        <path d="M14 15a2 2 0 0 0-2-2 2 2 0 0 0-2 2"></path>
        <path d="M2.5 13L5 7c.7-1.3 1.4-2 3-2"></path>
        <path d="M21.5 13L19 7c-.7-1.3-1.4-2-3-2"></path>
    </svg>

    <svg class="parallax-layer absolute top-[55%] left-[10%] w-20 h-20 text-apple-dark/10 stroke-current rotate-[-10deg] hidden sm:block"
        data-speed="0.06" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M5 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16l-7-3.5L5 21V5z"></path>
    </svg>

    <!-- 4. Mid-Bottom Section (65-75%) -->
    <svg class="parallax-layer absolute top-[65%] right-[25%] w-32 h-32 text-apple-gold/5 stroke-current rotate-12 hidden lg:block"
        data-speed="0.03" viewBox="0 0 24 24" fill="none" stroke-width="1" stroke-linecap="round">
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
        <line x1="8" y1="21" x2="16" y2="21"></line>
        <line x1="12" y1="17" x2="12" y2="21"></line>
    </svg>

    <svg class="parallax-layer absolute top-[72%] left-[30%] w-24 h-24 text-apple-dark/5 stroke-current -rotate-6"
        data-speed="0.05" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round">
        <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
        <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
        <path d="M2 2l7.586 7.586"></path>
        <circle cx="11" cy="11" r="2"></circle>
    </svg>

    <!-- 5. Bottom Section (85-95%) -->
    <svg class="parallax-layer absolute top-[85%] right-[10%] w-40 h-40 text-apple-dark/5 stroke-current rotate-[6deg]"
        data-speed="0.03" viewBox="0 0 24 24" fill="none" stroke-width="1" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
        <path d="M6 5h14"></path>
        <path d="M6 9h14"></path>
    </svg>

    <svg class="parallax-layer absolute top-[92%] left-[20%] w-24 h-24 text-apple-gold/10 stroke-current rotate-[-5deg] hidden md:block"
        data-speed="0.05" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M8 2h8a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"></path>
        <path d="M12 10v6"></path>
        <path d="M8 22v-2c0-1.1.9-2 2-2h4a2 2 0 0 1 2 2v2H8z"></path>
    </svg>

    <!-- 6. Extra Deep Footer Area (105% for very long pages) -->
    <svg class="parallax-layer absolute top-[105%] left-[50%] -translate-x-1/2 w-32 h-32 text-apple-blue/5 stroke-current hidden xl:block"
        data-speed="0.02" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
    </svg>
</div>

<script>
    // Simple Mouse Parallax Effect
    document.addEventListener('mousemove', (e) => {
        const layers = document.querySelectorAll('.parallax-layer');

        const x = (window.innerWidth - e.pageX * 2) / 100;
        const y = (window.innerHeight - e.pageY * 2) / 100;

        layers.forEach(layer => {
            const speed = layer.getAttribute('data-speed') || 0.05;
            const xOffset = x * speed * 100;
            const yOffset = y * speed * 100;

            // Apply transform cleanly
            layer.style.transform = `translateX(${xOffset}px) translateY(${yOffset}px) rotate(${layer.style.rotate || '0deg'})`;
        });
    });
</script>