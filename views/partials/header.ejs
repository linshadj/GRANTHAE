<div class="fixed top-4 left-0 right-0 z-50 px-4 sm:px-6 lg:px-8">
    <nav
        class="max-w-5xl mx-auto bg-apple-card/70 backdrop-blur-xl border border-white/10 rounded-full shadow-2xl transition-all duration-300">
        <div class="px-6">
            <div class="flex justify-between items-center h-14">
                <!-- Logo -->
                <div class="flex-shrink-0 flex items-center gap-2 cursor-pointer hover:scale-105 transition-transform">
                    <div class="w-8 h-8 rounded-full bg-apple-blue/20 flex items-center justify-center">
                        <i data-lucide="book-open" class="h-4 w-4 text-apple-blue"></i>
                    </div>
                    <span
                        class="font-bold text-base tracking-tight text-apple-dark hidden sm:block font-luxury">GRANTHAE.</span>
                </div>

                <!-- Desktop Menu (Centered) -->
                <div class="hidden md:flex items-center space-x-1">
                    <a href="/home"
                        class="px-4 py-1.5 text-sm font-medium rounded-full transition-all <%= path === '/home' || path === '/' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark/70 hover:text-apple-dark hover:bg-white/5' %>">Home</a>
                    <a href="/marketplace"
                        class="px-4 py-1.5 text-sm font-medium rounded-full transition-all <%= path === '/marketplace' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark/70 hover:text-apple-dark hover:bg-white/5' %>">Marketplace</a>
                    <a href="/rental-place"
                        class="px-4 py-1.5 text-sm font-medium rounded-full transition-all <%= path === '/rental-place' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark/70 hover:text-apple-dark hover:bg-white/5' %>">Rentalplace</a>


                </div>

                <!-- Right Side Actions -->
                <div class="flex items-center gap-2">
                    <!-- Cart (Icon) -->
                    <a href="/cart"
                        class="p-2 transition-colors rounded-full relative group <%= path === '/cart' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark/70 hover:text-apple-dark hover:bg-white/10' %>">
                        <i data-lucide="shopping-bag" class="w-4 h-4"></i>
                        <span
                            class="absolute top-1.5 right-1.5 w-1.5 h-1.5 bg-apple-blue rounded-full border border-apple-card opacity-100 transition-opacity"></span>
                    </a>

                    <!-- Wishlist (Icon) -->
                    <a href="/wishlist"
                        class="p-2 transition-colors rounded-full relative group <%= path === '/wishlist' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark/70 hover:text-apple-dark hover:bg-white/10' %>">
                        <i data-lucide="heart" class="w-4 h-4"></i>
                        <span
                            class="absolute top-1.5 right-1.5 w-1.5 h-1.5 bg-red-500 rounded-full border border-apple-card <%= path === '/wishlist' ? 'opacity-100' : 'opacity-0' %> group-hover:opacity-100 transition-opacity"></span>
                    </a>

                    <!-- Search -->
                    <button id="navbar-search-btn" type="button" aria-label="Search books" aria-controls="navbar-search-panel" aria-expanded="false"
                        class="p-2 text-apple-dark/70 hover:text-apple-dark transition-colors rounded-full hover:bg-white/10">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </button>

                    <!-- Sell Button -->
                    <a href="/list-rental-book"
                        class="hidden md:flex items-center gap-2 px-4 py-1.5 text-xs font-semibold text-apple-dark bg-white/10 hover:bg-white/20 rounded-full transition-all mr-2">
                        <i data-lucide="plus" class="w-3 h-3"></i>
                        Sell
                    </a>


                    <!-- Auth -->
                    <div class="hidden md:flex items-center gap-2 pl-2 border-l border-white/10">
                        <% if (typeof user !=='undefined' && user) { %>
                            <!-- Logged In: Profile Icon -->
                            <a href="/profile"
                                class="p-1.5 ml-1 transition-colors rounded-full <%= path.startsWith('/profile') ? 'bg-white/10 text-apple-dark' : 'text-apple-dark/70 hover:text-apple-dark hover:bg-white/10' %>">
                                <i data-lucide="user" class="w-5 h-5"></i>
                            </a>
                            <% } else { %>
                                <!-- Guest: Login/Signup -->
                                <a href="/sign-in"
                                    class="px-4 py-1.5 text-xs font-semibold text-apple-dark hover:text-white transition-colors">
                                    Log in
                                </a>
                                <a href="/sign-up"
                                    class="px-4 py-1.5 text-xs font-semibold text-apple-gray bg-apple-blue hover:bg-apple-blue/90 rounded-full transition-all shadow-lg shadow-apple-blue/20">
                                    Sign Up
                                </a>
                                <% } %>
                    </div>

                    <!-- Mobile Menu Button -->
                    <button id="mobile-menu-btn"
                        class="md:hidden p-2 text-apple-dark hover:bg-white/10 rounded-full transition-colors">
                        <i data-lucide="menu" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu"
            class="absolute top-full left-0 right-0 mt-2 mx-4 p-4 bg-apple-card/95 backdrop-blur-3xl border border-white/10 rounded-2xl shadow-2xl transition-all duration-300 ease-in-out transform origin-top opacity-0 -translate-y-4 pointer-events-none invisible">
            <div class="flex flex-col space-y-1">
                <a href="/home"
                    class="px-4 py-2.5 text-base font-medium rounded-xl transition-colors <%= path === '/home' || path === '/' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark hover:bg-white/5' %>">Home</a>
                <a href="/marketplace"
                    class="px-4 py-2.5 text-base font-medium rounded-xl transition-colors <%= path === '/marketplace' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark hover:bg-white/5' %>">Marketplace</a>
                <a href="/rental-place"
                    class="px-4 py-2.5 text-base font-medium rounded-xl transition-colors <%= path === '/rental-place' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark hover:bg-white/5' %>">Rentalplace</a>

                <a href="/wishlist"
                    class="px-4 py-2.5 text-base font-medium rounded-xl transition-colors <%= path === '/wishlist' ? 'bg-white/10 text-apple-dark' : 'text-apple-dark hover:bg-white/5' %>">Wishlist</a>
                <a href="/list-rental-book"
                    class="px-4 py-2.5 text-base font-medium text-apple-dark hover:bg-white/5 rounded-xl transition-colors">Sell
                    Book</a>

                <div class="h-px bg-white/10 my-2"></div>
                <!-- Mobile Auth -->
                <div class="flex items-center gap-3 px-4 pt-2">
                    <% if (typeof user !=='undefined' && user) { %>
                        <a href="/profile"
                            class="flex-1 py-2.5 text-center text-sm font-semibold rounded-xl transition-colors <%= path.startsWith('/profile') ? 'bg-white/10 text-apple-dark' : 'text-apple-dark hover:bg-white/5' %>">
                            My Profile
                        </a>
                        <% } else { %>
                            <a href="/login"
                                class="flex-1 py-2.5 text-center text-sm font-semibold text-apple-dark hover:bg-white/5 rounded-xl transition-colors">Log
                                in</a>
                            <a href="/sign-up"
                                class="flex-1 py-2.5 text-center text-sm font-semibold text-apple-gray bg-apple-blue shadow-lg shadow-apple-blue/20 rounded-xl transition-transform active:scale-95">Sign
                                Up</a>
                            <% } %>
                </div>
            </div>
        </div>

        <!-- Navbar Search -->
        <div id="navbar-search-panel"
            class="absolute top-full left-0 right-0 mt-2 mx-4 p-3 bg-apple-card/95 backdrop-blur-3xl border border-white/10 rounded-2xl shadow-2xl transition-all duration-300 ease-in-out transform origin-top opacity-0 -translate-y-4 pointer-events-none invisible">
            <form action="/marketplace" method="GET" id="navbar-search-form" class="relative group">
                <button type="submit" aria-label="Search"
                    class="absolute left-4 top-1/2 -translate-y-1/2 p-1 text-apple-text-gray group-focus-within:text-apple-blue transition-colors">
                    <i data-lucide="search" class="w-4 h-4"></i>
                </button>
                <input id="navbar-search-input" type="text" name="search"
                    value="<%= path === '/marketplace' && typeof query !== 'undefined' ? (query.search || '') : '' %>"
                    placeholder="Search books by title or author..."
                    class="w-full pl-12 pr-12 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-apple-dark placeholder-apple-text-gray focus:ring-2 focus:ring-apple-blue/20 focus:border-apple-blue outline-none transition-all">
                <button id="navbar-search-close" type="button" aria-label="Close search"
                    class="absolute right-4 top-1/2 -translate-y-1/2 p-1 text-apple-text-gray hover:text-apple-dark hover:bg-white/10 rounded-full transition-colors">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </form>
        </div>
    </nav>
</div>

<!-- Spacer -->
<div class="h-24"></div>

<script>
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const searchBtn = document.getElementById('navbar-search-btn');
    const searchPanel = document.getElementById('navbar-search-panel');
    const searchInput = document.getElementById('navbar-search-input');
    const searchClose = document.getElementById('navbar-search-close');
    const searchForm = document.getElementById('navbar-search-form');

    if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
            const isClosed = mobileMenu.classList.contains('invisible');

            if (isClosed) {
                // Open
                closeNavbarSearch();
                mobileMenu.classList.remove('invisible', 'opacity-0', '-translate-y-4', 'pointer-events-none');
                mobileMenu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            } else {
                // Close
                mobileMenu.classList.add('invisible', 'opacity-0', '-translate-y-4', 'pointer-events-none');
                mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            }
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
            if (!mobileBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
                mobileMenu.classList.add('invisible', 'opacity-0', '-translate-y-4', 'pointer-events-none');
                mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            }
        });
    }

    function openNavbarSearch() {
        if (!searchPanel || !searchBtn || !searchInput) return;

        if (mobileMenu) {
            mobileMenu.classList.add('invisible', 'opacity-0', '-translate-y-4', 'pointer-events-none');
            mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        }

        searchPanel.classList.remove('invisible', 'opacity-0', '-translate-y-4', 'pointer-events-none');
        searchPanel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        searchBtn.setAttribute('aria-expanded', 'true');
        setTimeout(() => searchInput.focus(), 120);
    }

    function closeNavbarSearch() {
        if (!searchPanel || !searchBtn) return;

        searchPanel.classList.add('invisible', 'opacity-0', '-translate-y-4', 'pointer-events-none');
        searchPanel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        searchBtn.setAttribute('aria-expanded', 'false');
    }

    if (searchBtn && searchPanel) {
        searchBtn.addEventListener('click', () => {
            const isClosed = searchPanel.classList.contains('invisible');
            if (isClosed) {
                openNavbarSearch();
            } else {
                closeNavbarSearch();
            }
        });

        if (searchClose) {
            searchClose.addEventListener('click', closeNavbarSearch);
        }

        if (searchForm && searchInput) {
            searchForm.addEventListener('submit', (event) => {
                searchInput.value = searchInput.value.trim();
                if (!searchInput.value.trim()) {
                    event.preventDefault();
                    window.location.href = '/marketplace';
                }
            });
        }

        document.addEventListener('click', (event) => {
            if (!searchBtn.contains(event.target) && !searchPanel.contains(event.target)) {
                closeNavbarSearch();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                closeNavbarSearch();
            }
        });
    }
</script>
