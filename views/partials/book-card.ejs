<div
    class="glass-card group relative p-3 flex flex-col h-full overflow-hidden hover:scale-[1.02] transition-all duration-500">
    <div class="relative aspect-[2/3] w-full overflow-hidden rounded-xl bg-gray-100">
        <img src="<%= book.image %>" alt="<%= book.title %>"
            class="h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-110">

        <!-- Hover Overlay -->
        <div
            class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-2">
            <button class="bg-white/90 p-2 rounded-full text-apple-dark hover:bg-white transition-colors"
                title="Quick View">
                <i data-lucide="eye" class="w-5 h-5"></i>
            </button>
            <a href="/wishlist"
                class="bg-white/90 p-2 rounded-full text-apple-dark hover:bg-white transition-colors flex items-center justify-center"
                title="View Wishlist">
                <i data-lucide="heart" class="w-5 h-5"></i>
            </a>
        </div>

        <div
            class="absolute top-2 right-2 bg-white/90 backdrop-blur-md px-2 py-1 rounded-lg text-xs font-semibold text-apple-dark">
            $<%= book.price %>
                <%= (typeof type !=='undefined' && type==='buy' ) ? '' : '/day' %>
        </div>
    </div>

    <div class="mt-4 flex flex-col flex-grow">
        <div class="flex justify-between items-start">
            <div>
                <span
                    class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-apple-text-gray ring-1 ring-inset ring-gray-500/10 mb-2">
                    <%= book.genre %>
                </span>
                <h3
                    class="text-base font-semibold text-apple-dark group-hover:text-apple-blue transition-colors clamp-1">
                    <a href="/book/1<%= (typeof type !== 'undefined' && type === 'buy') ? '?type=buy' : '' %>">
                        <span class="absolute inset-0"></span>
                        <%= book.title %>
                    </a>
                </h3>
            </div>
        </div>
        <p class="mt-1 text-sm text-apple-text-gray">
            <%= book.author %>
        </p>

        <div class="mt-auto pt-4 flex items-center justify-between border-t border-gray-100/50">
            <div class="flex items-center">
                <i data-lucide="star" class="h-4 w-4 text-yellow-400 fill-current"></i>
                <span class="ml-1 text-sm text-apple-text-gray">
                    <%= book.rating %>
                </span>
            </div>
            <div class="flex items-center text-green-600 text-xs font-medium">
                <span class="w-2 h-2 bg-green-500 rounded-full mr-1 animate-pulse"></span>
                Available
            </div>
        </div>
    </div>
</div>