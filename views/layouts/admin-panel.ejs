<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | Admin Panel' : 'Admin Panel' %>
    </title>
    <link href="/css/style.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
</head>

<body class="bg-apple-gray text-apple-dark font-sans antialiased min-h-screen relative">

    <%- include('../partials/background-doodles') %>

        <div class="flex min-h-screen transition-all duration-300" id="content-wrapper">
            <%- include('../partials/admin-sidebar') %>

                <main class="flex-1 md:ml-64 p-8 animate-fade-in w-full">
                    <!-- Top Bar for Mobile/Tablet context -->
                    <div class="md:hidden flex items-center justify-between mb-8">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-lg bg-apple-gold flex items-center justify-center">
                                <i data-lucide="shield-check" class="h-4 w-4 text-[#1a231e]"></i>
                            </div>
                        </div>
                        <button id="admin-menu-btn"
                            class="p-2 text-gray-600 hover:bg-black/5 rounded-full transition-colors">
                            <i data-lucide="menu" class="w-6 h-6"></i>
                        </button>
                    </div>

                    <!-- Page Header -->
                    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <div>
                            <h1 class="text-3xl font-bold font-serif text-apple-dark">
                                <%= title %>
                            </h1>
                            <p class="text-apple-text-gray mt-1 text-sm">
                                <%= typeof subtitle !=='undefined' ? subtitle : 'Manage your platform efficiently.' %>
                            </p>
                        </div>
                        <div class="flex gap-3">
                            <div
                                class="bg-white/10 px-4 py-2 rounded-lg shadow-sm border border-white/5 flex items-center gap-2 text-sm text-apple-dark">
                                <i data-lucide="calendar" class="w-4 h-4 text-apple-gold"></i>
                                <span>
                                    <%= new Date().toLocaleDateString('en-US', { weekday: 'long' , year: 'numeric' ,
                                        month: 'long' , day: 'numeric' }) %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <%- body %>
                </main>
        </div>

        <script>

            const adminMenuBtn = document.getElementById('admin-menu-btn');
            const adminSidebar = document.getElementById('admin-sidebar');
            const sidebarOverlay = document.getElementById('sidebar-overlay');

            if (adminMenuBtn && adminSidebar) {
                adminMenuBtn.addEventListener('click', () => {
                    adminSidebar.classList.remove('-translate-x-full');
                    if (sidebarOverlay) {
                        sidebarOverlay.classList.remove('hidden');
                        setTimeout(() => sidebarOverlay.classList.remove('opacity-0'), 10);
                    }
                });

                // Close on overlay click
                if (sidebarOverlay) {
                    sidebarOverlay.addEventListener('click', () => {
                        adminSidebar.classList.add('-translate-x-full');
                        sidebarOverlay.classList.add('opacity-0');
                        setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
                    });
                }
            }
        </script>

        <!-- Logout Confirmation Modal -->
        <div id="logout-confirm-modal" class="fixed inset-0 z-[9999] hidden" role="dialog" aria-modal="true">
            <div class="fixed inset-0 bg-black/90 backdrop-blur-md transition-opacity opacity-0"
                id="logout-modal-backdrop"></div>
            <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
                <div class="flex min-h-full items-center justify-center p-4 text-center">
                    <div class="relative transform overflow-hidden rounded-2xl bg-apple-card text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-md opacity-0 translate-y-4 scale-95 border border-white/10"
                        id="logout-modal-panel">
                        <div class="p-8 text-center space-y-4">
                            <div
                                class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i data-lucide="alert-circle" class="w-8 h-8 text-red-500"></i>
                            </div>
                            <h3 class="text-xl font-bold text-apple-dark font-serif">Confirm Logout</h3>
                            <p class="text-apple-text-gray text-sm">Are you sure you want to log out? You will need to
                                sign in again to access your account.</p>
                        </div>
                        <div class="p-6 border-t border-white/10 bg-white/5 flex gap-3">
                            <button type="button" onclick="closeLogoutModal()"
                                class="flex-1 px-4 py-2 bg-white/5 text-apple-dark hover:bg-white/10 rounded-lg text-sm transition-all font-medium border border-white/10">
                                Cancel
                            </button>
                            <a href="/admin/logout"
                                class="flex-1 px-4 py-2 bg-red-500 text-white hover:bg-red-600 rounded-lg text-sm transition-all font-medium text-center shadow-lg shadow-red-500/20 active:scale-95">
                                Log Out
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            const logoutModal = document.getElementById('logout-confirm-modal');
            const logoutBackdrop = document.getElementById('logout-modal-backdrop');
            const logoutPanel = document.getElementById('logout-modal-panel');
            const contentWrapper = document.getElementById('content-wrapper');

            function toggleModalState(isOpen) {
                if (isOpen) {
                    document.body.classList.add('overflow-hidden');
                    if (contentWrapper) {
                        contentWrapper.classList.add('blur-md', 'pointer-events-none', 'scale-[0.98]', 'opacity-50');
                    }
                } else {
                    document.body.classList.remove('overflow-hidden');
                    if (contentWrapper) {
                        contentWrapper.classList.remove('blur-md', 'pointer-events-none', 'scale-[0.98]', 'opacity-50');
                    }
                }
            }

            function openLogoutModal() {
                if (!logoutModal) return;
                toggleModalState(true);
                logoutModal.classList.remove('hidden');
                setTimeout(() => {
                    logoutBackdrop.classList.remove('opacity-0');
                    logoutPanel.classList.remove('opacity-0', 'translate-y-8', 'scale-95');
                    logoutPanel.classList.add('opacity-100', 'translate-y-0', 'scale-100');
                }, 10);
            }

            function closeLogoutModal() {
                if (!logoutModal) return;
                logoutBackdrop.classList.add('opacity-0');
                logoutPanel.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
                logoutPanel.classList.add('opacity-0', 'translate-y-8', 'scale-95');

                setTimeout(() => {
                    logoutModal.classList.add('hidden');
                    toggleModalState(false);
                }, 200);
            }

            if (logoutBackdrop) {
                logoutBackdrop.addEventListener('click', closeLogoutModal);
            }

            // Ensure all icons are created after everything is in the DOM
            lucide.createIcons();
        </script>
        <%- include('../partials/notifications') %>
</body>

</html>