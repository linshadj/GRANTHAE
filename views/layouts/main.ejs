<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | GRANTHAE' : 'GRANTHAE' %>
    </title>
    <link href="/css/style.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Marcellus&family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Using Lucide for Icons -->
</head>

<body
    class="bg-apple-gray text-apple-dark font-sans antialiased min-h-screen flex flex-col relative selection:bg-apple-dark selection:text-apple-dark">


    <%- include('../partials/background-doodles') %>

        <%- include('../partials/header') %>

            <main class="flex-grow animate-fade-in">
                <%- body %>
            </main>

            <%- include('../partials/footer') %>
                <%- include('../partials/notifications') %>

                    <script>
                        lucide.createIcons();

                        async function addToWishlistGlobal(productId, variant = '', btn = null) {
                            try {
                                // If btn is not passed, try to find it if it was called via event
                                if (!btn && window.event) btn = window.event.currentTarget;

                                const res = await fetch('/wishlist/add', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ productId, variant })
                                });
                                const data = await res.json();
                                
                                if (data.success) {
                                    Swal.fire({
                                        toast: true,
                                        position: 'top-end',
                                        icon: data.action === 'added' ? 'success' : 'info',
                                        title: data.message,
                                        showConfirmButton: false,
                                        timer: 3000
                                    });

                                    // Toggle UI state if btn is available
                                    if (btn) {
                                        const icon = btn.querySelector('i[data-lucide="heart"]');
                                        if (data.action === 'added') {
                                            btn.classList.add('text-red-500');
                                            if (icon) icon.classList.add('fill-current');
                                            // Handle text if present (for product details page)
                                            const textNode = Array.from(btn.childNodes).find(n => n.nodeType === 3 && n.textContent.trim().length > 1);
                                            if (textNode) textNode.textContent = ' Wishlisted';
                                        } else {
                                            btn.classList.remove('text-red-500');
                                            if (icon) icon.classList.remove('fill-current');
                                            const textNode = Array.from(btn.childNodes).find(n => n.nodeType === 3 && n.textContent.trim().length > 1);
                                            if (textNode) textNode.textContent = ' Wishlist';
                                        }
                                    }

                                    if(typeof lucide !== 'undefined') lucide.createIcons();
                                } else {
                                    if (res.status === 401 || (data.message && (data.message.toLowerCase().includes('login') || data.message.toLowerCase().includes('unauthorized')))) {
                                        window.location.href = '/sign-in';
                                    } else {
                                        Swal.fire({
                                            toast: true,
                                            position: 'top-end',
                                            icon: 'error',
                                            title: data.message || 'Something went wrong',
                                            showConfirmButton: false,
                                            timer: 3000
                                        });
                                    }
                                }
                            } catch (err) {
                                console.error(err);
                            }
                        }
                    </script>
</body>

</html>