<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' | Admin' : 'Admin' %>
    </title>
    <link href="/css/style.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Marcellus&family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-apple-gray text-apple-dark font-sans antialiased min-h-screen relative">

    <%- include('../partials/background-doodles') %>

        <div class="flex min-h-screen">
            <%- include('../partials/sidebar') %>

                <main class="flex-1 md:ml-64 p-8 animate-fade-in">
                    <!-- Top Bar for Mobile/Tablet context -->
                    <div class="md:hidden flex items-center justify-between mb-8">
                        <div class="flex items-center gap-2">
                            <i data-lucide="book-open" class="h-6 w-6 text-apple-dark"></i>
                            <span class="font-bold text-lg font-luxury">GRANTHAE.</span>
                        </div>
                        <button id="admin-menu-btn"
                            class="p-2 text-apple-text-gray hover:bg-white/10 rounded-full transition-colors">
                            <i data-lucide="menu" class="w-6 h-6"></i>
                        </button>
                    </div>

                    <%- body %>
                </main>
        </div>

        <script>
            lucide.createIcons();

            const adminMenuBtn = document.getElementById('admin-menu-btn');
            const adminSidebar = document.getElementById('admin-sidebar');
            const sidebarOverlay = document.getElementById('sidebar-overlay');

            if (adminMenuBtn && adminSidebar) {
                adminMenuBtn.addEventListener('click', () => {
                    adminSidebar.classList.remove('-translate-x-full');
                    if (sidebarOverlay) {
                        sidebarOverlay.classList.remove('hidden');
                        // small timeout to allow fade in
                        setTimeout(() => sidebarOverlay.classList.remove('opacity-0'), 10);
                    }
                });

                // Close on overlay click
                if (sidebarOverlay) {
                    sidebarOverlay.addEventListener('click', () => {
                        adminSidebar.classList.add('-translate-x-full');
                        sidebarOverlay.classList.add('opacity-0');
                        setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
                    });
                }
            }
        </script>
</body>

</html>