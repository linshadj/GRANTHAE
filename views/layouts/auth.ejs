<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= typeof title !=='undefined' ? title + ' | GRANTHAE' : 'GRANTHAE' %>
  </title>
  <link href="/css/style.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Marcellus&family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
    rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-apple-gray font-sans antialiased min-h-screen flex items-center justify-center p-4 relative">
  <!-- Background Doodles -->
  <%- include('../partials/background-doodles') %>

    <div class="w-full max-w-md animate-fade-in-up relative z-10">
      <!-- Logo Header -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 mb-2 group">
          <i data-lucide="book-open"
            class="h-8 w-8 text-apple-dark group-hover:scale-110 transition-transform duration-300"></i>
        </a>
        <h2 class="text-2xl font-bold text-apple-dark">
          <%= title %>
        </h2>
        <p class="mt-2 text-sm text-apple-text-gray">Welcome back to the community library.</p>
      </div>

      <!-- Main Content Card -->
      <div class="glass-card p-8 shadow-premium"><%- body %></div>

      <div class="mt-8 text-center text-xs text-apple-text-gray">
        &copy; 2026 GRANTHAE. All rights reserved.
      </div>
    </div>

    <script>
      lucide.createIcons();
    </script>
    <%- include('../partials/notifications') %>
</body>

</html>